<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Edit Car – Brajwasi Travels Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
:root{--gold:#B8731A;--gold-2:#D4882A;--dark:#0D1117;--dark-2:#161B22;--dark-3:#21262D;--text:#E6EDF3;--muted:#8B949E;--green:#3FB950;--border:rgba(255,255,255,0.07);--r:10px;}
*{box-sizing:border-box;margin:0;padding:0;}body{font-family:'DM Sans',sans-serif;background:var(--dark);color:var(--text);min-height:100vh;}
.header{background:var(--dark-2);border-bottom:1px solid var(--border);padding:14px 24px;display:flex;align-items:center;gap:16px;}
.header h1{font-family:'Playfair Display',serif;font-size:18px;}
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;border:none;transition:all 0.2s;text-decoration:none;}
.btn-gold{background:linear-gradient(135deg,var(--gold),var(--gold-2));color:#fff;}
.btn-sec{background:var(--dark-3);color:var(--muted);border:1px solid var(--border);}
.container{max-width:800px;margin:32px auto;padding:0 20px;}
.card{background:var(--dark-2);border:1px solid var(--border);border-radius:var(--r);padding:28px;}
.card-title{font-family:'Playfair Display',serif;font-size:22px;margin-bottom:24px;display:flex;align-items:center;gap:8px;}
.card-title i{color:var(--gold);}
.fg{margin-bottom:16px;}
.fg label{display:block;font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:5px;}
input,textarea,select{width:100%;background:var(--dark-3);border:1px solid rgba(255,255,255,0.1);color:var(--text);padding:10px 12px;border-radius:7px;font-size:13px;font-family:'DM Sans',sans-serif;outline:none;transition:all 0.2s;}
input:focus,textarea:focus,select:focus{border-color:var(--gold);}
.grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.preview{width:100%;height:160px;object-fit:cover;border-radius:8px;border:1px solid var(--border);margin-bottom:10px;}
.actions{display:flex;gap:12px;margin-top:20px;}
@media(max-width:600px){.grid{grid-template-columns:1fr;}}
</style>
</head>
<body>
<div class="header">
  <a href="/admin" class="btn btn-sec"><i class="fas fa-arrow-left"></i> Back</a>
  <h1>Edit Car: <%= car.model %></h1>
</div>
<div class="container">
  <div class="card">
    <div class="card-title"><i class="fas fa-edit"></i> Edit Car Details</div>
    <img src="<%= car.image %>" class="preview" id="img-preview" onerror="this.src='/images/default-crysta.jpg'" alt="Current car photo">
    <form method="POST" action="/admin/cars/<%= car._id %>/edit" enctype="multipart/form-data">
      <div class="grid">
        <div class="fg"><label>Car Brand *</label><input type="text" name="name" value="<%= car.name %>" required></div>
        <div class="fg"><label>Car Model *</label><input type="text" name="model" value="<%= car.model %>" required></div>
        <div class="fg"><label>Update Photo (leave blank to keep current)</label><input type="file" name="image" accept="image/*" onchange="previewImage(this)"></div>
        <div class="fg"><label>Available In (comma separated)</label><input type="text" name="availableIn" value="<%= car.availableIn.join(', ') %>"></div>
        <div class="fg"><label>Price Per KM (₹) *</label><input type="number" name="pricePerKm" value="<%= car.pricePerKm %>" required min="1"></div>
        <div class="fg"><label>Extra KM Charge (₹) *</label><input type="number" name="extraKmCharge" value="<%= car.extraKmCharge %>" required min="1"></div>
        <div class="fg"><label>Fixed Package KM</label><input type="number" name="fixedKm" value="<%= car.fixedPackage && car.fixedPackage.km ? car.fixedPackage.km : '' %>" placeholder="e.g. 300"></div>
        <div class="fg"><label>Fixed Package Price (₹)</label><input type="number" name="fixedPrice" value="<%= car.fixedPackage && car.fixedPackage.price ? car.fixedPackage.price : '' %>" placeholder="e.g. 3200"></div>
        <div class="fg"><label>Toll Tax Info</label><input type="text" name="tollTax" value="<%= car.tollTax %>"></div>
        <div class="fg"><label>Seats</label><select name="seats">
          <option value="4" <%=car.seats==4?'selected':''%>>4</option>
          <option value="5" <%=car.seats==5?'selected':''%>>5</option>
          <option value="6" <%=car.seats==6?'selected':''%>>6</option>
          <option value="7" <%=car.seats==7?'selected':''%>>7</option>
          <option value="8" <%=car.seats==8?'selected':''%>>8</option>
          <option value="12" <%=car.seats==12?'selected':''%>>12</option>
        </select></div>
        <div class="fg"><label>AC</label><select name="ac">
          <option value="true" <%=car.ac?'selected':''%>>AC ✅</option>
          <option value="false" <%=!car.ac?'selected':''%>>Non-AC</option>
        </select></div>
      </div>
      <div class="fg"><label>Description</label><textarea name="description" rows="3"><%= car.description||'' %></textarea></div>
      <div class="actions">
        <button type="submit" class="btn btn-gold"><i class="fas fa-save"></i> Save Changes</button>
        <a href="/admin" class="btn btn-sec"><i class="fas fa-times"></i> Cancel</a>
      </div>
    </form>
  </div>
</div>
<script>
function previewImage(input) {
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = e => document.getElementById('img-preview').src = e.target.result;
    reader.readAsDataURL(input.files[0]);
  }
}
</script>
</body>
</html>
