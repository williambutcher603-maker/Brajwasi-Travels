<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Edit Car – Brajwasi Travels</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
  :root { --gold: #C9922A; --dark: #0D1117; --dark-2: #161B22; --dark-3: #21262D; --text: #E6EDF3; --text-muted: #8B949E; --red: #F85149; --radius: 12px; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'DM Sans', sans-serif; background: var(--dark); color: var(--text); min-height: 100vh; display: flex; align-items: flex-start; justify-content: center; padding: 40px 20px; }
  .card { background: var(--dark-2); border: 1px solid rgba(255,255,255,0.06); border-radius: var(--radius); width: 100%; max-width: 700px; overflow: hidden; }
  .card-head { padding: 20px 28px; border-bottom: 1px solid rgba(255,255,255,0.06); display: flex; justify-content: space-between; align-items: center; }
  .card-head h2 { font-family: 'Playfair Display', serif; font-size: 20px; }
  form { padding: 28px; }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-group.full { grid-column: 1 / -1; }
  label { font-size: 11px; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
  input[type="text"], input[type="number"], input[type="file"], textarea, select { background: var(--dark-3); border: 1px solid rgba(255,255,255,0.1); color: var(--text); padding: 10px 14px; border-radius: 8px; font-size: 13px; font-family: 'DM Sans', sans-serif; outline: none; transition: border-color 0.2s; width: 100%; }
  input:focus, textarea:focus, select:focus { border-color: var(--gold); }
  select option { background: var(--dark-3); }
  .current-img { width: 140px; height: 90px; object-fit: cover; border-radius: 10px; border: 1px solid rgba(255,255,255,0.1); display: block; margin-bottom: 8px; }
  .btn { display: inline-flex; align-items: center; gap: 7px; padding: 10px 20px; border-radius: 8px; font-size: 14px; font-weight: 700; cursor: pointer; border: none; transition: all 0.2s; text-decoration: none; font-family: 'DM Sans', sans-serif; }
  .btn-gold { background: linear-gradient(135deg, var(--gold), #9B6F1A); color: #fff; }
  .btn-gold:hover { opacity: 0.9; }
  .btn-secondary { background: var(--dark-3); color: var(--text-muted); border: 1px solid rgba(255,255,255,0.1); }
  .btn-actions { display: flex; gap: 12px; margin-top: 24px; }
  @media (max-width: 600px) { .form-grid { grid-template-columns: 1fr; } }
</style>
</head>
<body>
<div class="card">
  <div class="card-head">
    <h2><i class="fas fa-edit" style="color:var(--gold);margin-right:8px"></i> Edit Car</h2>
    <a href="/admin" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
  </div>
  <form method="POST" action="/admin/cars/<%= car._id %>/edit" enctype="multipart/form-data">
    <div class="form-grid">
      <div class="form-group">
        <label>Car Brand *</label>
        <input type="text" name="name" value="<%= car.name %>" required>
      </div>
      <div class="form-group">
        <label>Car Model *</label>
        <input type="text" name="model" value="<%= car.model %>" required>
      </div>
      <div class="form-group full">
        <label>Current Photo</label>
        <img src="<%= car.image %>" class="current-img" onerror="this.src='/images/default-crysta.jpg'" alt="Current">
        <label>Upload New Photo (leave empty to keep current)</label>
        <input type="file" name="image" accept="image/*">
      </div>
      <div class="form-group">
        <label>Price Per KM (₹) *</label>
        <input type="number" name="pricePerKm" value="<%= car.pricePerKm %>" required min="1">
      </div>
      <div class="form-group">
        <label>Extra KM Charge (₹) *</label>
        <input type="number" name="extraKmCharge" value="<%= car.extraKmCharge %>" required min="1">
      </div>
      <div class="form-group">
        <label>Fixed Package KM</label>
        <input type="number" name="fixedKm" value="<%= (car.fixedPackage && car.fixedPackage.km) ? car.fixedPackage.km : '' %>" placeholder="300 (optional)">
      </div>
      <div class="form-group">
        <label>Fixed Package Price (₹)</label>
        <input type="number" name="fixedPrice" value="<%= (car.fixedPackage && car.fixedPackage.price) ? car.fixedPackage.price : '' %>" placeholder="3200 (optional)">
      </div>
      <div class="form-group">
        <label>Toll Tax Info</label>
        <input type="text" name="tollTax" value="<%= car.tollTax %>">
      </div>
      <div class="form-group">
        <label>Available In</label>
        <input type="text" name="availableIn" value="<%= car.availableIn.join(', ') %>" placeholder="Agra, Delhi">
      </div>
      <div class="form-group">
        <label>Seating Capacity</label>
        <select name="seats">
          <% [4,5,6,7,8,12].forEach(n => { %>
          <option value="<%= n %>" <%= car.seats === n ? 'selected' : '' %>><%= n %> Seater</option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>Air Conditioning</label>
        <select name="ac">
          <option value="true" <%= car.ac ? 'selected' : '' %>>AC ✅</option>
          <option value="false" <%= !car.ac ? 'selected' : '' %>>Non-AC</option>
        </select>
      </div>
      <div class="form-group full">
        <label>Description</label>
        <textarea name="description" rows="3"><%= car.description || '' %></textarea>
      </div>
    </div>
    <div class="btn-actions">
      <button type="submit" class="btn btn-gold"><i class="fas fa-save"></i> Save Changes</button>
      <a href="/admin" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a>
    </div>
  </form>
</div>
</body>
</html>
