<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin – Brajwasi Travels</title>
<link rel="manifest" href="/manifest.json">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
:root{--gold:#B8731A;--gold-2:#D4882A;--gold-lt:#F5A623;--dark:#0D1117;--dark-2:#161B22;--dark-3:#21262D;--text:#E6EDF3;--muted:#8B949E;--green:#3FB950;--red:#F85149;--blue:#58A6FF;--border:rgba(255,255,255,0.07);--r:10px;}
*{box-sizing:border-box;margin:0;padding:0;}body{font-family:'DM Sans',sans-serif;background:var(--dark);color:var(--text);min-height:100vh;}
.sidebar{position:fixed;left:0;top:0;bottom:0;width:230px;background:var(--dark-2);border-right:1px solid var(--border);padding:20px 0;display:flex;flex-direction:column;z-index:100;}
.sb-brand{padding:0 16px 20px;border-bottom:1px solid var(--border);margin-bottom:12px;}
.sb-icon{width:38px;height:38px;background:linear-gradient(135deg,var(--gold),var(--gold-2));border-radius:9px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:15px;margin-bottom:8px;}
.sb-brand h1{font-family:'Playfair Display',serif;font-size:14px;color:var(--text);line-height:1.2;}
.sb-brand span{font-size:10px;color:var(--gold-lt);letter-spacing:1.5px;text-transform:uppercase;}
.nav-item{display:flex;align-items:center;gap:9px;padding:10px 16px;color:var(--muted);text-decoration:none;font-size:13px;transition:all 0.2s;cursor:pointer;border:none;background:none;width:100%;text-align:left;border-left:2px solid transparent;}
.nav-item:hover,.nav-item.active{color:var(--text);background:rgba(255,255,255,0.04);border-left-color:var(--gold);}
.nav-item i{width:16px;font-size:12px;color:var(--muted);}
.nav-item.active i,.nav-item:hover i{color:var(--gold-lt);}
.nav-item .nb{background:var(--red);color:#fff;font-size:10px;font-weight:700;padding:1px 6px;border-radius:10px;margin-left:auto;}
.sb-footer{margin-top:auto;padding:14px 0;border-top:1px solid var(--border);}
.main{margin-left:230px;min-height:100vh;}
.topbar{background:var(--dark-2);border-bottom:1px solid var(--border);padding:14px 24px;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;z-index:50;}
.topbar h2{font-size:17px;font-weight:600;}
.content{padding:24px;}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;}
.stat-c{background:var(--dark-2);border:1px solid var(--border);border-radius:var(--r);padding:18px 20px;}
.stat-c .lbl{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:6px;}
.stat-c .num{font-family:'Playfair Display',serif;font-size:32px;color:var(--text);}
.stat-c .ico{float:right;width:40px;height:40px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:16px;}
.ic-g{background:rgba(63,185,80,0.12);color:var(--green);}
.ic-gold{background:rgba(184,115,26,0.15);color:var(--gold-lt);}
.ic-b{background:rgba(88,166,255,0.12);color:var(--blue);}
.ic-r{background:rgba(248,81,73,0.12);color:var(--red);}
.card{background:var(--dark-2);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin-bottom:20px;}
.card-hd{padding:16px 20px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;}
.card-hd h3{font-size:15px;font-weight:600;display:flex;align-items:center;gap:7px;}
.card-hd h3 i{color:var(--gold-lt);}
.tp{display:none;}.tp.active{display:block;}
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;border:none;transition:all 0.2s;text-decoration:none;}
.btn-gold{background:linear-gradient(135deg,var(--gold),var(--gold-2));color:#fff;}
.btn-sm{padding:5px 10px;font-size:11px;}
.btn-danger{background:rgba(248,81,73,0.12);color:var(--red);border:1px solid rgba(248,81,73,0.2);}
.btn-danger:hover{background:rgba(248,81,73,0.22);}
.btn-sec{background:var(--dark-3);color:var(--muted);border:1px solid var(--border);}
.btn-sec:hover{color:var(--text);}
.btn-blue{background:rgba(88,166,255,0.12);color:var(--blue);border:1px solid rgba(88,166,255,0.2);}
.fg{margin-bottom:14px;}
.fg label{display:block;font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:5px;}
input,textarea,select{width:100%;background:var(--dark-3);border:1px solid rgba(255,255,255,0.1);color:var(--text);padding:9px 12px;border-radius:7px;font-size:13px;font-family:'DM Sans',sans-serif;outline:none;transition:all 0.2s;}
input:focus,textarea:focus,select:focus{border-color:var(--gold);}
select option{background:var(--dark-3);}
.fg-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.fg-full{grid-column:1/-1;}
table{width:100%;border-collapse:collapse;font-size:13px;}
th{padding:10px 14px;text-align:left;font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.8px;border-bottom:1px solid var(--border);background:var(--dark-3);}
td{padding:11px 14px;border-bottom:1px solid rgba(255,255,255,0.03);vertical-align:middle;}
tr:hover td{background:rgba(255,255,255,0.015);}
.car-thumb{width:72px;height:48px;object-fit:cover;border-radius:7px;border:1px solid var(--border);}
.badge{display:inline-flex;align-items:center;padding:3px 9px;border-radius:16px;font-size:11px;font-weight:600;}
.b-active{background:rgba(63,185,80,0.12);color:var(--green);border:1px solid rgba(63,185,80,0.25);}
.b-inactive{background:rgba(248,81,73,0.1);color:var(--red);border:1px solid rgba(248,81,73,0.2);}
.b-avail{background:rgba(63,185,80,0.12);color:var(--green);border:1px solid rgba(63,185,80,0.2);}
.b-unavail{background:rgba(248,81,73,0.1);color:var(--red);border:1px solid rgba(248,81,73,0.15);}
.b-pending{background:rgba(245,166,35,0.12);color:var(--gold-lt);border:1px solid rgba(245,166,35,0.25);}
.b-adv{background:rgba(88,166,255,0.1);color:var(--blue);border:1px solid rgba(88,166,255,0.2);}
.b-confirmed{background:rgba(63,185,80,0.12);color:var(--green);border:1px solid rgba(63,185,80,0.2);}
.b-completed{background:rgba(88,166,255,0.1);color:var(--blue);border:1px solid rgba(88,166,255,0.2);}
.b-cancelled{background:rgba(248,81,73,0.1);color:var(--red);border:1px solid rgba(248,81,73,0.15);}
.toggle-switch{position:relative;width:42px;height:22px;cursor:pointer;}
.toggle-switch input{opacity:0;width:0;height:0;}
.slider{position:absolute;inset:0;background:var(--dark-3);border-radius:22px;transition:0.3s;border:1px solid var(--border);}
.slider::before{content:'';position:absolute;height:16px;width:16px;left:2px;bottom:2px;background:#fff;border-radius:50%;transition:0.3s;}
input:checked+.slider{background:var(--green);border-color:var(--green);}
input:checked+.slider::before{transform:translateX(20px);}
.tw{overflow-x:auto;}
.form-pad{padding:20px;}
.empty{text-align:center;padding:48px;color:var(--muted);}
.empty i{font-size:36px;color:var(--border);display:block;margin-bottom:10px;}
/* Chat admin list */
.chat-list{display:flex;flex-direction:column;gap:0;}
.chat-item{display:flex;align-items:center;gap:12px;padding:12px 16px;border-bottom:1px solid var(--border);cursor:pointer;transition:all 0.2s;}
.chat-item:hover,.chat-item.active{background:rgba(255,255,255,0.03);}
.chat-av{width:38px;height:38px;background:linear-gradient(135deg,var(--gold),var(--gold-2));border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;color:#fff;font-weight:700;flex-shrink:0;}
.chat-meta{flex:1;min-width:0;}
.chat-meta strong{display:block;font-size:13px;color:var(--text);}
.chat-meta span{display:block;font-size:11px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.chat-unread{background:var(--red);color:#fff;font-size:10px;font-weight:700;padding:1px 7px;border-radius:10px;}
.chat-pane{display:flex;gap:0;}
.chat-sidebar{width:280px;flex-shrink:0;border-right:1px solid var(--border);}
.chat-main{flex:1;display:flex;flex-direction:column;min-height:400px;}
.chat-msgs{flex:1;padding:16px;overflow-y:auto;display:flex;flex-direction:column;gap:8px;background:var(--dark);}
.admin-msg-input{display:flex;border-top:1px solid var(--border);}
.admin-msg-input input{background:var(--dark-3);border:none;border-radius:0;padding:12px 14px;flex:1;}
.admin-msg-input button{background:var(--gold);color:#fff;border:none;padding:12px 18px;cursor:pointer;font-size:14px;}
.msg-bubble{max-width:75%;padding:8px 12px;border-radius:12px;font-size:13px;line-height:1.4;}
.msg-bubble.customer{background:var(--dark-3);border:1px solid var(--border);align-self:flex-start;border-radius:12px 12px 12px 2px;}
.msg-bubble.admin{background:var(--gold);color:#fff;align-self:flex-end;border-radius:12px 12px 2px 12px;}
.msg-time{font-size:10px;opacity:0.5;margin-top:3px;display:block;text-align:right;}
.no-chat{display:flex;align-items:center;justify-content:center;flex:1;color:var(--muted);font-size:14px;flex-direction:column;gap:10px;}
.no-chat i{font-size:32px;color:var(--border);}
@media(max-width:900px){.sidebar{display:none;}.main{margin-left:0;}.stats{grid-template-columns:1fr 1fr;}.fg-grid{grid-template-columns:1fr;}.chat-pane{flex-direction:column;}.chat-sidebar{width:100%;border-right:none;border-bottom:1px solid var(--border);}}
@media(max-width:500px){.stats{grid-template-columns:1fr;}}
</style>
</head>
<body>
<aside class="sidebar">
  <div class="sb-brand">
    <div class="sb-icon"><i class="fas fa-car"></i></div>
    <h1>Brajwasi Travels</h1>
    <span>Admin Panel</span>
  </div>
  <button class="nav-item active" id="nav-dashboard" onclick="showTab('dashboard',this)"><i class="fas fa-tachometer-alt"></i> Dashboard</button>
  <button class="nav-item" id="nav-add-car" onclick="showTab('add-car',this)"><i class="fas fa-plus-circle"></i> Add New Car</button>
  <button class="nav-item" id="nav-fleet" onclick="showTab('fleet',this)"><i class="fas fa-car-side"></i> Fleet Management</button>
  <a href="/admin/bookings" class="nav-item"><i class="fas fa-calendar-check"></i> Bookings <% if(stats.pendingBookings>0){%><span class="nb"><%= stats.pendingBookings %></span><%}%></a>
  <button class="nav-item" id="nav-chat" onclick="showTab('chat',this);loadChats()"><i class="fas fa-comments"></i> Customer Chat <span class="nb" id="total-unread" style="display:none">!</span></button>
  <button class="nav-item" id="nav-push" onclick="showTab('push',this)"><i class="fas fa-bell"></i> Push Notifications</button>
  <div class="sb-footer">
    <a href="/" target="_blank" class="nav-item"><i class="fas fa-external-link-alt"></i> View Website</a>
    <a href="/admin/logout" class="nav-item" style="color:var(--red)"><i class="fas fa-sign-out-alt"></i> Logout</a>
  </div>
</aside>

<main class="main">
  <div class="topbar">
    <h2 id="page-title"><i class="fas fa-tachometer-alt" style="color:var(--gold-lt);margin-right:7px"></i>Dashboard</h2>
    <div style="display:flex;gap:8px">
      <a href="tel:9411061000" class="btn btn-sec btn-sm"><i class="fas fa-phone"></i> 9411061000</a>
      <a href="/admin/logout" class="btn btn-danger btn-sm"><i class="fas fa-sign-out-alt"></i> Logout</a>
    </div>
  </div>

  <div class="content">

    <!-- DASHBOARD -->
    <div id="tp-dashboard" class="tp active">
      <div class="stats">
        <div class="stat-c"><div class="ico ic-gold"><i class="fas fa-car"></i></div><div class="lbl">Active Cars</div><div class="num"><%= stats.totalCars %></div></div>
        <div class="stat-c"><div class="ico ic-g"><i class="fas fa-calendar-check"></i></div><div class="lbl">Total Bookings</div><div class="num"><%= stats.totalBookings %></div></div>
        <div class="stat-c"><div class="ico ic-b"><i class="fas fa-clock"></i></div><div class="lbl">Pending</div><div class="num"><%= stats.pendingBookings %></div></div>
        <div class="stat-c"><div class="ico ic-r"><i class="fas fa-check-circle"></i></div><div class="lbl">Confirmed</div><div class="num"><%= stats.confirmedBookings %></div></div>
      </div>
      <div class="card">
        <div class="card-hd"><h3><i class="fas fa-clock"></i> Recent Bookings</h3><a href="/admin/bookings" class="btn btn-sec btn-sm">View All</a></div>
        <div class="tw">
          <table>
            <thead><tr><th>Booking ID</th><th>Customer</th><th>Car</th><th>Route</th><th>Date</th><th>Amount</th><th>Status</th></tr></thead>
            <tbody>
              <% if(!bookings.length){%><tr><td colspan="7"><div class="empty"><i class="fas fa-calendar-times"></i>No bookings yet</div></td></tr><%}%>
              <% bookings.forEach(b=>{%>
              <tr>
                <td style="font-weight:700;color:var(--gold-lt)"><%= b.bookingId %></td>
                <td><div><%= b.customerName %></div><div style="font-size:11px;color:var(--muted)"><%= b.customerPhone %></div></td>
                <td><%= b.carName||'N/A' %></td>
                <td style="font-size:12px"><%= b.pickupLocation %> → <%= b.dropLocation %></td>
                <td style="font-size:12px"><%= new Date(b.journeyDate).toLocaleDateString('en-IN') %></td>
                <td style="color:var(--green);font-weight:700"><%=b.totalPrice?'₹'+b.totalPrice.toLocaleString('en-IN'):'TBD'%></td>
                <td><span class="badge b-<%= b.status==='advance_pending'?'adv':b.status %>"><%= b.status.replace('_',' ') %></span></td>
              </tr>
              <%})%>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ADD CAR -->
    <div id="tp-add-car" class="tp">
      <div class="card">
        <div class="card-hd"><h3><i class="fas fa-plus-circle"></i> Add New Car to Fleet</h3></div>
        <form class="form-pad" method="POST" action="/admin/cars/add" enctype="multipart/form-data">
          <div class="fg-grid">
            <div class="fg"><label>Car Brand *</label><input type="text" name="name" placeholder="e.g. Toyota" required></div>
            <div class="fg"><label>Car Model *</label><input type="text" name="model" placeholder="e.g. Innova Crysta" required></div>
            <div class="fg"><label>Car Photo *</label><input type="file" name="image" accept="image/*" required></div>
            <div class="fg"><label>Available In (comma separated)</label><input type="text" name="availableIn" placeholder="Agra, Delhi" value="Agra"></div>
            <div class="fg"><label>Price Per KM (₹) *</label><input type="number" name="pricePerKm" placeholder="12" required min="1"></div>
            <div class="fg"><label>Extra KM Charge (₹) *</label><input type="number" name="extraKmCharge" placeholder="12" required min="1"></div>
            <div class="fg"><label>Fixed Package KM (optional)</label><input type="number" name="fixedKm" placeholder="300"></div>
            <div class="fg"><label>Fixed Package Price ₹ (auto-calc if blank)</label><input type="number" name="fixedPrice" placeholder="Leave blank to auto-calculate"></div>
            <div class="fg"><label>Toll Tax Info</label><input type="text" name="tollTax" placeholder="As per actual (paid by customer)" value="As per actual (paid by customer)"></div>
            <div class="fg"><label>Seating Capacity</label><select name="seats"><option value="4">4</option><option value="5">5</option><option value="6">6</option><option value="7" selected>7</option><option value="8">8</option><option value="12">12</option></select></div>
            <div class="fg"><label>AC</label><select name="ac"><option value="true">AC ✅</option><option value="false">Non-AC</option></select></div>
            <div class="fg fg-full"><label>Description</label><textarea name="description" rows="2" placeholder="Describe the vehicle..."></textarea></div>
          </div>
          <button type="submit" class="btn btn-gold" style="margin-top:8px"><i class="fas fa-plus"></i> Add Car</button>
        </form>
      </div>
    </div>

    <!-- FLEET -->
    <div id="tp-fleet" class="tp">
      <div class="card">
        <div class="card-hd"><h3><i class="fas fa-car-side"></i> Fleet (<%= cars.length %>)</h3><button onclick="showTab('add-car',document.getElementById('nav-add-car'))" class="btn btn-gold btn-sm"><i class="fas fa-plus"></i> Add Car</button></div>
        <div class="tw">
          <table>
            <thead><tr><th>Photo</th><th>Car</th><th>Pricing</th><th>Available</th><th>Active</th><th>Actions</th></tr></thead>
            <tbody>
              <%if(!cars.length){%><tr><td colspan="6"><div class="empty"><i class="fas fa-car"></i>No cars yet</div></td></tr><%}%>
              <%cars.forEach(car=>{%>
              <tr>
                <td><img src="<%= car.image %>" class="car-thumb" onerror="this.src='/images/default-crysta.jpg'" alt="<%= car.model %>"></td>
                <td>
                  <div style="font-weight:600"><%= car.model %></div>
                  <div style="font-size:11px;color:var(--muted)"><%= car.name %> · <%= car.seats %>s <%= car.ac?'· AC':'' %></div>
                  <div style="font-size:11px;color:var(--muted)"><%= car.availableIn.join(', ') %></div>
                </td>
                <td>
                  <div style="color:var(--gold-lt);font-weight:700">₹<%= car.pricePerKm %>/km</div>
                  <%if(car.fixedPackage&&car.fixedPackage.km){%>
                  <div style="color:var(--green);font-size:12px">₹<%= car.fixedPackage.price %> / <%= car.fixedPackage.km %>km</div>
                  <%}%>
                  <div style="font-size:11px;color:var(--muted)">Extra: ₹<%= car.extraKmCharge %>/km</div>
                </td>
                <td>
                  <label class="toggle-switch" title="<%= car.isAvailable?'Available':'Unavailable' %>">
                    <input type="checkbox" <%= car.isAvailable?'checked':'' %> onchange="toggleAvailability('<%= car._id %>',this)">
                    <span class="slider"></span>
                  </label>
                  <div style="font-size:10px;color:var(--muted);margin-top:3px"><%= car.isAvailable?'Available':'Unavailable' %></div>
                </td>
                <td><span class="badge b-<%= car.isActive?'active':'inactive' %>"><%= car.isActive?'Active':'Inactive' %></span></td>
                <td>
                  <div style="display:flex;gap:6px;flex-wrap:wrap">
                    <a href="/admin/cars/<%= car._id %>/edit" class="btn btn-blue btn-sm"><i class="fas fa-edit"></i> Edit</a>
                    <form method="POST" action="/admin/cars/<%= car._id %>/toggle" style="display:inline">
                      <button type="submit" class="btn btn-sec btn-sm"><i class="fas fa-toggle-<%= car.isActive?'on':'off' %>"></i> <%= car.isActive?'Disable':'Enable' %></button>
                    </form>
                    <form method="POST" action="/admin/cars/<%= car._id %>/delete" style="display:inline" onsubmit="return confirm('Delete this car permanently?')">
                      <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
                    </form>
                  </div>
                </td>
              </tr>
              <%})%>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- CHAT -->
    <div id="tp-chat" class="tp">
      <div class="card">
        <div class="card-hd"><h3><i class="fas fa-comments"></i> Customer Chats</h3><span style="font-size:12px;color:var(--muted)">Only visible to admin</span></div>
        <div class="chat-pane">
          <div class="chat-sidebar">
            <div class="chat-list" id="chat-list"><div class="empty" style="padding:24px"><i class="fas fa-comments"></i>Loading chats...</div></div>
          </div>
          <div class="chat-main" id="chat-main">
            <div class="no-chat"><i class="fas fa-comments"></i>Select a conversation</div>
          </div>
        </div>
      </div>
    </div>

    <!-- PUSH -->
    <div id="tp-push" class="tp">
      <div class="card">
        <div class="card-hd"><h3><i class="fas fa-bell"></i> Push Notifications</h3></div>
        <div class="form-pad">
          <p style="font-size:13px;color:var(--muted);margin-bottom:16px">Send push notifications to all subscribed users — delivered even when the app is closed.</p>
          <div class="fg-grid">
            <div class="fg"><label>Title *</label><input type="text" id="push-title" placeholder="e.g. Special Offer!" value="🚗 Brajwasi Travels"></div>
            <div class="fg"><label>Message *</label><input type="text" id="push-body" placeholder="Notification message..."></div>
          </div>
          <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:8px">
            <button class="btn btn-gold" onclick="sendPush()"><i class="fas fa-paper-plane"></i> Send to All</button>
            <button class="btn btn-sec" onclick="document.getElementById('push-body').value='🎉 Special discount! Book now and save ₹200 on your next trip.'"><i class="fas fa-tag"></i> Offer Template</button>
            <button class="btn btn-sec" onclick="document.getElementById('push-body').value='📞 Please confirm your upcoming booking. Call: 9411061000'"><i class="fas fa-phone"></i> Reminder</button>
          </div>
          <div id="push-msg" style="margin-top:14px"></div>
        </div>
      </div>
    </div>

  </div>
</main>

<script src="/socket.io/socket.io.js"></script>
<script>
let activeSessionId = null;
const adminSocket = io();

adminSocket.on('new-chat-message', (data) => {
  document.getElementById('total-unread').style.display = 'flex';
  loadChats();
  if (activeSessionId === data.sessionId) loadMessages(data.sessionId);
  else {
    const item = document.querySelector(`.chat-item[data-id="${data.sessionId}"]`);
    if (item) item.querySelector('.chat-unread')?.style && (item.querySelector('.chat-unread').style.display = 'flex');
  }
});

adminSocket.on('chat-updated', (data) => {
  if (activeSessionId === data.sessionId) loadMessages(data.sessionId);
});

function showTab(name, el) {
  document.querySelectorAll('.tp').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('tp-' + name)?.classList.add('active');
  if (el) el.classList.add('active');
  const titles = { dashboard:'Dashboard', 'add-car':'Add New Car', fleet:'Fleet Management', chat:'Customer Chat', push:'Push Notifications' };
  document.getElementById('page-title').innerHTML = `<i class="fas fa-${name==='dashboard'?'tachometer-alt':name==='add-car'?'plus-circle':name==='fleet'?'car-side':name==='chat'?'comments':'bell'}" style="color:var(--gold-lt);margin-right:7px"></i>${titles[name]||name}`;
}

async function toggleAvailability(carId, checkbox) {
  try {
    const res = await fetch(`/admin/cars/${carId}/availability`, { method: 'POST' });
    const data = await res.json();
    const row = checkbox.closest('tr');
    const label = row.querySelector('.toggle-switch + div');
    if (label) label.textContent = data.isAvailable ? 'Available' : 'Unavailable';
  } catch(e) { checkbox.checked = !checkbox.checked; }
}

async function loadChats() {
  try {
    const res = await fetch('/admin/chat/list');
    const data = await res.json();
    const list = document.getElementById('chat-list');
    if (!data.chats?.length) { list.innerHTML = '<div class="empty" style="padding:24px"><i class="fas fa-comments"></i>No chats yet</div>'; return; }
    list.innerHTML = data.chats.map(c => `
      <div class="chat-item" data-id="${c.sessionId}" onclick="openChat('${c.sessionId}','${c.customerName}')">
        <div class="chat-av">${c.customerName.charAt(0).toUpperCase()}</div>
        <div class="chat-meta">
          <strong>${c.customerName}${c.customerPhone?' · '+c.customerPhone:''}</strong>
          <span>${c.lastMessage||'No messages'}</span>
        </div>
        ${c.unreadCount>0?`<span class="chat-unread">${c.unreadCount}</span>`:''}
      </div>`).join('');
  } catch(e) {}
}

async function openChat(sessionId, name) {
  activeSessionId = sessionId;
  document.querySelectorAll('.chat-item').forEach(i => i.classList.toggle('active', i.dataset.id === sessionId));
  adminSocket.emit('admin-read', { sessionId });
  await loadMessages(sessionId, name);
}

async function loadMessages(sessionId, name) {
  try {
    const res = await fetch(`/admin/chat/${sessionId}`);
    const data = await res.json();
    const main = document.getElementById('chat-main');
    main.innerHTML = `
      <div style="padding:12px 16px;border-bottom:1px solid var(--border);font-weight:600;font-size:14px;background:var(--dark-3)">${name||data.chat?.customerName||'Customer'} ${data.chat?.customerPhone?'· '+data.chat.customerPhone:''}</div>
      <div class="chat-msgs" id="admin-msgs">${(data.chat?.messages||[]).filter(m=>!m.text.startsWith('[User Info]')).map(m=>`
        <div class="msg-bubble ${m.sender}">${m.text}<span class="msg-time">${new Date(m.timestamp).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'})}</span></div>`).join('')}</div>
      <div class="admin-msg-input">
        <input id="admin-reply" type="text" placeholder="Type reply..." onkeypress="if(event.key==='Enter')sendAdminMsg()">
        <button onclick="sendAdminMsg()"><i class="fas fa-paper-plane"></i></button>
      </div>`;
    const msgs = document.getElementById('admin-msgs');
    if (msgs) msgs.scrollTop = msgs.scrollHeight;
  } catch(e) {}
}

function sendAdminMsg() {
  const input = document.getElementById('admin-reply');
  const text = input?.value.trim();
  if (!text || !activeSessionId) return;
  adminSocket.emit('admin-message', { sessionId: activeSessionId, text });
  const msgs = document.getElementById('admin-msgs');
  if (msgs) {
    const d = document.createElement('div');
    d.className = 'msg-bubble admin';
    const t = new Date();
    d.innerHTML = `${text}<span class="msg-time">${t.getHours()}:${String(t.getMinutes()).padStart(2,'0')}</span>`;
    msgs.appendChild(d);
    msgs.scrollTop = msgs.scrollHeight;
  }
  input.value = '';
}

async function sendPush() {
  const title = document.getElementById('push-title').value;
  const body = document.getElementById('push-body').value;
  if (!title || !body) return alert('Fill in title and message');
  const btn = event.target;
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';
  try {
    await fetch('/admin/push', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title, body }) });
    document.getElementById('push-msg').innerHTML = '<div style="background:rgba(63,185,80,0.1);border:1px solid rgba(63,185,80,0.3);color:var(--green);padding:10px 14px;border-radius:8px;font-size:13px;margin-top:8px"><i class="fas fa-check-circle"></i> Sent successfully!</div>';
    setTimeout(() => document.getElementById('push-msg').innerHTML = '', 4000);
  } catch(e) {}
  btn.disabled = false; btn.innerHTML = '<i class="fas fa-paper-plane"></i> Send to All';
}

// Register SW for admin PWA
if ('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js');
</script>
</body>
</html>
