<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Dashboard – Brajwasi Travels</title>
<link rel="manifest" href="/manifest.json">
<link rel="icon" type="image/png" href="/images/favicon.png">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
  :root { --gold: #C9922A; --gold-light: #E8B84B; --dark: #0D1117; --dark-2: #161B22; --dark-3: #21262D; --text: #E6EDF3; --text-muted: #8B949E; --green: #3FB950; --red: #F85149; --blue: #58A6FF; --radius: 12px; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'DM Sans', sans-serif; background: var(--dark); color: var(--text); min-height: 100vh; }
  
  .sidebar { position: fixed; left: 0; top: 0; bottom: 0; width: 240px; background: var(--dark-2); border-right: 1px solid rgba(255,255,255,0.06); padding: 24px 0; display: flex; flex-direction: column; z-index: 100; }
  .sidebar-brand { padding: 0 20px 24px; border-bottom: 1px solid rgba(255,255,255,0.06); margin-bottom: 16px; }
  .sidebar-brand h1 { font-family: 'Playfair Display', serif; font-size: 16px; color: var(--text); }
  .sidebar-brand span { font-size: 10px; color: var(--gold); letter-spacing: 2px; text-transform: uppercase; }
  .sidebar-brand .brand-icon { width: 40px; height: 40px; background: linear-gradient(135deg, var(--gold), #9B6F1A); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 16px; margin-bottom: 10px; }
  .nav-item { display: flex; align-items: center; gap: 10px; padding: 11px 20px; color: var(--text-muted); text-decoration: none; font-size: 14px; transition: all 0.2s; cursor: pointer; border: none; background: none; width: 100%; text-align: left; position: relative; }
  .nav-item:hover, .nav-item.active { color: var(--text); background: rgba(255,255,255,0.04); border-right: 2px solid var(--gold); }
  .nav-item i { width: 18px; color: var(--text-muted); font-size: 13px; }
  .nav-item.active i, .nav-item:hover i { color: var(--gold); }
  .sidebar-footer { margin-top: auto; padding: 16px 20px; border-top: 1px solid rgba(255,255,255,0.06); }
  .nav-badge { position: absolute; right: 16px; background: var(--red); color: #fff; border-radius: 10px; font-size: 10px; font-weight: 700; padding: 2px 7px; min-width: 18px; text-align: center; }
  
  .main { margin-left: 240px; min-height: 100vh; }
  .topbar { background: var(--dark-2); border-bottom: 1px solid rgba(255,255,255,0.06); padding: 16px 28px; display: flex; justify-content: space-between; align-items: center; }
  .topbar h2 { font-size: 20px; font-weight: 600; }
  .topbar-right { display: flex; align-items: center; gap: 12px; }
  .content { padding: 28px; }
  
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 28px; }
  .stat-card { background: var(--dark-2); border: 1px solid rgba(255,255,255,0.06); border-radius: var(--radius); padding: 20px 24px; }
  .stat-card .stat-label { font-size: 12px; color: var(--text-muted); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px; }
  .stat-card .stat-num { font-family: 'Playfair Display', serif; font-size: 36px; color: var(--text); font-weight: 700; }
  .stat-card .stat-icon { float: right; width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 18px; }
  .stat-icon.gold { background: rgba(201,146,42,0.15); color: var(--gold); }
  .stat-icon.green { background: rgba(63,185,80,0.15); color: var(--green); }
  .stat-icon.blue { background: rgba(88,166,255,0.15); color: var(--blue); }
  .stat-icon.red { background: rgba(248,81,73,0.15); color: var(--red); }
  
  .section-card { background: var(--dark-2); border: 1px solid rgba(255,255,255,0.06); border-radius: var(--radius); overflow: hidden; margin-bottom: 28px; }
  .section-head { padding: 18px 24px; border-bottom: 1px solid rgba(255,255,255,0.06); display: flex; justify-content: space-between; align-items: center; }
  .section-head h3 { font-size: 16px; font-weight: 600; }
  
  .add-car-form { padding: 24px; }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-group { margin-bottom: 0; }
  .form-group.full { grid-column: 1 / -1; }
  label { display: block; font-size: 12px; color: var(--text-muted); margin-bottom: 6px; font-weight: 500; letter-spacing: 0.5px; text-transform: uppercase; }
  input[type="text"], input[type="number"], input[type="file"], input[type="email"], textarea, select { width: 100%; background: var(--dark-3); border: 1px solid rgba(255,255,255,0.1); color: var(--text); padding: 10px 14px; border-radius: 8px; font-size: 13px; font-family: 'DM Sans', sans-serif; outline: none; transition: all 0.2s; }
  input:focus, textarea:focus, select:focus { border-color: var(--gold); }
  select option { background: var(--dark-3); }
  
  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th { padding: 12px 16px; text-align: left; font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid rgba(255,255,255,0.06); font-weight: 600; background: var(--dark-3); }
  td { padding: 13px 16px; border-bottom: 1px solid rgba(255,255,255,0.04); vertical-align: middle; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: rgba(255,255,255,0.02); }
  .car-img-thumb { width: 80px; height: 52px; object-fit: cover; border-radius: 8px; border: 1px solid rgba(255,255,255,0.08); }
  
  .badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }
  .badge-active { background: rgba(63,185,80,0.15); color: var(--green); border: 1px solid rgba(63,185,80,0.3); }
  .badge-inactive { background: rgba(248,81,73,0.1); color: var(--red); border: 1px solid rgba(248,81,73,0.2); }
  .badge-pending { background: rgba(201,146,42,0.15); color: var(--gold-light); border: 1px solid rgba(201,146,42,0.3); }
  .badge-confirmed { background: rgba(63,185,80,0.15); color: var(--green); border: 1px solid rgba(63,185,80,0.3); }
  .badge-cancelled { background: rgba(248,81,73,0.1); color: var(--red); border: 1px solid rgba(248,81,73,0.2); }
  .badge-completed { background: rgba(88,166,255,0.15); color: var(--blue); border: 1px solid rgba(88,166,255,0.3); }
  
  .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; border: none; transition: all 0.2s; text-decoration: none; }
  .btn-gold { background: linear-gradient(135deg, var(--gold), #9B6F1A); color: #fff; }
  .btn-gold:hover { opacity: 0.9; }
  .btn-sm { padding: 5px 10px; font-size: 11px; }
  .btn-danger { background: rgba(248,81,73,0.15); color: var(--red); border: 1px solid rgba(248,81,73,0.3); }
  .btn-danger:hover { background: rgba(248,81,73,0.25); }
  .btn-secondary { background: var(--dark-3); color: var(--text-muted); border: 1px solid rgba(255,255,255,0.1); }
  .btn-secondary:hover { color: var(--text); }
  .btn-blue { background: rgba(88,166,255,0.15); color: var(--blue); border: 1px solid rgba(88,166,255,0.3); }
  .btn-blue:hover { background: rgba(88,166,255,0.25); }
  .btn-green { background: rgba(63,185,80,0.15); color: var(--green); border: 1px solid rgba(63,185,80,0.3); }
  .btn-green:hover { background: rgba(63,185,80,0.25); }
  
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }
  
  .push-form { padding: 24px; }
  
  /* Toggle Switch */
  .toggle-switch { position: relative; display: inline-block; width: 42px; height: 22px; }
  .toggle-switch input { opacity: 0; width: 0; height: 0; }
  .toggle-slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(248,81,73,0.3); border-radius: 22px; transition: .3s; border: 1px solid rgba(248,81,73,0.4); }
  .toggle-slider:before { position: absolute; content: ""; height: 16px; width: 16px; left: 2px; bottom: 2px; background-color: #F85149; border-radius: 50%; transition: .3s; }
  input:checked + .toggle-slider { background-color: rgba(63,185,80,0.3); border-color: rgba(63,185,80,0.4); }
  input:checked + .toggle-slider:before { transform: translateX(20px); background-color: #3FB950; }
  .toggle-wrap { display: flex; align-items: center; gap: 8px; }
  .toggle-label { font-size: 12px; color: var(--text-muted); }

  /* Chat styles */
  .chat-layout { display: grid; grid-template-columns: 260px 1fr; height: 600px; }
  .chat-sidebar { border-right: 1px solid rgba(255,255,255,0.06); overflow-y: auto; }
  .chat-list-item { padding: 14px 18px; cursor: pointer; border-bottom: 1px solid rgba(255,255,255,0.04); transition: background 0.2s; display: flex; gap: 12px; align-items: flex-start; }
  .chat-list-item:hover, .chat-list-item.active { background: rgba(255,255,255,0.04); }
  .chat-avatar { width: 38px; height: 38px; min-width: 38px; background: linear-gradient(135deg, var(--gold), #9B6F1A); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700; font-size: 14px; }
  .chat-list-name { font-size: 13px; font-weight: 600; color: var(--text); }
  .chat-list-preview { font-size: 11px; color: var(--text-muted); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 160px; }
  .chat-list-time { font-size: 10px; color: var(--text-muted); margin-left: auto; flex-shrink: 0; }
  .unread-dot { width: 8px; height: 8px; background: var(--blue); border-radius: 50%; margin-top: 4px; flex-shrink: 0; }
  
  .chat-main { display: flex; flex-direction: column; }
  .chat-topbar { padding: 14px 18px; border-bottom: 1px solid rgba(255,255,255,0.06); display: flex; justify-content: space-between; align-items: center; }
  .chat-messages-area { flex: 1; overflow-y: auto; padding: 16px; display: flex; flex-direction: column; gap: 10px; }
  .chat-bubble { max-width: 72%; padding: 10px 14px; border-radius: 14px; font-size: 13px; line-height: 1.5; word-break: break-word; }
  .chat-bubble.customer { background: rgba(255,255,255,0.08); color: var(--text); align-self: flex-start; border-bottom-left-radius: 4px; }
  .chat-bubble.admin { background: linear-gradient(135deg, var(--gold), #9B6F1A); color: #fff; align-self: flex-end; border-bottom-right-radius: 4px; }
  .bubble-time { font-size: 10px; opacity: 0.6; margin-top: 4px; }
  .chat-reply-row { display: flex; gap: 10px; padding: 14px 18px; border-top: 1px solid rgba(255,255,255,0.06); }
  .chat-reply-row input { flex: 1; background: var(--dark-3); border: 1px solid rgba(255,255,255,0.1); color: var(--text); padding: 10px 14px; border-radius: 8px; font-size: 13px; font-family: 'DM Sans', sans-serif; outline: none; }
  .chat-reply-row input:focus { border-color: var(--gold); }
  .chat-placeholder { display: flex; align-items: center; justify-content: center; height: 100%; color: var(--text-muted); flex-direction: column; gap: 10px; }
  .chat-placeholder i { font-size: 40px; color: rgba(255,255,255,0.08); }
  
  @media (max-width: 900px) {
    .sidebar { transform: translateX(-100%); transition: transform 0.3s; }
    .sidebar.open { transform: translateX(0); }
    .main { margin-left: 0; }
    .stats-grid { grid-template-columns: 1fr 1fr; }
    .form-grid { grid-template-columns: 1fr; }
    .chat-layout { grid-template-columns: 1fr; height: auto; }
    .chat-sidebar { height: 250px; border-right: none; border-bottom: 1px solid rgba(255,255,255,0.06); }
  }
  @media (max-width: 600px) { .stats-grid { grid-template-columns: 1fr; } }
  
  .alert { padding: 12px 16px; border-radius: 8px; font-size: 13px; margin-bottom: 20px; }
  .alert-success { background: rgba(63,185,80,0.1); border: 1px solid rgba(63,185,80,0.3); color: var(--green); }
  .empty-state { text-align: center; padding: 48px; color: var(--text-muted); }
  .empty-state i { font-size: 40px; color: rgba(255,255,255,0.1); margin-bottom: 12px; display: block; }
  
  .advance-tag { display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 10px; font-size: 10px; font-weight: 700; background: rgba(63,185,80,0.12); color: var(--green); border: 1px solid rgba(63,185,80,0.25); }
  .advance-tag.unpaid { background: rgba(248,81,73,0.08); color: var(--red); border-color: rgba(248,81,73,0.2); }
</style>
</head>
<body>

<aside class="sidebar" id="sidebar">
  <div class="sidebar-brand">
    <div class="brand-icon"><i class="fas fa-car"></i></div>
    <h1>Brajwasi Travels</h1>
    <span>Admin Panel</span>
  </div>
  <button class="nav-item active" onclick="showTab('dashboard')"><i class="fas fa-tachometer-alt"></i> Dashboard</button>
  <button class="nav-item" onclick="showTab('add-car')"><i class="fas fa-plus-circle"></i> Add New Car</button>
  <button class="nav-item" onclick="showTab('fleet')"><i class="fas fa-car-side"></i> Manage Fleet</button>
  <a href="/admin/bookings" class="nav-item"><i class="fas fa-calendar-check"></i> All Bookings</a>
  <button class="nav-item" onclick="showTab('chat')">
    <i class="fas fa-comments"></i> Live Chats
    <% const totalUnread = chatSessions.reduce((a, s) => a + (s.unreadCount || 0), 0); %>
    <% if (totalUnread > 0) { %><span class="nav-badge"><%= totalUnread %></span><% } %>
  </button>
  <button class="nav-item" onclick="showTab('push')"><i class="fas fa-bell"></i> Push Notifications</button>
  <div class="sidebar-footer">
    <a href="/" target="_blank" class="nav-item"><i class="fas fa-external-link-alt"></i> View Website</a>
    <a href="/admin/logout" class="nav-item" style="color: var(--red)"><i class="fas fa-sign-out-alt"></i> Logout</a>
  </div>
</aside>

<main class="main">
  <div class="topbar">
    <div style="display:flex;align-items:center;gap:12px">
      <button onclick="document.getElementById('sidebar').classList.toggle('open')" style="display:none;background:none;border:none;color:var(--text-muted);font-size:18px;cursor:pointer" id="menu-btn"><i class="fas fa-bars"></i></button>
      <h2 id="page-title">Dashboard</h2>
    </div>
    <div class="topbar-right">
      <a href="tel:9411061000" class="btn btn-secondary btn-sm"><i class="fas fa-phone"></i> 9411061000</a>
      <a href="/admin/logout" class="btn btn-danger btn-sm"><i class="fas fa-sign-out-alt"></i> Logout</a>
    </div>
  </div>

  <div class="content">
    <!-- DASHBOARD TAB -->
    <div id="tab-dashboard" class="tab-panel active">
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon gold" style="float:right"><i class="fas fa-car"></i></div>
          <div class="stat-label">Active Cars</div>
          <div class="stat-num"><%= stats.totalCars %></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon green" style="float:right"><i class="fas fa-calendar-check"></i></div>
          <div class="stat-label">Total Bookings</div>
          <div class="stat-num"><%= stats.totalBookings %></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon blue" style="float:right"><i class="fas fa-clock"></i></div>
          <div class="stat-label">Pending</div>
          <div class="stat-num"><%= stats.pendingBookings %></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon red" style="float:right"><i class="fas fa-check"></i></div>
          <div class="stat-label">Confirmed</div>
          <div class="stat-num"><%= stats.confirmedBookings %></div>
        </div>
      </div>

      <div class="section-card">
        <div class="section-head">
          <h3><i class="fas fa-clock"></i> Recent Bookings</h3>
          <a href="/admin/bookings" class="btn btn-secondary btn-sm">View All</a>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr><th>Booking ID</th><th>Customer</th><th>Car</th><th>Route</th><th>Date</th><th>Amount</th><th>Advance</th><th>Status</th></tr>
            </thead>
            <tbody>
              <% if (bookings.length === 0) { %>
              <tr><td colspan="8"><div class="empty-state"><i class="fas fa-calendar-times"></i><p>No bookings yet</p></div></td></tr>
              <% } else { %>
              <% bookings.forEach(b => { %>
              <tr>
                <td style="font-weight:600;color:var(--gold);font-family:monospace"><%= b.bookingId %></td>
                <td><div><%= b.customerName %></div><div style="font-size:11px;color:var(--text-muted)"><%= b.customerPhone %></div></td>
                <td><%= b.carName || 'N/A' %></td>
                <td style="font-size:12px"><%= b.pickupLocation %> → <%= b.dropLocation %></td>
                <td style="font-size:12px"><%= new Date(b.journeyDate).toLocaleDateString('en-IN') %></td>
                <td style="color:var(--green);font-weight:600"><% if(b.totalPrice) { %>₹<%= b.totalPrice.toLocaleString('en-IN') %><% } else { %>TBD<% } %></td>
                <td><span class="advance-tag <%= b.advancePaid ? '' : 'unpaid' %>"><%= b.advancePaid ? '✓ Paid' : '✗ Pending' %></span></td>
                <td><span class="badge badge-<%= b.status %>"><%= b.status %></span></td>
              </tr>
              <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ADD CAR TAB -->
    <div id="tab-add-car" class="tab-panel">
      <div class="section-card">
        <div class="section-head"><h3><i class="fas fa-plus-circle"></i> Add New Car to Fleet</h3></div>
        <form class="add-car-form" method="POST" action="/admin/cars/add" enctype="multipart/form-data">
          <div class="form-grid">
            <div class="form-group">
              <label>Car Brand *</label>
              <input type="text" name="name" placeholder="e.g. Toyota" required>
            </div>
            <div class="form-group">
              <label>Car Model *</label>
              <input type="text" name="model" placeholder="e.g. Innova Crysta" required>
            </div>
            <div class="form-group">
              <label>Car Photo *</label>
              <input type="file" name="image" accept="image/*" required>
            </div>
            <div class="form-group">
              <label>Available In (comma separated)</label>
              <input type="text" name="availableIn" placeholder="Agra, Delhi, Mathura" value="Agra">
            </div>
            <div class="form-group">
              <label>Price Per KM (₹) *</label>
              <input type="number" name="pricePerKm" placeholder="12" required min="1">
            </div>
            <div class="form-group">
              <label>Extra KM Charge (₹) *</label>
              <input type="number" name="extraKmCharge" placeholder="12" required min="1">
            </div>
            <div class="form-group">
              <label>Fixed Package KM (optional)</label>
              <input type="number" name="fixedKm" placeholder="300">
            </div>
            <div class="form-group">
              <label>Fixed Package Price ₹ (optional)</label>
              <input type="number" name="fixedPrice" placeholder="3200">
            </div>
            <div class="form-group">
              <label>Toll Tax Info</label>
              <input type="text" name="tollTax" placeholder="As per actual" value="As per actual (paid by customer)">
            </div>
            <div class="form-group">
              <label>Seating Capacity</label>
              <select name="seats">
                <option value="4">4 Seater</option>
                <option value="5">5 Seater</option>
                <option value="6">6 Seater</option>
                <option value="7" selected>7 Seater</option>
                <option value="8">8 Seater</option>
                <option value="12">12 Seater</option>
              </select>
            </div>
            <div class="form-group">
              <label>Air Conditioning</label>
              <select name="ac">
                <option value="true">AC ✅</option>
                <option value="false">Non-AC</option>
              </select>
            </div>
            <div class="form-group full">
              <label>Description</label>
              <textarea name="description" rows="3" placeholder="Describe the vehicle and ideal use cases..."></textarea>
            </div>
          </div>
          <div style="margin-top:20px">
            <button type="submit" class="btn btn-gold"><i class="fas fa-plus"></i> Add Car to Fleet</button>
          </div>
        </form>
      </div>
    </div>

    <!-- FLEET TAB -->
    <div id="tab-fleet" class="tab-panel">
      <div class="section-card">
        <div class="section-head">
          <h3><i class="fas fa-car-side"></i> Fleet Management (<%= cars.length %> cars)</h3>
          <button onclick="showTab('add-car')" class="btn btn-gold btn-sm"><i class="fas fa-plus"></i> Add Car</button>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr><th>Photo</th><th>Car</th><th>Pricing</th><th>Package</th><th>Location</th><th>Available</th><th>Actions</th></tr>
            </thead>
            <tbody>
              <% if (cars.length === 0) { %>
              <tr><td colspan="7"><div class="empty-state"><i class="fas fa-car"></i><p>No cars added yet</p></div></td></tr>
              <% } else { %>
              <% cars.forEach(car => { %>
              <tr id="car-row-<%= car._id %>">
                <td><img src="<%= car.image %>" class="car-img-thumb" onerror="this.src='/images/default-crysta.jpg'" alt="<%= car.model %>"></td>
                <td>
                  <div style="font-weight:600"><%= car.model %></div>
                  <div style="font-size:11px;color:var(--text-muted)"><%= car.name %> • <%= car.seats %> Seats <%= car.ac ? '• AC' : '' %></div>
                </td>
                <td>
                  <div style="font-weight:600;color:var(--gold)">₹<%= car.pricePerKm %>/km</div>
                  <div style="font-size:11px;color:var(--text-muted)">Extra: ₹<%= car.extraKmCharge %>/km</div>
                </td>
                <td>
                  <% if (car.fixedPackage && car.fixedPackage.km) { %>
                  <div style="font-weight:600;color:var(--green)">₹<%= car.fixedPackage.price %></div>
                  <div style="font-size:11px;color:var(--text-muted)">for <%= car.fixedPackage.km %>km</div>
                  <% } else { %>
                  <span style="color:var(--text-muted);font-size:12px">No package</span>
                  <% } %>
                </td>
                <td style="font-size:12px"><%= car.availableIn.join(', ') %></td>
                <td>
                  <div class="toggle-wrap">
                    <label class="toggle-switch">
                      <input type="checkbox" <%= car.isActive ? 'checked' : '' %> onchange="toggleCar('<%= car._id %>', this)">
                      <span class="toggle-slider"></span>
                    </label>
                    <span class="toggle-label" id="toggle-label-<%= car._id %>"><%= car.isActive ? 'Active' : 'Inactive' %></span>
                  </div>
                </td>
                <td>
                  <div style="display:flex;gap:6px;flex-wrap:wrap">
                    <a href="/admin/cars/<%= car._id %>/edit" class="btn btn-blue btn-sm"><i class="fas fa-edit"></i> Edit</a>
                    <form method="POST" action="/admin/cars/<%= car._id %>/delete" style="display:inline" onsubmit="return confirm('Delete this car? This cannot be undone.')">
                      <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
                    </form>
                  </div>
                </td>
              </tr>
              <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- CHAT TAB -->
    <div id="tab-chat" class="tab-panel">
      <div class="section-card">
        <div class="section-head"><h3><i class="fas fa-comments"></i> Customer Chats</h3><span style="font-size:12px;color:var(--text-muted)"><%= chatSessions.length %> conversations</span></div>
        <div class="chat-layout">
          <div class="chat-sidebar">
            <% if (chatSessions.length === 0) { %>
            <div class="empty-state" style="padding:30px"><i class="fas fa-comment-slash"></i><p>No chats yet</p></div>
            <% } else { %>
            <% chatSessions.forEach(s => { %>
            <div class="chat-list-item" onclick="loadAdminChat('<%= s._id %>', '<%= s.customerName %>', '<%= s.customerPhone %>')" id="chat-item-<%= s._id %>">
              <div class="chat-avatar"><%= s.customerName.charAt(0).toUpperCase() %></div>
              <div style="flex:1;min-width:0">
                <div style="display:flex;justify-content:space-between;align-items:center">
                  <span class="chat-list-name"><%= s.customerName %></span>
                  <span class="chat-list-time"><%= new Date(s.lastTime).toLocaleTimeString('en-IN', {hour:'2-digit', minute:'2-digit'}) %></span>
                </div>
                <div style="font-size:11px;color:var(--text-muted);margin-top:1px"><%= s.customerPhone %></div>
                <div class="chat-list-preview"><%= s.lastMessage %></div>
              </div>
              <% if (s.unreadCount > 0) { %><div class="unread-dot"></div><% } %>
            </div>
            <% }) %>
            <% } %>
          </div>
          <div class="chat-main" id="chatMainArea">
            <div class="chat-placeholder">
              <i class="fas fa-hand-pointer"></i>
              <p>Select a conversation to view messages</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- PUSH NOTIFICATIONS TAB -->
    <div id="tab-push" class="tab-panel">
      <div class="section-card">
        <div class="section-head"><h3><i class="fas fa-bell"></i> Send Push Notification</h3></div>
        <div class="push-form">
          <p style="color:var(--text-muted);font-size:14px;margin-bottom:20px">Send push notifications to all subscribed users (works even when browser is closed).</p>
          <div class="form-grid">
            <div class="form-group">
              <label>Notification Title *</label>
              <input type="text" id="push-title" placeholder="e.g. Special Offer!" value="🚗 Brajwasi Travels">
            </div>
            <div class="form-group">
              <label>Message Body *</label>
              <input type="text" id="push-body" placeholder="e.g. Get 10% off this weekend!">
            </div>
          </div>
          <div style="margin-top:16px;display:flex;gap:12px;flex-wrap:wrap">
            <button class="btn btn-gold" onclick="sendPush()"><i class="fas fa-paper-plane"></i> Send to All Users</button>
            <button class="btn btn-secondary" onclick="document.getElementById('push-body').value='🎉 Special offer: 10% off on all bookings this weekend!'"><i class="fas fa-tag"></i> Offer Template</button>
            <button class="btn btn-secondary" onclick="document.getElementById('push-body').value='📞 Please confirm your upcoming booking. Call: 9411061000'"><i class="fas fa-phone"></i> Reminder Template</button>
          </div>
          <div id="push-result" style="margin-top:16px"></div>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
// Register service worker for admin push notifications
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('/sw.js').catch(() => {});
}

function showTab(name) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('tab-' + name)?.classList.add('active');
  const titles = { dashboard: 'Dashboard', 'add-car': 'Add New Car', fleet: 'Fleet Management', chat: 'Live Chats', push: 'Push Notifications' };
  document.getElementById('page-title').textContent = titles[name] || name;
  // Mark clicked nav as active
  event?.target?.closest('.nav-item')?.classList.add('active');
}

// Toggle car availability via AJAX
async function toggleCar(carId, checkbox) {
  const label = document.getElementById('toggle-label-' + carId);
  try {
    const resp = await fetch('/admin/cars/' + carId + '/toggle', { method: 'POST' });
    const data = await resp.json();
    if (data.success) {
      label.textContent = data.isActive ? 'Active' : 'Inactive';
    }
  } catch(e) {
    // Revert checkbox on error
    checkbox.checked = !checkbox.checked;
    alert('Failed to update status');
  }
}

// Send push notification
async function sendPush() {
  const title = document.getElementById('push-title').value;
  const body = document.getElementById('push-body').value;
  if (!title || !body) return alert('Please fill in both title and message');
  
  const btn = event.target;
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';
  
  try {
    await fetch('/admin/push', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title, body })
    });
    const resultEl = document.getElementById('push-result');
    resultEl.innerHTML = '<div class="alert alert-success"><i class="fas fa-check-circle"></i> Push notification sent successfully!</div>';
    setTimeout(() => resultEl.innerHTML = '', 5000);
  } catch(e) {
    alert('Failed to send notification');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-paper-plane"></i> Send to All Users';
  }
}

// Chat functions
let activeChatSession = null;

async function loadAdminChat(sessionId, name, phone) {
  activeChatSession = sessionId;
  
  // Highlight active item
  document.querySelectorAll('.chat-list-item').forEach(el => el.classList.remove('active'));
  document.getElementById('chat-item-' + sessionId)?.classList.add('active');
  
  const area = document.getElementById('chatMainArea');
  area.innerHTML = `
    <div class="chat-topbar">
      <div>
        <div style="font-weight:700;font-size:15px">${name}</div>
        <div style="font-size:11px;color:var(--text-muted)">${phone}</div>
      </div>
      <a href="https://wa.me/91${phone}" target="_blank" class="btn btn-green btn-sm"><i class="fab fa-whatsapp"></i> WhatsApp</a>
    </div>
    <div class="chat-messages-area" id="adminChatMessages"></div>
    <div class="chat-reply-row">
      <input type="text" id="adminReplyInput" placeholder="Type your reply..." onkeypress="if(event.key==='Enter') sendAdminReply('${sessionId}')">
      <button class="btn btn-gold btn-sm" onclick="sendAdminReply('${sessionId}')"><i class="fas fa-paper-plane"></i> Send</button>
    </div>
  `;
  
  try {
    const resp = await fetch('/admin/chat/' + sessionId + '/messages');
    const data = await resp.json();
    renderAdminMessages(data.messages);
  } catch(e) {}
}

function renderAdminMessages(messages) {
  const container = document.getElementById('adminChatMessages');
  if (!container) return;
  container.innerHTML = '';
  
  if (messages.length === 0) {
    container.innerHTML = '<div style="text-align:center;color:var(--text-muted);padding:20px">No messages yet</div>';
    return;
  }
  
  messages.forEach(m => {
    const div = document.createElement('div');
    div.className = 'chat-bubble ' + (m.fromCustomer ? 'customer' : 'admin');
    const time = new Date(m.createdAt).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' });
    div.innerHTML = `${m.message}<div class="bubble-time">${m.fromCustomer ? m.customerName : '👨‍💼 Brajwasi Travels'} · ${time}</div>`;
    container.appendChild(div);
  });
  container.scrollTop = container.scrollHeight;
}

async function sendAdminReply(sessionId) {
  const input = document.getElementById('adminReplyInput');
  const message = input?.value?.trim();
  if (!message) return;
  input.value = '';
  
  try {
    await fetch('/admin/chat/' + sessionId + '/reply', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message })
    });
    // Reload messages
    const resp = await fetch('/admin/chat/' + sessionId + '/messages');
    const data = await resp.json();
    renderAdminMessages(data.messages);
  } catch(e) { alert('Failed to send reply'); }
}

// Mobile sidebar
if (window.innerWidth < 900) {
  document.getElementById('menu-btn').style.display = 'block';
}
</script>
</body>
</html>
