<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Admin – Brajwasi Travels</title>
<link rel="manifest" href="/admin-manifest.json">
<link rel="icon" type="image/png" href="/images/favicon.png">
<meta name="theme-color" content="#B8731A">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
:root{--gold:#B8731A;--g2:#D4882A;--bg:#F8F4EF;--white:#fff;--text:#1C1C1C;--t2:#4A4A4A;--t3:#7A7A7A;--border:#E8DDD0;--green:#1A7A3A;--gbg:#E8F5ED;--red:#C0392B;--blue:#1565C0;--r:10px;}
*{box-sizing:border-box;margin:0;padding:0;}body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}
/* SIDEBAR */
.sb{position:fixed;left:0;top:0;bottom:0;width:225px;background:var(--white);border-right:1px solid var(--border);padding:18px 0;display:flex;flex-direction:column;z-index:100;box-shadow:2px 0 12px rgba(0,0,0,0.05);}
.sb-brand{padding:0 16px 18px;border-bottom:1px solid var(--border);margin-bottom:10px;}
.sb-ico{width:36px;height:36px;background:linear-gradient(135deg,var(--gold),var(--g2));border-radius:9px;display:flex;align-items:center;justify-content:center;overflow:hidden;margin-bottom:8px;}
.sb-ico img{width:100%;height:100%;object-fit:cover;}
.sb-brand h1{font-family:'Playfair Display',serif;font-size:14px;color:var(--text);line-height:1.2;}
.sb-brand span{font-size:10px;color:var(--gold);letter-spacing:1.5px;text-transform:uppercase;}
.ni{display:flex;align-items:center;gap:9px;padding:10px 16px;color:var(--t3);text-decoration:none;font-size:13px;transition:all 0.2s;cursor:pointer;border:none;background:none;width:100%;text-align:left;border-left:3px solid transparent;}
.ni:hover,.ni.on{color:var(--gold);background:#FFF8EE;border-left-color:var(--gold);}
.ni i{width:16px;font-size:12px;color:var(--t3);}
.ni:hover i,.ni.on i{color:var(--gold);}
.ni .nb{background:var(--red);color:#fff;font-size:10px;font-weight:700;padding:1px 6px;border-radius:10px;margin-left:auto;}
.sb-ft{margin-top:auto;padding:12px 0;border-top:1px solid var(--border);}
/* MAIN */
.main{margin-left:225px;min-height:100vh;}
.topbar{background:var(--white);border-bottom:1px solid var(--border);padding:13px 22px;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;z-index:50;}
.topbar h2{font-size:17px;font-weight:600;color:var(--text);}
.content{padding:22px;}
/* STATS */
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px;}
.sc{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:16px 18px;box-shadow:0 2px 8px rgba(0,0,0,0.04);}
.sc .lbl{font-size:11px;color:var(--t3);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:5px;}
.sc .num{font-family:'Playfair Display',serif;font-size:30px;color:var(--text);}
.sc .ico{float:right;width:38px;height:38px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:15px;}
.ic-g{background:var(--gbg);color:var(--green);}.ic-gold{background:#FFF8EE;color:var(--gold);}.ic-b{background:#EBF4FF;color:var(--blue);}.ic-r{background:#FEF2F2;color:var(--red);}
/* CARDS */
.card{background:var(--white);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin-bottom:18px;box-shadow:0 2px 8px rgba(0,0,0,0.04);}
.card-hd{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;}
.card-hd h3{font-size:14px;font-weight:600;color:var(--text);display:flex;align-items:center;gap:7px;}
.card-hd h3 i{color:var(--gold);}
.tp{display:none;}.tp.on{display:block;}
/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 13px;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;border:none;transition:all 0.2s;text-decoration:none;}
.btn-gold{background:linear-gradient(135deg,var(--gold),var(--g2));color:#fff;}
.btn-sm{padding:5px 10px;font-size:11px;}
.btn-danger{background:#FEF2F2;color:var(--red);border:1px solid #FECACA;}
.btn-danger:hover{background:#FECACA;}
.btn-sec{background:var(--bg);color:var(--t3);border:1px solid var(--border);}
.btn-sec:hover{color:var(--text);}
.btn-blue{background:#EBF4FF;color:var(--blue);border:1px solid rgba(21,101,192,0.2);}
/* FORM */
.fg{margin-bottom:13px;}.fg label{display:block;font-size:11px;color:var(--t3);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:5px;font-weight:600;}
input,textarea,select{width:100%;background:var(--bg);border:1px solid var(--border);color:var(--text);padding:9px 12px;border-radius:7px;font-size:13px;font-family:'DM Sans',sans-serif;outline:none;transition:all 0.2s;}
input:focus,textarea:focus,select:focus{border-color:var(--gold);box-shadow:0 0 0 2px rgba(184,115,26,0.08);}
.fg-grid{display:grid;grid-template-columns:1fr 1fr;gap:13px;}
.fg-full{grid-column:1/-1;}
.form-pad{padding:18px;}
/* TABLE */
.tw{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:13px;}
th{padding:10px 13px;text-align:left;font-size:11px;color:var(--t3);text-transform:uppercase;letter-spacing:0.8px;border-bottom:1px solid var(--border);background:var(--bg);}
td{padding:11px 13px;border-bottom:1px solid var(--border);vertical-align:middle;}
tr:last-child td{border-bottom:none;}
tr:hover td{background:#FAFAFA;}
.thumb{width:68px;height:46px;object-fit:cover;border-radius:7px;border:1px solid var(--border);}
/* BADGES */
.bdg{display:inline-flex;align-items:center;padding:3px 9px;border-radius:14px;font-size:11px;font-weight:600;}
.b-active{background:var(--gbg);color:var(--green);border:1px solid rgba(26,122,58,0.2);}
.b-inactive{background:#FEF2F2;color:var(--red);border:1px solid #FECACA;}
.b-avail{background:var(--gbg);color:var(--green);border:1px solid rgba(26,122,58,0.2);}
.b-unavail{background:#FEF2F2;color:var(--red);border:1px solid #FECACA;}
.b-pending{background:#FFF8EE;color:var(--gold);border:1px solid rgba(184,115,26,0.25);}
.b-advance_pending{background:#FFFDE7;color:#F57F17;border:1px solid #F9A825;}
.b-confirmed{background:var(--gbg);color:var(--green);border:1px solid rgba(26,122,58,0.2);}
.b-completed{background:#EBF4FF;color:var(--blue);border:1px solid rgba(21,101,192,0.2);}
.b-cancelled{background:#FEF2F2;color:var(--red);border:1px solid #FECACA;}
/* TOGGLE */
.tgl{position:relative;width:40px;height:21px;cursor:pointer;}
.tgl input{opacity:0;width:0;height:0;}
.tslider{position:absolute;inset:0;background:var(--border);border-radius:21px;transition:0.3s;}
.tslider::before{content:'';position:absolute;height:15px;width:15px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:0.3s;}
input:checked+.tslider{background:var(--green);}
input:checked+.tslider::before{transform:translateX(19px);}
/* CHAT */
.chat-pane{display:flex;min-height:420px;}
.chat-list-col{width:270px;flex-shrink:0;border-right:1px solid var(--border);overflow-y:auto;}
.chat-main-col{flex:1;display:flex;flex-direction:column;}
.chat-item{display:flex;align-items:center;gap:10px;padding:11px 14px;border-bottom:1px solid var(--border);cursor:pointer;transition:all 0.15s;}
.chat-item:hover,.chat-item.on{background:#FFF8EE;}
.c-av{width:36px;height:36px;background:linear-gradient(135deg,var(--gold),var(--g2));border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;color:#fff;font-weight:700;flex-shrink:0;}
.c-meta{flex:1;min-width:0;}.c-meta strong{display:block;font-size:13px;color:var(--text);}.c-meta span{display:block;font-size:11px;color:var(--t3);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.c-unread{background:var(--red);color:#fff;font-size:10px;font-weight:700;padding:1px 6px;border-radius:10px;}
.msgs-area{flex:1;padding:13px;overflow-y:auto;display:flex;flex-direction:column;gap:8px;background:#F8F9FA;}
.mb{max-width:76%;padding:8px 11px;border-radius:11px;font-size:13px;line-height:1.4;}
.mb.customer{background:var(--white);border:1px solid var(--border);align-self:flex-start;border-radius:11px 11px 11px 2px;}
.mb.admin{background:var(--gold);color:#fff;align-self:flex-end;border-radius:11px 11px 2px 11px;}
.mb-t{font-size:10px;opacity:.5;margin-top:3px;display:block;text-align:right;}
.msg-inp{display:flex;border-top:1px solid var(--border);}
.msg-inp input{flex:1;border:none;padding:11px 13px;font-size:13px;font-family:'DM Sans',sans-serif;outline:none;background:var(--white);}
.msg-inp button{background:var(--gold);color:#fff;border:none;padding:11px 16px;cursor:pointer;font-size:14px;}
.no-chat-sel{display:flex;align-items:center;justify-content:center;flex:1;flex-direction:column;gap:10px;color:var(--t3);font-size:13px;}
.no-chat-sel i{font-size:30px;color:var(--border);}
.chat-top-bar{padding:11px 15px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;background:var(--bg);}
.chat-top-bar strong{font-size:14px;color:var(--text);}
.chat-top-bar span{font-size:12px;color:var(--t3);}
.empty{text-align:center;padding:40px;color:var(--t3);}
.empty i{font-size:32px;color:var(--border);display:block;margin-bottom:10px;}
/* RESPONSIVE */
@media(max-width:900px){.sb{display:none;}.main{margin-left:0;}.stats{grid-template-columns:1fr 1fr;}.fg-grid{grid-template-columns:1fr;}.chat-pane{flex-direction:column;}.chat-list-col{width:100%;max-height:220px;border-right:none;border-bottom:1px solid var(--border);}}
@media(max-width:500px){.stats{grid-template-columns:1fr;}}
</style>
</head>
<body>
<aside class="sb">
  <div class="sb-brand">
    <div class="sb-ico"><img src="/images/favicon.png" alt="BT" onerror="this.outerHTML='<i class=\'fas fa-car\' style=\'color:#fff;font-size:16px\'></i>'"></div>
    <h1>Brajwasi Travels</h1><span>Admin Panel</span>
  </div>
  <button class="ni on" id="n0" onclick="showT('dash',this)"><i class="fas fa-tachometer-alt"></i> Dashboard</button>
  <button class="ni" id="n1" onclick="showT('add',this)"><i class="fas fa-plus-circle"></i> Add New Car</button>
  <button class="ni" id="n2" onclick="showT('fleet',this)"><i class="fas fa-car-side"></i> Fleet</button>
  <a href="/admin/bookings" class="ni"><i class="fas fa-calendar-check"></i> Bookings <% if(stats.pendingBookings>0){%><span class="nb"><%= stats.pendingBookings %></span><%}%></a>
  <button class="ni" id="n3" onclick="showT('chat',this);loadChats()"><i class="fas fa-comments"></i> Customer Chat <span class="nb" id="total-unread" style="display:none">!</span></button>
  <button class="ni" id="n4" onclick="showT('push',this)"><i class="fas fa-bell"></i> Push</button>
  <div class="sb-ft">
    <a href="/track" target="_blank" class="ni"><i class="fas fa-map-marker-alt"></i> Tracking Page</a>
    <a href="/" target="_blank" class="ni"><i class="fas fa-external-link-alt"></i> View Website</a>
    <a href="/admin/logout" class="ni" style="color:var(--red)"><i class="fas fa-sign-out-alt"></i> Logout</a>
  </div>
</aside>

<main class="main">
  <div class="topbar">
    <h2 id="pt">Dashboard</h2>
    <div style="display:flex;gap:8px">
      <a href="tel:9411061000" class="btn btn-sec btn-sm"><i class="fas fa-phone"></i> 9411061000</a>
      <a href="/admin/logout" class="btn btn-danger btn-sm"><i class="fas fa-sign-out-alt"></i> Logout</a>
    </div>
  </div>
  <div class="content">

    <!-- DASHBOARD -->
    <div id="tp-dash" class="tp on">
      <div class="stats">
        <div class="sc"><div class="ico ic-gold"><i class="fas fa-car"></i></div><div class="lbl">Active Cars</div><div class="num"><%= stats.totalCars %></div></div>
        <div class="sc"><div class="ico ic-g"><i class="fas fa-calendar-check"></i></div><div class="lbl">Total Bookings</div><div class="num"><%= stats.totalBookings %></div></div>
        <div class="sc"><div class="ico ic-b"><i class="fas fa-clock"></i></div><div class="lbl">Pending</div><div class="num"><%= stats.pendingBookings %></div></div>
        <div class="sc"><div class="ico ic-r"><i class="fas fa-check"></i></div><div class="lbl">Confirmed</div><div class="num"><%= stats.confirmedBookings %></div></div>
      </div>
      <div class="card">
        <div class="card-hd"><h3><i class="fas fa-clock"></i> Recent Bookings</h3><a href="/admin/bookings" class="btn btn-sec btn-sm">View All</a></div>
        <div class="tw"><table><thead><tr><th>Booking ID</th><th>Customer</th><th>Car</th><th>Route</th><th>Date</th><th>Amount</th><th>Status</th></tr></thead><tbody>
          <%if(!bookings.length){%><tr><td colspan="7"><div class="empty"><i class="fas fa-calendar-times"></i>No bookings yet</div></td></tr><%}%>
          <%bookings.forEach(b=>{%><tr>
            <td style="font-weight:700;color:var(--gold)"><%=b.bookingId%></td>
            <td><div><%=b.customerName%></div><div style="font-size:11px;color:var(--t3)"><%=b.customerPhone%></div></td>
            <td><%=b.carName||'—'%></td>
            <td style="font-size:12px"><%=b.pickupLocation%> → <%=b.dropLocation%></td>
            <td style="font-size:12px"><%=new Date(b.journeyDate).toLocaleDateString('en-IN')%></td>
            <td style="color:var(--green);font-weight:700"><%=b.totalPrice?'₹'+b.totalPrice.toLocaleString('en-IN'):'TBD'%></td>
            <td><span class="bdg b-<%=b.status%>"><%=b.status.replace('_',' ')%></span></td>
          </tr><%})%>
        </tbody></table></div>
      </div>
    </div>

    <!-- ADD CAR -->
    <div id="tp-add" class="tp">
      <div class="card">
        <div class="card-hd"><h3><i class="fas fa-plus-circle"></i> Add New Car</h3></div>
        <form class="form-pad" method="POST" action="/admin/cars/add" enctype="multipart/form-data">
          <div class="fg-grid">
            <div class="fg"><label>Brand *</label><input type="text" name="name" placeholder="e.g. Toyota" required></div>
            <div class="fg"><label>Model *</label><input type="text" name="model" placeholder="e.g. Innova Crysta" required></div>
            <div class="fg"><label>Photo *</label><input type="file" name="image" accept="image/*" required></div>
            <div class="fg"><label>Available In</label><input type="text" name="availableIn" value="Agra" placeholder="Agra, Delhi"></div>
            <div class="fg"><label>Price Per KM ₹ *</label><input type="number" name="pricePerKm" placeholder="12" required min="1"></div>
            <div class="fg"><label>Extra KM Charge ₹ *</label><input type="number" name="extraKmCharge" placeholder="12" required min="1"></div>
            <div class="fg"><label>Fixed Package KM</label><input type="number" name="fixedKm" placeholder="300 (optional)"></div>
            <div class="fg"><label>Fixed Package Price ₹ (blank=auto)</label><input type="number" name="fixedPrice" placeholder="Leave blank to auto-calc"></div>
            <div class="fg"><label>Toll Tax Info</label><input type="text" name="tollTax" value="As per actual (paid by customer)"></div>
            <div class="fg"><label>Seats</label><select name="seats"><option value="4">4</option><option value="5">5</option><option value="6">6</option><option value="7" selected>7</option><option value="8">8</option><option value="12">12</option></select></div>
            <div class="fg"><label>AC</label><select name="ac"><option value="true">AC ✅</option><option value="false">Non-AC</option></select></div>
            <div class="fg fg-full"><label>Description</label><textarea name="description" rows="2" placeholder="Describe the vehicle..."></textarea></div>
          </div>
          <button type="submit" class="btn btn-gold" style="margin-top:8px"><i class="fas fa-plus"></i> Add Car</button>
        </form>
      </div>
    </div>

    <!-- FLEET -->
    <div id="tp-fleet" class="tp">
      <div class="card">
        <div class="card-hd"><h3><i class="fas fa-car-side"></i> Fleet (<%= cars.length %>)</h3><button onclick="showT('add',document.getElementById('n1'))" class="btn btn-gold btn-sm"><i class="fas fa-plus"></i> Add</button></div>
        <div class="tw"><table><thead><tr><th>Photo</th><th>Car</th><th>Pricing</th><th>Available</th><th>Active</th><th>Actions</th></tr></thead><tbody>
          <%if(!cars.length){%><tr><td colspan="6"><div class="empty"><i class="fas fa-car"></i>No cars yet</div></td></tr><%}%>
          <%cars.forEach(car=>{%><tr>
            <td><img src="<%=car.image%>" class="thumb" onerror="this.src='/images/default-crysta.jpg'" alt="<%=car.model%>"></td>
            <td><div style="font-weight:600"><%=car.model%></div><div style="font-size:11px;color:var(--t3)"><%=car.name%> · <%=car.seats%>s<%=car.ac?' · AC':''%></div><div style="font-size:11px;color:var(--t3)"><%=car.availableIn.join(', ')%></div></td>
            <td><div style="color:var(--gold);font-weight:700">₹<%=car.pricePerKm%>/km</div><%if(car.fixedPackage&&car.fixedPackage.km){%><div style="color:var(--green);font-size:12px">₹<%=car.fixedPackage.price%>/<%=car.fixedPackage.km%>km</div><%}%><div style="font-size:11px;color:var(--t3)">Extra:₹<%=car.extraKmCharge%>/km</div></td>
            <td><label class="tgl"><input type="checkbox" <%=car.isAvailable?'checked':''%> onchange="toggleAvail('<%=car._id%>',this)"><span class="tslider"></span></label><div style="font-size:10px;color:var(--t3);margin-top:3px"><%=car.isAvailable?'Available':'Unavailable'%></div></td>
            <td><span class="bdg b-<%=car.isActive?'active':'inactive'%>"><%=car.isActive?'Active':'Inactive'%></span></td>
            <td><div style="display:flex;gap:5px;flex-wrap:wrap">
              <a href="/admin/cars/<%=car._id%>/edit" class="btn btn-blue btn-sm"><i class="fas fa-edit"></i> Edit</a>
              <form method="POST" action="/admin/cars/<%=car._id%>/toggle" style="display:inline"><button type="submit" class="btn btn-sec btn-sm"><i class="fas fa-toggle-<%=car.isActive?'on':'off'%>"></i> <%=car.isActive?'Disable':'Enable'%></button></form>
              <form method="POST" action="/admin/cars/<%=car._id%>/delete" style="display:inline" onsubmit="return confirm('Delete this car?')"><button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button></form>
            </div></td>
          </tr><%})%>
        </tbody></table></div>
      </div>
    </div>

    <!-- CHAT -->
    <div id="tp-chat" class="tp">
      <div class="card">
        <div class="card-hd"><h3><i class="fas fa-comments"></i> Customer Chats</h3><span style="font-size:12px;color:var(--t3)">Private – only admin can see all chats</span></div>
        <div class="chat-pane">
          <div class="chat-list-col" id="chat-list"><div class="empty"><i class="fas fa-comments"></i>Loading...</div></div>
          <div class="chat-main-col" id="chat-main"><div class="no-chat-sel"><i class="fas fa-comments"></i>Select a conversation</div></div>
        </div>
      </div>
    </div>

    <!-- PUSH -->
    <div id="tp-push" class="tp">
      <div class="card">
        <div class="card-hd"><h3><i class="fas fa-bell"></i> Push Notifications</h3></div>
        <div class="form-pad">
          <p style="font-size:13px;color:var(--t3);margin-bottom:14px">Send notifications to all users – delivered even when the app is closed.</p>
          <div class="fg-grid">
            <div class="fg"><label>Title *</label><input type="text" id="push-title" value="🚗 Brajwasi Travels"></div>
            <div class="fg"><label>Message *</label><input type="text" id="push-body" placeholder="Your message..."></div>
          </div>
          <div style="display:flex;gap:9px;flex-wrap:wrap;margin-top:8px">
            <button class="btn btn-gold" onclick="sendPush(event)"><i class="fas fa-paper-plane"></i> Send to All</button>
            <button class="btn btn-sec" onclick="document.getElementById('push-body').value='🎉 Special discount! Book now and save.'"><i class="fas fa-tag"></i> Offer</button>
            <button class="btn btn-sec" onclick="document.getElementById('push-body').value='📞 Please confirm your upcoming booking. Call 9411061000.'"><i class="fas fa-phone"></i> Reminder</button>
          </div>
          <div id="push-res" style="margin-top:12px"></div>
        </div>
      </div>
    </div>

  </div>
</main>

<script src="/socket.io/socket.io.js"></script>
<script>
let curChat = null, curChatName = '', curChatPhone = '';
let adminSock = null;

// ===== INIT: get token then connect socket =====
async function initAdminSocket() {
  try {
    const { token } = await fetch('/admin-socket-token').then(r => r.json());
    adminSock = io({ query: { adminToken: token } });

    adminSock.on('connect', () => console.log('✅ Admin socket connected'));
    adminSock.on('connect_error', e => console.error('Socket error:', e.message));

    adminSock.on('new-cust-msg', data => {
      const unreadEl = document.getElementById('total-unread');
      if (unreadEl) unreadEl.style.display = 'flex';
      playPing();
      // If chat tab is open, refresh list
      if (document.getElementById('tp-chat').classList.contains('on')) {
        loadChats();
        // If this session is active, append live
        if (curChat === data.sessionId) appendMsg('customer', data.text, data.ts);
      } else {
        loadChats(); // keep list fresh
      }
    });

    adminSock.on('chat-list-update', () => loadChats());

  } catch(e) { console.error('initAdminSocket error:', e); }
}

initAdminSocket();

// ===== PWA PUSH SETUP =====
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('/sw.js').then(async reg => {
    if (Notification.permission === 'default') await Notification.requestPermission();
    if (Notification.permission === 'granted') {
      try {
        const { publicKey } = await fetch('/vapid-public-key').then(r => r.json());
        if (!publicKey) return;
        const sub = await reg.pushManager.subscribe({
          userVisibleOnly: true,
          applicationServerKey: b64ToUint8(publicKey)
        });
        await fetch('/subscribe', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(sub) });
        console.log('✅ Admin push subscribed');
      } catch(e) { console.log('Push setup:', e.message); }
    }
  });
}

function b64ToUint8(b64) {
  const pad = '='.repeat((4 - b64.length % 4) % 4);
  const base64 = (b64 + pad).replace(/-/g, '+').replace(/_/g, '/');
  const raw = atob(base64);
  return Uint8Array.from([...raw].map(c => c.charCodeAt(0)));
}

function playPing() {
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    const o = ctx.createOscillator(), g = ctx.createGain();
    o.connect(g); g.connect(ctx.destination);
    o.frequency.setValueAtTime(880, ctx.currentTime);
    o.frequency.setValueAtTime(660, ctx.currentTime + 0.12);
    g.gain.setValueAtTime(0.25, ctx.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.35);
    o.start(); o.stop(ctx.currentTime + 0.35);
  } catch(e) {}
}

// ===== TABS =====
function showT(name, el) {
  document.querySelectorAll('.tp').forEach(t => t.classList.remove('on'));
  document.querySelectorAll('.ni').forEach(n => n.classList.remove('on'));
  document.getElementById('tp-' + name)?.classList.add('on');
  if (el) el.classList.add('on');
  const names = { dash: 'Dashboard', add: 'Add New Car', fleet: 'Fleet', chat: 'Customer Chat', push: 'Push Notifications' };
  document.getElementById('pt').textContent = names[name] || name;
}

// ===== AVAILABILITY =====
async function toggleAvail(id, cb) {
  try {
    const d = await fetch('/admin/cars/' + id + '/availability', { method: 'POST' }).then(r => r.json());
    const lbl = cb.closest('td').querySelector('div');
    if (lbl) lbl.textContent = d.isAvailable ? 'Available' : 'Unavailable';
  } catch(e) { cb.checked = !cb.checked; }
}

// ===== CHAT =====
async function loadChats() {
  try {
    const d = await fetch('/admin/chat/list').then(r => r.json());
    const list = document.getElementById('chat-list');
    if (!d.chats || !d.chats.length) {
      list.innerHTML = '<div class="empty"><i class="fas fa-comments"></i><br>No chats yet</div>';
      return;
    }
    list.innerHTML = d.chats.map(c => {
      const init = (c.customerName || 'G').charAt(0).toUpperCase();
      const phone = c.customerPhone ? ' · ' + c.customerPhone : '';
      const last = (c.lastMessage && !c.lastMessage.startsWith('[Info]')) ? c.lastMessage.substring(0, 40) : 'New conversation';
      const unrd = c.unreadCount > 0 ? `<span class="c-unread">${c.unreadCount}</span>` : '';
      const act = curChat === c.sessionId ? ' on' : '';
      const sid = c.sessionId;
      const cname = esc(c.customerName || 'Guest');
      const cphone = (c.customerPhone || '');
      return `<div class="chat-item${act}" data-id="${sid}" onclick="openChat('${sid}','${cname.replace(/'/g,"\'")}','${cphone}')">
        <div class="c-av">${init}</div>
        <div class="c-meta"><strong>${cname}${esc(phone)}</strong><span>${esc(last)}</span></div>
        ${unrd}
      </div>`;
    }).join('');
  } catch(e) { console.error('loadChats error:', e); }
}

async function openChat(sid, name, phone) {
  curChat = sid; curChatName = name; curChatPhone = phone;
  document.querySelectorAll('.chat-item').forEach(i => i.classList.toggle('on', i.dataset.id === sid));
  // Remove unread badge
  const item = document.querySelector(`.chat-item[data-id="${sid}"]`);
  if (item) { const b = item.querySelector('.c-unread'); if (b) b.remove(); }
  if (adminSock) adminSock.emit('admin-read', { sessionId: sid });
  await loadMsgs(sid, name, phone);
}

async function loadMsgs(sid, name, phone) {
  try {
    const d = await fetch('/admin/chat/' + sid).then(r => r.json());
    const msgs = (d.chat && d.chat.messages ? d.chat.messages : []).filter(m => !m.text.startsWith('[Info]'));
    const main = document.getElementById('chat-main');
    const phoneDisp = (phone || (d.chat && d.chat.customerPhone)) ? ` <span style="color:var(--t3);font-size:12px">· ${phone || d.chat.customerPhone}</span>` : '';
    const displayName = name || (d.chat && d.chat.customerName) || 'Customer';

    main.innerHTML =
      `<div class="chat-top-bar">
        <div><strong>${esc(displayName)}${phoneDisp}</strong></div>
        <button onclick="clearChat('${sid}')" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i> Clear History</button>
      </div>
      <div class="msgs-area" id="msgs-area">
        ${msgs.length === 0
          ? '<div style="text-align:center;color:var(--t3);padding:24px;font-size:13px">No messages yet</div>'
          : msgs.map(m => {
              const t = new Date(m.timestamp);
              const time = t.getHours() + ':' + String(t.getMinutes()).padStart(2, '0');
              return `<div class="mb ${m.sender}">${esc(m.text)}<span class="mb-t">${time}</span></div>`;
            }).join('')
        }
      </div>
      <div class="msg-inp">
        <input id="rep-inp" type="text" placeholder="Reply to ${esc(displayName)}..." onkeypress="if(event.key==='Enter')sendRep()">
        <button onclick="sendRep()"><i class="fas fa-paper-plane"></i></button>
      </div>`;

    const ma = document.getElementById('msgs-area');
    if (ma) ma.scrollTop = ma.scrollHeight;
  } catch(e) { console.error('loadMsgs error:', e); }
}

function appendMsg(sender, text, ts) {
  const ma = document.getElementById('msgs-area');
  if (!ma) return;
  const placeholder = ma.querySelector('[style*="No messages"]');
  if (placeholder) placeholder.remove();
  const t = new Date(ts);
  const time = t.getHours() + ':' + String(t.getMinutes()).padStart(2, '0');
  const d = document.createElement('div');
  d.className = 'mb ' + sender;
  d.innerHTML = esc(text) + `<span class="mb-t">${time}</span>`;
  ma.appendChild(d);
  ma.scrollTop = ma.scrollHeight;
}

function sendRep() {
  const inp = document.getElementById('rep-inp');
  const text = inp ? inp.value.trim() : '';
  if (!text || !curChat || !adminSock) return;
  adminSock.emit('admin-msg', { sessionId: curChat, text });
  appendMsg('admin', text, new Date());
  if (inp) inp.value = '';
  loadChats();
}

async function clearChat(sid) {
  if (!confirm('Clear all messages? This cannot be undone.')) return;
  try {
    await fetch('/admin/chat/' + sid + '/clear', { method: 'DELETE' });
    await loadMsgs(sid, curChatName, curChatPhone);
    loadChats();
    aToast('Chat history cleared', 'ok');
  } catch(e) {}
}

// ===== PUSH =====
async function sendPush(e) {
  const btn = e.target;
  const title = document.getElementById('push-title').value;
  const body = document.getElementById('push-body').value;
  if (!title || !body) { alert('Fill in both title and message'); return; }
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner" style="animation:spin 1s linear infinite"></i> Sending...';
  try {
    await fetch('/admin/push', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title, body }) });
    const el = document.getElementById('push-res');
    if (el) el.innerHTML = '<div style="background:var(--gbg);border:1px solid rgba(26,122,58,0.2);color:var(--green);padding:10px 13px;border-radius:8px;font-size:13px"><i class="fas fa-check-circle"></i> Sent to all subscribed users!</div>';
    setTimeout(() => { const el2 = document.getElementById('push-res'); if (el2) el2.innerHTML = ''; }, 5000);
  } catch(e) {}
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-paper-plane"></i> Send to All';
}

// ===== UTILS =====
function esc(t) { return String(t || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function aToast(msg, type) {
  const t = document.createElement('div');
  t.style.cssText = `position:fixed;bottom:20px;left:50%;transform:translateX(-50%);z-index:9999;
    background:${type==='ok'?'var(--gbg)':'#FEF2F2'};
    border:1px solid ${type==='ok'?'rgba(26,122,58,0.3)':'#FECACA'};
    color:${type==='ok'?'var(--green)':'var(--red)'};
    padding:10px 18px;border-radius:8px;font-size:13px;font-family:'DM Sans',sans-serif;
    box-shadow:0 4px 16px rgba(0,0,0,0.1);`;
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 3000);
}
</script>
