<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Login – Brajwasi Tour & Travels</title>
<link rel="icon" type="image/png" href="/images/favicon.png">
<link rel="manifest" href="/admin-manifest.json">
<meta name="theme-color" content="#B8780A">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:linear-gradient(135deg,#FFF8EC 0%,#F8F5F0 100%);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;}
.login-card{background:#fff;border:1px solid #E8DDD0;border-radius:20px;padding:40px;width:100%;max-width:400px;box-shadow:0 8px 40px rgba(184,120,10,0.12);}
.login-logo{text-align:center;margin-bottom:28px;}
.login-logo .logo-icon{width:64px;height:64px;background:linear-gradient(135deg,#D4920E,#8A5A06);border-radius:16px;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;overflow:hidden;box-shadow:0 4px 16px rgba(184,120,10,.25);}
.login-logo .logo-icon img{width:100%;height:100%;object-fit:cover;border-radius:16px;}
.login-logo h1{font-family:'Playfair Display',serif;font-size:20px;color:#1A1208;}
.login-logo p{font-size:11px;color:#B8780A;letter-spacing:2px;text-transform:uppercase;margin-top:3px;}
.form-group{margin-bottom:16px;}
.form-group label{display:block;font-size:11px;color:#7A6A55;margin-bottom:6px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;}
.form-group input{width:100%;background:#F8F5F0;border:1px solid #E8DDD0;color:#1A1208;padding:12px 16px;border-radius:10px;font-size:14px;font-family:'DM Sans',sans-serif;outline:none;transition:all .2s;}
.form-group input:focus{border-color:#B8780A;box-shadow:0 0 0 3px rgba(184,120,10,.1);}
.btn-login{width:100%;background:linear-gradient(135deg,#D4920E,#8A5A06);color:#fff;border:none;padding:13px;border-radius:10px;font-weight:700;font-size:15px;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s;box-shadow:0 2px 12px rgba(184,120,10,.25);}
.btn-login:hover{opacity:.9;transform:translateY(-1px);}
.error-msg{background:#FDEDEB;border:1px solid rgba(192,57,43,.2);color:#C0392B;padding:12px 16px;border-radius:8px;font-size:13px;margin-bottom:16px;display:flex;align-items:center;gap:8px;}
.secure-note{text-align:center;margin-top:16px;font-size:12px;color:#A0917E;display:flex;align-items:center;justify-content:center;gap:6px;}
</style>
</head>
<body>
<div class="login-card">
  <div class="login-logo">
    <div class="logo-icon">
      <img src="/images/favicon.png" alt="BT" onerror="this.style.display='none';this.parentNode.innerHTML='<i class=\'fas fa-car\' style=\'color:#fff;font-size:26px\'></i>'">
    </div>
    <h1>Brajwasi Tour & Travels</h1>
    <p>Admin Panel</p>
  </div>
  <% if(error){ %>
  <div class="error-msg"><i class="fas fa-exclamation-circle"></i><%= error %></div>
  <% } %>
  <form method="POST" action="/admin/login">
    <div class="form-group">
      <label>Username</label>
      <input type="text" name="username" placeholder="Enter username" required autofocus>
    </div>
    <div class="form-group">
      <label>Password</label>
      <input type="password" name="password" placeholder="Enter password" required>
    </div>
    <button type="submit" class="btn-login"><i class="fas fa-sign-in-alt"></i> Login to Admin Panel</button>
  </form>
  <p class="secure-note"><i class="fas fa-lock"></i> Secure admin access only</p>
</div>
</body>
</html>
