<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Admin Login – Brajwasi Travels</title>
<link rel="manifest" href="/admin-manifest.json">
<link rel="icon" type="image/png" href="/images/favicon.png">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
:root{--gold:#B8731A;--g2:#D4882A;--bg:#F8F4EF;--white:#fff;--text:#1C1C1C;--t3:#7A7A7A;--border:#E8DDD0;--red:#C0392B;}
*{box-sizing:border-box;margin:0;padding:0;}body{font-family:'DM Sans',sans-serif;background:var(--bg);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;}
.card{background:var(--white);border:1px solid var(--border);border-radius:18px;padding:36px 32px;width:100%;max-width:400px;box-shadow:0 8px 32px rgba(0,0,0,0.08);}
.brand{text-align:center;margin-bottom:28px;}
.brand-ico{width:56px;height:56px;background:linear-gradient(135deg,var(--gold),var(--g2));border-radius:13px;display:inline-flex;align-items:center;justify-content:center;margin-bottom:12px;overflow:hidden;}
.brand-ico img{width:100%;height:100%;object-fit:cover;}
.brand h1{font-family:'Playfair Display',serif;font-size:20px;color:var(--text);}
.brand span{font-size:11px;color:var(--gold);letter-spacing:2px;text-transform:uppercase;}
h2{font-size:22px;margin-bottom:4px;color:var(--text);}
.sub{font-size:14px;color:var(--t3);margin-bottom:22px;}
.fg{margin-bottom:15px;}.fg label{display:block;font-size:12px;color:var(--t3);font-weight:600;margin-bottom:5px;}
.iw{position:relative;}.iw i{position:absolute;left:13px;top:50%;transform:translateY(-50%);color:var(--t3);font-size:13px;}
input{width:100%;background:var(--bg);border:1px solid var(--border);color:var(--text);padding:11px 13px 11px 38px;border-radius:9px;font-size:14px;font-family:'DM Sans',sans-serif;outline:none;transition:all 0.2s;}
input:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(184,115,26,0.08);}
.err{background:#FEF2F2;border:1px solid #FECACA;color:var(--red);padding:10px 13px;border-radius:8px;font-size:13px;margin-bottom:15px;display:flex;align-items:center;gap:8px;}
button{width:100%;background:linear-gradient(135deg,var(--gold),var(--g2));color:#fff;border:none;padding:13px;border-radius:9px;font-weight:700;font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:all 0.2s;}
button:hover{opacity:.92;}
.back{text-align:center;margin-top:18px;font-size:13px;color:var(--t3);}
.back a{color:var(--gold);text-decoration:none;font-weight:600;}
</style>
</head>
<body>
<div class="card">
  <div class="brand">
    <div class="brand-ico"><img src="/images/favicon.png" alt="BT" onerror="this.outerHTML='<i class=\'fas fa-car\' style=\'color:#fff;font-size:22px\'></i>'"></div>
    <h1>Brajwasi Travels</h1><span>Admin Portal</span>
  </div>
  <h2>Welcome Back</h2>
  <p class="sub">Sign in to manage your fleet and bookings</p>
  <%if(error){%><div class="err"><i class="fas fa-exclamation-circle"></i><%=error%></div><%}%>
  <form method="POST" action="/admin/login">
    <div class="fg"><label>Username</label><div class="iw"><i class="fas fa-user"></i><input type="text" name="username" placeholder="admin" required autofocus></div></div>
    <div class="fg"><label>Password</label><div class="iw"><i class="fas fa-lock"></i><input type="password" name="password" placeholder="••••••••" required></div></div>
    <button type="submit"><i class="fas fa-sign-in-alt"></i> Sign In</button>
  </form>
  <div class="back"><a href="/"><i class="fas fa-arrow-left"></i> Back to Website</a></div>
</div>
</body>
</html>
