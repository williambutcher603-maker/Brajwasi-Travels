<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Driver App – Brajwasi Travels</title>
<link rel="manifest" href="/manifest.json">
<link rel="icon" type="image/png" href="/images/favicon.png">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="theme-color" content="#B8780A">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
:root{--gold:#B8780A;--gold-l:#D4920E;--gold-d:#8A5A06;--gold-bg:#FFF8EC;--bg:#fff;--bg2:#F8F5F0;--border:#E8DDD0;--text:#1A1208;--muted:#7A6A55;--green:#1A7A3A;--green-bg:#EAF7EE;--red:#C0392B;--red-bg:#FDEDEB;}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--bg2);color:var(--text);min-height:100vh;}
.app{max-width:440px;margin:0 auto;padding:20px 16px;min-height:100vh;display:flex;flex-direction:column;gap:16px;}
.logo-bar{display:flex;align-items:center;gap:10px;padding:14px 18px;background:linear-gradient(135deg,#B8780A,#8A5A06);border-radius:14px;color:#fff;}
.logo-bar img{width:36px;height:36px;border-radius:8px;object-fit:cover;}
.logo-bar h1{font-size:16px;font-weight:700;}
.logo-bar span{font-size:11px;opacity:.8;}
.card{background:var(--bg);border:1px solid var(--border);border-radius:16px;overflow:hidden;box-shadow:0 2px 12px rgba(184,120,10,.08);}
.card-head{padding:14px 18px;border-bottom:1px solid var(--border);font-size:14px;font-weight:700;color:var(--text);display:flex;align-items:center;gap:8px;}
.card-head i{color:var(--gold);}
.card-body{padding:18px;}
label{display:block;font-size:11px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin-bottom:5px;}
input,select{width:100%;background:var(--bg2);border:1px solid var(--border);color:var(--text);padding:11px 14px;border-radius:10px;font-size:14px;font-family:'DM Sans',sans-serif;outline:none;transition:all .2s;margin-bottom:12px;}
input:focus,select:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(184,120,10,.1);}
.btn{width:100%;padding:14px;border:none;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;display:flex;align-items:center;justify-content:center;gap:8px;transition:all .2s;}
.btn-gold{background:linear-gradient(135deg,var(--gold-l),var(--gold-d));color:#fff;}
.btn-gold:hover{opacity:.9;}
.btn-red{background:var(--red-bg);color:var(--red);border:1px solid rgba(192,57,43,.2);}
.btn-green{background:var(--green-bg);color:var(--green);border:1px solid rgba(26,122,58,.2);}
.status-card{padding:16px 18px;border-radius:12px;display:flex;align-items:center;gap:12px;font-size:14px;font-weight:600;}
.status-live{background:var(--green-bg);color:var(--green);border:1px solid rgba(26,122,58,.2);}
.status-stopped{background:var(--red-bg);color:var(--red);border:1px solid rgba(192,57,43,.2);}
.status-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.dot-green{background:var(--green);animation:pulse 1.5s infinite;}
.dot-red{background:var(--red);}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.6;transform:scale(1.3)}}
.info-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px;}
.info-row:last-child{border-bottom:none;}
.info-row .lbl{color:var(--muted);}
.info-row .val{font-weight:600;}
.alert{padding:12px 16px;border-radius:10px;font-size:13px;font-weight:600;display:flex;align-items:center;gap:8px;margin-bottom:12px;}
.alert-success{background:var(--green-bg);color:var(--green);border:1px solid rgba(26,122,58,.2);}
.alert-error{background:var(--red-bg);color:var(--red);border:1px solid rgba(192,57,43,.2);}
.hidden{display:none;}
.link-btn{background:none;border:none;color:var(--gold);font-size:13px;font-weight:600;cursor:pointer;padding:0;font-family:'DM Sans',sans-serif;text-decoration:underline;}
.divider{text-align:center;color:var(--muted);font-size:13px;margin:4px 0;}
</style>
</head>
<body>
<div class="app">
  <div class="logo-bar">
    <img src="/images/favicon.png" alt="BT" onerror="this.style.display='none'">
    <div><h1>Driver App</h1><span>Brajwasi Tour & Travels</span></div>
  </div>

  <!-- Setup form -->
  <div id="setupSection">
    <div class="card">
      <div class="card-head"><i class="fas fa-key"></i> Login to Driver App</div>
      <div class="card-body">
        <div id="loginAlert"></div>
        <label>Your Driver Secret Code</label>
        <input type="password" id="secretInput" placeholder="Enter your secret code" autocomplete="off">
        <label>Booking ID assigned to you</label>
        <input type="text" id="bookingIdInput" placeholder="e.g. BT-A1B2C3" style="text-transform:uppercase">
        <button class="btn btn-gold" onclick="startDriver()"><i class="fas fa-play"></i> Start Session</button>
        <div class="divider" style="margin:16px 0">— Forgot your secret? —</div>
        <button class="link-btn" onclick="showResetForm()">Reset via email OTP</button>
      </div>
    </div>

    <!-- Reset secret form -->
    <div class="card hidden" id="resetForm">
      <div class="card-head"><i class="fas fa-unlock"></i> Reset Driver Secret</div>
      <div class="card-body">
        <div id="resetAlert"></div>
        <label>Your Registered Email</label>
        <input type="email" id="resetEmail" placeholder="you@example.com">
        <button class="btn btn-gold" onclick="sendResetOtp()" id="sendOtpBtn"><i class="fas fa-paper-plane"></i> Send OTP to Email</button>
        <div id="otpSection" class="hidden" style="margin-top:12px">
          <label>OTP from Email</label>
          <input type="text" id="resetOtp" placeholder="6-digit OTP" maxlength="6">
          <label>New Secret Code (min 6 chars)</label>
          <input type="password" id="newSecret" placeholder="New secret code">
          <button class="btn btn-green" onclick="verifyResetOtp()"><i class="fas fa-check"></i> Set New Secret</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Active session -->
  <div id="sessionSection" class="hidden">
    <div id="liveStatus" class="status-card status-stopped">
      <div class="status-dot dot-red" id="statusDot"></div>
      <span id="statusText">Location sharing OFF</span>
    </div>

    <div class="card">
      <div class="card-head"><i class="fas fa-info-circle"></i> Session Info</div>
      <div class="card-body">
        <div class="info-row"><span class="lbl">Booking ID</span><span class="val" id="sessionBookingId"></span></div>
        <div class="info-row"><span class="lbl">Updates Sent</span><span class="val" id="updateCount">0</span></div>
        <div class="info-row"><span class="lbl">Last Update</span><span class="val" id="lastUpdateTime">—</span></div>
        <div class="info-row"><span class="lbl">GPS Status</span><span class="val" id="gpsStatus">Waiting…</span></div>
      </div>
    </div>

    <button class="btn btn-gold" id="toggleBtn" onclick="toggleSharing()">
      <i class="fas fa-location-arrow"></i> Start Sharing Location
    </button>

    <!-- Complete trip -->
    <div class="card">
      <div class="card-head"><i class="fas fa-flag-checkered"></i> Complete Trip</div>
      <div class="card-body">
        <div id="completeAlert"></div>
        <p style="font-size:13px;color:var(--muted);margin-bottom:12px">After the trip ends, enter the actual kilometres driven. This will calculate the final fare.</p>
        <label>Actual KM Driven</label>
        <input type="number" id="actualKmInput" placeholder="e.g. 145" min="1">
        <button class="btn btn-green" onclick="submitActualKm()"><i class="fas fa-check-circle"></i> Submit & Complete Trip</button>
      </div>
    </div>

    <button class="btn btn-red" onclick="endSession()" style="margin-top:4px"><i class="fas fa-power-off"></i> End Session & Logout</button>
  </div>
</div>

<script>
let secret = '', bookingId = '', sharing = false, watchId = null, updateCount = 0;

// Persist session in localStorage so screen off / reopen works
function loadSession() {
  secret = localStorage.getItem('drv_secret') || '';
  bookingId = localStorage.getItem('drv_booking') || '';
  if (secret && bookingId) {
    document.getElementById('setupSection').classList.add('hidden');
    document.getElementById('sessionSection').classList.remove('hidden');
    document.getElementById('sessionBookingId').textContent = bookingId;
    autoStartSharing();
  }
}

function startDriver() {
  const s = document.getElementById('secretInput').value.trim();
  const b = document.getElementById('bookingIdInput').value.trim().toUpperCase();
  if (!s || !b) { showAlert('loginAlert', 'Please enter both secret and booking ID', 'error'); return; }
  secret = s; bookingId = b;
  localStorage.setItem('drv_secret', s);
  localStorage.setItem('drv_booking', b);
  document.getElementById('setupSection').classList.add('hidden');
  document.getElementById('sessionSection').classList.remove('hidden');
  document.getElementById('sessionBookingId').textContent = b;
  autoStartSharing();
}

function autoStartSharing() {
  // Auto-start if was sharing before (handles screen-off scenario)
  if (localStorage.getItem('drv_sharing') === 'true') toggleSharing();
}

function toggleSharing() {
  if (!sharing) {
    if (!navigator.geolocation) { alert('GPS not available on this device'); return; }
    sharing = true;
    localStorage.setItem('drv_sharing', 'true');
    document.getElementById('toggleBtn').innerHTML = '<i class="fas fa-stop-circle"></i> Stop Sharing Location';
    document.getElementById('toggleBtn').className = 'btn btn-red';
    document.getElementById('liveStatus').className = 'status-card status-live';
    document.getElementById('statusDot').className = 'status-dot dot-green';
    document.getElementById('statusText').textContent = 'Location sharing LIVE';
    watchId = navigator.geolocation.watchPosition(onLocation, onGpsError, {
      enableHighAccuracy: true,
      maximumAge: 5000,
      timeout: 15000
    });
  } else {
    stopSharing();
  }
}

function stopSharing() {
  sharing = false;
  localStorage.setItem('drv_sharing', 'false');
  if (watchId) { navigator.geolocation.clearWatch(watchId); watchId = null; }
  document.getElementById('toggleBtn').innerHTML = '<i class="fas fa-location-arrow"></i> Start Sharing Location';
  document.getElementById('toggleBtn').className = 'btn btn-gold';
  document.getElementById('liveStatus').className = 'status-card status-stopped';
  document.getElementById('statusDot').className = 'status-dot dot-red';
  document.getElementById('statusText').textContent = 'Location sharing OFF';
}

async function onLocation(pos) {
  const lat = pos.coords.latitude, lng = pos.coords.longitude;
  document.getElementById('gpsStatus').textContent = lat.toFixed(5) + ', ' + lng.toFixed(5);
  try {
    const r = await fetch('/api/driver/location', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ bookingId, lat, lng, secret })
    });
    const d = await r.json();
    if (d.success) {
      updateCount++;
      document.getElementById('updateCount').textContent = updateCount;
      document.getElementById('lastUpdateTime').textContent = new Date().toLocaleTimeString('en-IN');
    } else if (d.error === 'Invalid secret') {
      stopSharing();
      alert('Invalid secret code. Please login again.');
      endSession();
    }
  } catch(e) { /* Network error — will retry on next GPS update */ }
}

function onGpsError(err) {
  document.getElementById('gpsStatus').textContent = 'GPS error: ' + err.message;
}

async function submitActualKm() {
  const km = document.getElementById('actualKmInput').value;
  if (!km || +km < 1) { showAlert('completeAlert', 'Please enter actual kilometres', 'error'); return; }
  try {
    const r = await fetch('/api/driver/complete', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ bookingId, actualKm: km, secret })
    });
    const d = await r.json();
    if (d.success) {
      stopSharing();
      showAlert('completeAlert', `Trip completed! Final fare: ₹${d.finalFare.toLocaleString('en-IN')} | Advance deducted: ₹${d.advanceDeducted} | Balance due: ₹${d.balanceDue}`, 'success');
    } else { showAlert('completeAlert', d.error || 'Failed', 'error'); }
  } catch(e) { showAlert('completeAlert', 'Network error', 'error'); }
}

function endSession() {
  stopSharing();
  localStorage.removeItem('drv_secret');
  localStorage.removeItem('drv_booking');
  localStorage.removeItem('drv_sharing');
  secret = ''; bookingId = '';
  document.getElementById('setupSection').classList.remove('hidden');
  document.getElementById('sessionSection').classList.add('hidden');
}

function showResetForm() {
  document.getElementById('resetForm').classList.toggle('hidden');
}

async function sendResetOtp() {
  const email = document.getElementById('resetEmail').value.trim();
  if (!email) { showAlert('resetAlert', 'Please enter your email', 'error'); return; }
  const btn = document.getElementById('sendOtpBtn');
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...'; btn.disabled = true;
  try {
    const r = await fetch('/api/driver/reset-secret/send-otp', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email })
    });
    const d = await r.json();
    if (d.success) {
      showAlert('resetAlert', 'OTP sent! Check your email.', 'success');
      document.getElementById('otpSection').classList.remove('hidden');
    } else { showAlert('resetAlert', d.error, 'error'); }
  } catch(e) { showAlert('resetAlert', 'Network error', 'error'); }
  btn.innerHTML = '<i class="fas fa-paper-plane"></i> Send OTP to Email'; btn.disabled = false;
}

async function verifyResetOtp() {
  const email = document.getElementById('resetEmail').value.trim();
  const otp = document.getElementById('resetOtp').value.trim();
  const newSecret = document.getElementById('newSecret').value.trim();
  if (!email || !otp || !newSecret) { showAlert('resetAlert', 'Fill all fields', 'error'); return; }
  const r = await fetch('/api/driver/reset-secret/verify', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email, otp, newSecret })
  });
  const d = await r.json();
  if (d.success) { showAlert('resetAlert', 'Secret reset! Use your new code to login.', 'success'); document.getElementById('otpSection').classList.add('hidden'); document.getElementById('resetForm').classList.add('hidden'); }
  else showAlert('resetAlert', d.error, 'error');
}

function showAlert(id, msg, type) {
  const el = document.getElementById(id);
  el.innerHTML = `<div class="alert alert-${type}"><i class="fas fa-${type==='success'?'check-circle':'exclamation-circle'}"></i>${msg}</div>`;
  if (type === 'success') setTimeout(() => { if (el) el.innerHTML = ''; }, 6000);
}

// Keep GPS alive even when screen is off via Wake Lock API
async function requestWakeLock() {
  try { if ('wakeLock' in navigator) await navigator.wakeLock.request('screen'); } catch(e) {}
}

// Register service worker for background operation
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('/sw.js').then(() => console.log('SW registered')).catch(console.error);
}

requestWakeLock();
loadSession();

// Restore wake lock when page becomes visible again
document.addEventListener('visibilitychange', async () => {
  if (!document.hidden) { await requestWakeLock(); if (sharing && !watchId) toggleSharing(); }
});
</script>
</body>
</html>
