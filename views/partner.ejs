<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Partner With Us – Brajwasi Travels Agra | Register Your Car</title>
<meta name="description" content="Register your car with Brajwasi Travels Agra and earn money. Easy onboarding, transparent 10% commission, and regular bookings.">
<link rel="icon" type="image/png" href="/images/favicon.png">
<meta name="theme-color" content="#B8780A">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
:root{--gold:#B8780A;--gold-l:#D4920E;--gold-d:#8A5A06;--gold-bg:#FFF8EC;--gold-bg2:#FEF3DC;--bg:#fff;--bg2:#F8F5F0;--bg3:#F0EBE3;--border:#E8DDD0;--text:#1A1208;--muted:#7A6A55;--light:#A0917E;--green:#1A7A3A;--green-bg:#EAF7EE;--red:#C0392B;--red-bg:#FDEDEB;--r:12px;}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--bg2);color:var(--text);}
.header{background:var(--bg);border-bottom:1px solid var(--border);padding:14px 20px;display:flex;align-items:center;gap:12px;box-shadow:0 2px 12px rgba(184,120,10,.08);}
.logo-icon{width:40px;height:40px;background:linear-gradient(135deg,var(--gold-l),var(--gold-d));border-radius:9px;display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0;}
.logo-icon img{width:100%;height:100%;object-fit:cover;border-radius:9px;}
.logo h1{font-family:'Playfair Display',serif;font-size:16px;color:var(--text);}
.logo span{font-size:10px;color:var(--gold);letter-spacing:1.5px;text-transform:uppercase;}
.back-btn{margin-left:auto;display:inline-flex;align-items:center;gap:6px;color:var(--muted);text-decoration:none;font-size:13px;font-weight:600;padding:7px 14px;border:1px solid var(--border);border-radius:8px;transition:all .2s;}
.back-btn:hover{color:var(--gold);border-color:var(--gold);}
.hero{background:linear-gradient(135deg,#B8780A,#8A5A06);padding:60px 20px;text-align:center;color:#fff;}
.hero h2{font-family:'Playfair Display',serif;font-size:clamp(28px,5vw,46px);margin-bottom:14px;}
.hero p{font-size:17px;opacity:.85;max-width:580px;margin:0 auto 28px;line-height:1.7;}
.benefits{display:flex;justify-content:center;gap:28px;flex-wrap:wrap;margin-top:8px;}
.benefit{text-align:center;padding:14px 20px;background:rgba(255,255,255,.15);border-radius:12px;min-width:140px;}
.benefit .num{font-family:'Playfair Display',serif;font-size:30px;font-weight:700;color:#FFD980;}
.benefit .lbl{font-size:12px;opacity:.8;text-transform:uppercase;letter-spacing:1px;}
.commission-note{background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.35);border-radius:12px;padding:14px 20px;margin-top:20px;display:inline-flex;align-items:center;gap:10px;font-size:15px;font-weight:600;}
.page{max-width:760px;margin:0 auto;padding:32px 20px;}
.section-title{font-family:'Playfair Display',serif;font-size:22px;margin-bottom:20px;color:var(--text);}
/* How it works */
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:40px;}
.step{background:var(--bg);border:1px solid var(--border);border-radius:14px;padding:22px;text-align:center;}
.step-num{width:40px;height:40px;background:linear-gradient(135deg,var(--gold-l),var(--gold-d));color:#fff;border-radius:50%;font-weight:800;font-size:16px;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;}
.step h4{font-size:15px;font-weight:700;margin-bottom:6px;}
.step p{font-size:13px;color:var(--muted);line-height:1.5;}
/* Form card */
.form-card{background:var(--bg);border:1px solid var(--border);border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(184,120,10,.1);}
.form-section{padding:24px;border-bottom:1px solid var(--border);}
.form-section:last-child{border-bottom:none;}
.form-section h3{font-size:15px;font-weight:700;margin-bottom:16px;display:flex;align-items:center;gap:8px;color:var(--gold-d);}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.form-group{display:flex;flex-direction:column;gap:5px;}
.form-group.full{grid-column:1/-1;}
label{font-size:11px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.5px;}
input,select,textarea{background:var(--bg2);border:1px solid var(--border);color:var(--text);padding:10px 14px;border-radius:var(--r);font-size:13px;font-family:'DM Sans',sans-serif;outline:none;transition:all .2s;width:100%;}
input:focus,select:focus,textarea:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(184,120,10,.1);}
select option{background:var(--bg);}
/* Doc upload */
.doc-upload{border:2px dashed var(--border);border-radius:var(--r);padding:18px;text-align:center;cursor:pointer;transition:all .2s;background:var(--bg2);}
.doc-upload:hover{border-color:var(--gold);background:var(--gold-bg);}
.doc-upload i{font-size:28px;color:var(--gold);display:block;margin-bottom:8px;}
.doc-upload p{font-size:13px;color:var(--muted);margin-bottom:4px;}
.doc-upload span{font-size:11px;color:var(--light);}
.doc-preview{display:none;margin-top:10px;font-size:12px;color:var(--green);font-weight:600;}
.doc-preview i{margin-right:5px;}
input[type=file]{position:absolute;opacity:0;width:0;height:0;}
/* Commission box */
.commission-box{background:var(--gold-bg);border:1px solid rgba(184,120,10,.3);border-radius:12px;padding:16px 18px;margin-bottom:20px;display:flex;gap:14px;align-items:flex-start;}
.commission-box .icon{width:40px;height:40px;background:var(--gold-bg2);border-radius:10px;display:flex;align-items:center;justify-content:center;color:var(--gold);font-size:18px;flex-shrink:0;}
.commission-box h4{color:var(--gold-d);font-size:14px;font-weight:700;margin-bottom:4px;}
.commission-box p{font-size:13px;color:var(--muted);line-height:1.5;}
.submit-btn{width:100%;padding:15px;background:linear-gradient(135deg,var(--gold-l),var(--gold-d));color:#fff;border:none;border-radius:var(--r);font-size:16px;font-weight:800;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:all .2s;font-family:'DM Sans',sans-serif;letter-spacing:.3px;}
.submit-btn:hover{opacity:.92;transform:translateY(-1px);}
.alert{padding:14px 18px;border-radius:10px;font-size:14px;margin-bottom:16px;display:flex;align-items:center;gap:10px;}
.alert-success{background:var(--green-bg);border:1px solid rgba(26,122,58,.25);color:var(--green);}
.alert-error{background:var(--red-bg);border:1px solid rgba(192,57,43,.2);color:var(--red);}
.hidden{display:none!important;}
@media(max-width:600px){.form-grid{grid-template-columns:1fr;}.steps{grid-template-columns:1fr;}.benefits{gap:12px;}.benefit{min-width:120px;}}
</style>
</head>
<body>
<div class="header">
  <div class="logo-icon"><img src="/images/favicon.png" alt="BT" onerror="this.style.display='none';this.parentNode.innerHTML='<i class=\'fas fa-car\' style=\'color:#fff\'></i>'"></div>
  <div class="logo"><h1>Brajwasi Tour & Travels</h1><span>Partner Programme</span></div>
  <a href="/" class="back-btn"><i class="fas fa-arrow-left"></i> Back</a>
</div>

<div class="hero">
  <h2>Drive More. Earn More.<br>Partner With Us.</h2>
  <p>Join Agra's trusted cab network. Get regular bookings, transparent commissions, and full support from Brajwasi Travels.</p>
  <div class="benefits">
    <div class="benefit"><div class="num">₹0</div><div class="lbl">Registration Fee</div></div>
    <div class="benefit"><div class="num">10%</div><div class="lbl">Commission Only</div></div>
    <div class="benefit"><div class="num">24/7</div><div class="lbl">Support</div></div>
  </div>
  <div class="commission-note" style="margin-top:24px">
    <i class="fas fa-info-circle"></i>
    We charge only <strong>10% commission</strong> on completed trips — you keep 90% of the fare.
  </div>
</div>

<div class="page">
  <h2 class="section-title" style="text-align:center;margin-bottom:8px">How It Works</h2>
  <p style="text-align:center;color:var(--muted);margin-bottom:24px;font-size:15px">Simple 3-step process to start earning</p>
  <div class="steps">
    <div class="step"><div class="step-num">1</div><h4>Register Below</h4><p>Fill the form with your car details and upload your documents. Free to join.</p></div>
    <div class="step"><div class="step-num">2</div><h4>Admin Reviews</h4><p>Our team verifies your documents and approves your profile within 24 hours.</p></div>
    <div class="step"><div class="step-num">3</div><h4>Get Bookings</h4><p>You get an email when a booking is assigned to you. Just show up and drive!</p></div>
  </div>

  <!-- Alert messages -->
  <div id="alertBox" class="alert hidden"></div>

  <!-- Success state -->
  <div id="successBox" class="hidden" style="text-align:center;background:var(--bg);border:1px solid var(--border);border-radius:16px;padding:40px 24px;margin-bottom:24px">
    <div style="font-size:56px;margin-bottom:16px">🎉</div>
    <h2 style="font-family:'Playfair Display',serif;font-size:26px;margin-bottom:10px">Registration Submitted!</h2>
    <p style="color:var(--muted);max-width:420px;margin:0 auto 20px">Your application is under review. We'll email you at <strong id="submittedEmail"></strong> within 24 hours.</p>
    <a href="/" style="display:inline-flex;align-items:center;gap:8px;background:linear-gradient(135deg,var(--gold-l),var(--gold-d));color:#fff;padding:12px 28px;border-radius:30px;text-decoration:none;font-weight:700">
      <i class="fas fa-home"></i> Back to Home
    </a>
  </div>

  <form id="partnerForm" enctype="multipart/form-data">
    <div class="form-card">

      <!-- Owner details -->
      <div class="form-section">
        <h3><i class="fas fa-user-circle"></i> Owner Details</h3>
        <div class="form-grid">
          <div class="form-group"><label>Full Name *</label><input type="text" name="ownerName" placeholder="Your full name" required></div>
          <div class="form-group"><label>Phone Number *</label><input type="tel" name="phone" placeholder="10-digit mobile number" required></div>
          <div class="form-group full"><label>Email Address *</label><input type="email" name="email" placeholder="you@example.com (booking assignments will be sent here)" required></div>
          <div class="form-group full">
            <label>Driver Secret Code * <span style="font-size:11px;color:var(--muted);text-transform:none;letter-spacing:0;font-weight:400">(min 6 characters — used to share live location. Keep it private!)</span></label>
            <input type="password" name="driverSecret" placeholder="Create a secret code (min 6 chars)" required minlength="6" autocomplete="new-password">
          </div>
        </div>
      </div>

      <!-- Car details -->
      <div class="form-section">
        <h3><i class="fas fa-car"></i> Car Details</h3>
        <div class="form-grid">
          <div class="form-group"><label>Car Brand *</label><input type="text" name="carName" placeholder="e.g. Toyota, Maruti" required></div>
          <div class="form-group"><label>Car Model *</label><input type="text" name="carModel" placeholder="e.g. Innova Crysta, Ertiga" required></div>
          <div class="form-group"><label>Registration Number *</label><input type="text" id="carNumber" name="carNumber" placeholder="e.g. UP80AB1234" required style="text-transform:uppercase"></div>
          <div class="form-group"><label>Seating Capacity</label>
            <select name="seats">
              <option value="4">4 Seater</option>
              <option value="5">5 Seater</option>
              <option value="6">6 Seater</option>
              <option value="7" selected>7 Seater</option>
              <option value="8">8 Seater</option>
              <option value="12">12 Seater (Tempo)</option>
            </select>
          </div>
          <div class="form-group"><label>Air Conditioning</label>
            <select name="ac"><option value="true">AC ✅</option><option value="false">Non-AC</option></select>
          </div>
        </div>
      </div>

      <!-- Pricing -->
      <div class="form-section">
        <h3><i class="fas fa-rupee-sign"></i> Your Pricing</h3>
        <div class="commission-box">
          <div class="icon"><i class="fas fa-percent"></i></div>
          <div>
            <h4>10% Commission applies on all trips</h4>
            <p>Brajwasi Tour & Travels charges a 10% commission on every completed trip. Example: If total fare is ₹1,000 — you earn ₹900, we keep ₹100. Set your prices accordingly.</p>
          </div>
        </div>
        <div class="form-grid">
          <div class="form-group"><label>Price Per KM (₹) *</label><input type="number" name="pricePerKm" placeholder="e.g. 12" min="5" required></div>
          <div class="form-group"><label>Extra KM Charge (₹) *</label><input type="number" name="extraKmCharge" placeholder="e.g. 12" min="5" required></div>
          <div class="form-group"><label>Fixed Package KM (optional)</label><input type="number" name="fixedKm" placeholder="e.g. 300"></div>
          <div class="form-group"><label>Fixed Package Price ₹ (optional)</label><input type="number" name="fixedPrice" placeholder="e.g. 3200"></div>
        </div>
        <p style="font-size:12px;color:var(--light);margin-top:10px"><i class="fas fa-info-circle" style="margin-right:5px"></i>Leave fixed package blank if you only charge per km.</p>
      </div>

      <!-- Documents -->
      <div class="form-section">
        <h3><i class="fas fa-file-alt"></i> Required Documents</h3>
        <p style="font-size:13px;color:var(--muted);margin-bottom:20px">Upload clear photos or scans. Accepted formats: JPG, PNG, PDF (max 10MB each)</p>
        <div class="form-grid">
          <div class="form-group">
            <label>Driving Licence *</label>
            <label for="licInput" class="doc-upload" id="licLabel">
              <i class="fas fa-id-card"></i>
              <p>Click to upload Driving Licence</p>
              <span>Front side required</span>
            </label>
            <input type="file" id="licInput" name="licensePhoto" accept="image/*,.pdf" required onchange="showDocName(this,'licLabel','licPreview')">
            <div class="doc-preview" id="licPreview"><i class="fas fa-check-circle"></i><span></span></div>
          </div>
          <div class="form-group">
            <label>Vehicle RC (Registration Certificate) *</label>
            <label for="rcInput" class="doc-upload" id="rcLabel">
              <i class="fas fa-car"></i>
              <p>Click to upload Vehicle RC</p>
              <span>Both sides if needed</span>
            </label>
            <input type="file" id="rcInput" name="rcPhoto" accept="image/*,.pdf" required onchange="showDocName(this,'rcLabel','rcPreview')">
            <div class="doc-preview" id="rcPreview"><i class="fas fa-check-circle"></i><span></span></div>
          </div>
          <div class="form-group full">
            <label>Vehicle Insurance *</label>
            <label for="insInput" class="doc-upload" id="insLabel" style="max-width:380px">
              <i class="fas fa-shield-alt"></i>
              <p>Click to upload Insurance Certificate</p>
              <span>Must be currently valid</span>
            </label>
            <input type="file" id="insInput" name="insurancePhoto" accept="image/*,.pdf" required onchange="showDocName(this,'insLabel','insPreview')">
            <div class="doc-preview" id="insPreview"><i class="fas fa-check-circle"></i><span></span></div>
          </div>
        </div>
      </div>

      <!-- Terms and submit -->
      <div class="form-section">
        <div style="display:flex;gap:10px;align-items:flex-start;margin-bottom:20px;padding:14px;background:var(--bg2);border-radius:10px">
          <input type="checkbox" id="agreeTerms" style="margin-top:3px;width:16px;height:16px;flex-shrink:0" required>
          <label for="agreeTerms" style="font-size:13px;color:var(--muted);text-transform:none;letter-spacing:0;font-weight:400;cursor:pointer">
            I agree that Brajwasi Tour & Travels will deduct <strong>10% commission</strong> from every completed booking assigned to me. I confirm all documents uploaded are genuine and valid.
          </label>
        </div>
        <button type="submit" class="submit-btn" id="submitPartnerBtn">
          <i class="fas fa-paper-plane"></i> Submit Registration
        </button>
      </div>

    </div>
  </form>
</div>

<script>
function showDocName(input, labelId, previewId) {
  const label = document.getElementById(labelId);
  const preview = document.getElementById(previewId);
  if (input.files && input.files[0]) {
    const name = input.files[0].name;
    label.style.borderColor = 'var(--green)';
    label.style.background = 'var(--green-bg)';
    label.querySelector('i').style.color = 'var(--green)';
    preview.style.display = 'flex';
    preview.style.alignItems = 'center';
    preview.style.gap = '6px';
    preview.querySelector('span').textContent = name;
  }
}

document.getElementById('carNumber')?.addEventListener('input', function() {
  this.value = this.value.toUpperCase();
});

document.getElementById('partnerForm').addEventListener('submit', async e => {
  e.preventDefault();

  // Client-side validation before sending
  var required = ['ownerName','phone','email','driverSecret','carName','carModel','carNumber','pricePerKm','extraKmCharge'];
  var missing = [];
  var form = e.target;
  for (var i=0; i<required.length; i++) {
    var el = form.elements[required[i]];
    if (!el || !el.value.trim()) missing.push(required[i]);
  }
  if (missing.length > 0) {
    var alertBox = document.getElementById('alertBox');
    alertBox.className = 'alert alert-error';
    alertBox.innerHTML = '<i class="fas fa-exclamation-circle"></i> Please fill: ' + missing.join(', ');
    alertBox.classList.remove('hidden');
    alertBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }

  var secretEl = form.elements['driverSecret'];
  if (secretEl && secretEl.value.trim().length < 6) {
    var alertBox = document.getElementById('alertBox');
    alertBox.className = 'alert alert-error';
    alertBox.innerHTML = '<i class="fas fa-exclamation-circle"></i> Driver secret code must be at least 6 characters.';
    alertBox.classList.remove('hidden');
    alertBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }

  var fileFields = ['licensePhoto','rcPhoto','insurancePhoto'];
  for (var j=0; j<fileFields.length; j++) {
    var fileEl = form.elements[fileFields[j]];
    if (!fileEl || !fileEl.files || !fileEl.files.length) {
      var alertBox = document.getElementById('alertBox');
      alertBox.className = 'alert alert-error';
      alertBox.innerHTML = '<i class="fas fa-exclamation-circle"></i> Please upload all 3 documents (Licence, RC, Insurance).';
      alertBox.classList.remove('hidden');
      alertBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }
  }

  const btn = document.getElementById('submitPartnerBtn');
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Submitting...'; btn.disabled = true;

  const formData = new FormData(e.target);

  try {
    const r = await fetch('/api/partner/register', { 
      method: 'POST', 
      body: formData
    });
    const d = await r.json();
    if (d.success) {
      document.getElementById('partnerForm').classList.add('hidden');
      document.getElementById('submittedEmail').textContent = formData.get('email');
      document.getElementById('successBox').classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    } else {
      const alertBox = document.getElementById('alertBox');
      alertBox.className = 'alert alert-error';
      alertBox.innerHTML = '<i class="fas fa-exclamation-circle"></i> ' + (d.error || 'Registration failed. Please try again.');
      alertBox.classList.remove('hidden');
      alertBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  } catch(err) {
    const alertBox = document.getElementById('alertBox');
    alertBox.className = 'alert alert-error';
    alertBox.innerHTML = '<i class="fas fa-exclamation-circle"></i> Network error. Please check your connection and try again.';
    alertBox.classList.remove('hidden');
  } finally {
    btn.innerHTML = '<i class="fas fa-paper-plane"></i> Submit Registration'; btn.disabled = false;
  }
});
</script>
</body>
</html>
