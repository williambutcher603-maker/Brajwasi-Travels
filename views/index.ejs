<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Brajwasi Tour & Travels Agra | Tour & Travels in Agra</title>
<meta name="description" content="Brajwasi Tour & Travels Agra – Trusted car rental since 1980. Book Innova Crysta for Taj Mahal tours, Agra sightseeing, and outstation trips at best price.">
<meta name="keywords" content="tour travels agra, car rental agra, innova crysta agra, taj mahal tour, agra cab booking, brajwasi travels">
<!-- Google Search Console: paste your verification meta tag here -->
<!-- <meta name="google-site-verification" content="YOUR_CODE_HERE" /> -->
<link rel="manifest" href="/manifest.json">
<link rel="icon" href="/images/favicon.png">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link rel="stylesheet" href="/css/main.css">
</head>
<body>

<!-- Push permission bar -->
<div id="notif-bar" class="notif-bar" style="display:none">
  <i class="fas fa-bell"></i>
  <span>Get booking updates & special offers directly on your device</span>
  <button onclick="requestNotificationPermission()">Enable</button>
  <button onclick="document.getElementById('notif-bar').style.display='none'" class="nb-close"><i class="fas fa-times"></i></button>
</div>

<!-- Header -->
<header class="header" id="header">
  <nav class="nav container">
    <a href="/" class="logo">
      <div class="logo-icon"><i class="fas fa-car"></i></div>
      <div>
        <h1>Brajwasi Tour & Travels</h1>
        <span>Est. 1980 · Agra</span>
      </div>
    </a>
    <div class="nav-links">
      <a href="#fleet">Our Fleet</a>
      <a href="#why-us">Why Us</a>
      <a href="#contact">Contact</a>
      <a href="tel:9411061000" class="call-btn"><i class="fas fa-phone"></i> 9411061000</a>
    </div>
    <button class="hamburger" id="hamburger" aria-label="Menu"><i class="fas fa-bars"></i></button>
  </nav>
  <div class="mobile-menu" id="mobile-menu">
    <a href="#fleet" onclick="closeMobileMenu()"><i class="fas fa-car-side"></i> Our Fleet</a>
    <a href="#why-us" onclick="closeMobileMenu()"><i class="fas fa-star"></i> Why Us</a>
    <a href="#contact" onclick="closeMobileMenu()"><i class="fas fa-envelope"></i> Contact</a>
    <a href="tel:9411061000"><i class="fas fa-phone"></i> Call: 9411061000</a>
  </div>
</header>

<!-- Hero -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="container hero-content">
    <div class="hero-badge"><i class="fas fa-award"></i> Trusted Since 1980</div>
    <h1 class="hero-title">Agra's Most<br><em>Trusted Travels</em></h1>
    <p class="hero-subtitle">Premium cab service for Taj Mahal tours, outstation trips and airport transfers. 40+ years of trust, thousands of happy travellers.</p>
    <div class="hero-actions">
      <a href="#fleet" class="btn-primary"><i class="fas fa-car"></i> View Our Fleet</a>
      <a href="https://wa.me/919411061000" target="_blank" class="btn-wa"><i class="fab fa-whatsapp"></i> WhatsApp Us</a>
    </div>
    <div class="hero-stats">
      <div class="stat"><span>40+</span><em>Years</em></div>
      <div class="vd"></div>
      <div class="stat"><span>5000+</span><em>Trips Done</em></div>
      <div class="vd"></div>
      <div class="stat"><span>24/7</span><em>Service</em></div>
    </div>
  </div>
  <div class="scroll-down"><i class="fas fa-chevron-down"></i></div>
</section>

<!-- Fleet Section -->
<section class="section" id="fleet">
  <div class="container">
    <div class="sec-head">
      <span class="sec-tag">Our Fleet</span>
      <h2>Choose Your Ride</h2>
      <p>All vehicles are AC equipped, well-maintained and driven by verified professional chauffeurs.</p>
    </div>
    <div class="cars-grid">
      <% if (cars.length === 0) { %>
        <div class="no-cars"><i class="fas fa-car-side"></i><p>Fleet details coming soon. Call <a href="tel:9411061000">9411061000</a></p></div>
      <% } else { %>
      <% cars.forEach(car => {
        const fixedKm = car.fixedPackage && car.fixedPackage.km ? car.fixedPackage.km : null;
        const fixedCharge = fixedKm ? (fixedKm * car.pricePerKm) - 400 : null;
        const fixedPrice = car.fixedPackage && car.fixedPackage.price ? car.fixedPackage.price : fixedCharge;
      %>
      <div class="car-card <%= !car.isAvailable ? 'unavailable' : '' %>">
        <div class="car-img-wrap">
          <img src="<%= car.image %>" alt="<%= car.model %> for rent in Agra" loading="lazy" onerror="this.src='/images/default-crysta.jpg'">
          <div class="loc-badge"><i class="fas fa-map-marker-alt"></i> <%= car.availableIn.join(', ') %></div>
          <% if (car.ac) { %><div class="ac-badge"><i class="fas fa-snowflake"></i> AC</div><% } %>
          <% if (!car.isAvailable) { %><div class="unavail-overlay"><i class="fas fa-clock"></i><span>Currently Unavailable</span></div><% } %>
        </div>
        <div class="car-body">
          <div class="car-top">
            <div>
              <h3><%= car.model %></h3>
              <p class="car-sub"><%= car.name %> &bull; <i class="fas fa-users"></i> <%= car.seats %> Seats</p>
            </div>
          </div>
          <% if (car.description) { %>
          <p class="car-desc"><%= car.description %></p>
          <% } %>

          <!-- Pricing card -->
          <div class="pricing-card">
            <div class="price-main">
              <div class="price-item">
                <span class="pi-label">Per KM</span>
                <span class="pi-val">₹<%= car.pricePerKm %></span>
              </div>
              <% if (fixedKm && fixedPrice) { %>
              <div class="price-divider"></div>
              <div class="price-item highlight">
                <span class="pi-label"><%= fixedKm %> KM Package</span>
                <span class="pi-val green">₹<%= fixedPrice.toLocaleString('en-IN') %></span>
              </div>
              <div class="price-divider"></div>
              <div class="price-item">
                <span class="pi-label">Extra KM</span>
                <span class="pi-val">₹<%= car.extraKmCharge %>/km</span>
              </div>
              <% } %>
            </div>
            <% if (fixedKm && fixedPrice) { %>
            <div class="price-formula">
              <i class="fas fa-info-circle"></i>
              Fixed <%= fixedKm %>km = (<%= fixedKm %>km × ₹<%= car.pricePerKm %>) − ₹400 = <strong>₹<%= fixedPrice.toLocaleString('en-IN') %></strong> &bull; Extra KM @ ₹<%= car.extraKmCharge %>/km
            </div>
            <% } %>
            <div class="toll-row">
              <i class="fas fa-road"></i> Toll tax: <strong><%= car.tollTax %></strong>
            </div>
          </div>

          <% if (car.isAvailable) { %>
          <button class="book-btn" onclick="openBookingModal('<%= car._id %>', '<%= car.model %>', '<%= car.name %>', <%= car.pricePerKm %>, <%= fixedKm || 0 %>, <%= fixedPrice || 0 %>, <%= car.extraKmCharge %>)">
            <i class="fas fa-calendar-check"></i> Book Now
          </button>
          <% } else { %>
          <button class="book-btn unavail-btn" disabled>
            <i class="fas fa-clock"></i> Currently Unavailable
          </button>
          <% } %>
        </div>
      </div>
      <% }) %>
      <% } %>
    </div>
  </div>
</section>

<!-- Why Us -->
<section class="section why-section" id="why-us">
  <div class="container">
    <div class="sec-head">
      <span class="sec-tag">Why Choose Us</span>
      <h2>Our Promise To You</h2>
    </div>
    <div class="why-grid">
      <div class="why-card">
        <div class="why-icon"><i class="fas fa-shield-alt"></i></div>
        <h3>Safe & Reliable</h3>
        <p>Licensed verified drivers. Regularly serviced vehicles. Your safety is our top priority.</p>
      </div>
      <div class="why-card">
        <div class="why-icon"><i class="fas fa-clock"></i></div>
        <h3>24/7 Available</h3>
        <p>Round-the-clock service. Airport pickups, early mornings, late nights — we're always there.</p>
      </div>
      <div class="why-card">
        <div class="why-icon"><i class="fas fa-rupee-sign"></i></div>
        <h3>No Hidden Charges</h3>
        <p>Transparent pricing. Fixed packages & clear per-km rates. What you see is what you pay.</p>
      </div>
      <div class="why-card">
        <div class="why-icon"><i class="fas fa-map-marked-alt"></i></div>
        <h3>Local Experts</h3>
        <p>40+ years in Agra. Our drivers know every monument, shortcut and hidden gem.</p>
      </div>
    </div>
  </div>
</section>

<!-- Contact -->
<section class="section contact-section" id="contact">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-left">
        <span class="sec-tag">Get In Touch</span>
        <h2>Book Your Ride Today</h2>
        <p>Available 24 hours, 7 days. Call, WhatsApp or email us for instant booking.</p>
        <div class="cinfo-list">
          <a href="tel:9411061000" class="cinfo-item">
            <div class="ci-icon"><i class="fas fa-phone"></i></div>
            <div><strong>Phone / WhatsApp</strong><span>9411061000</span></div>
          </a>
          <a href="mailto:brajwasitravels.1980@gmail.com" class="cinfo-item">
            <div class="ci-icon"><i class="fas fa-envelope"></i></div>
            <div><strong>Email</strong><span>brajwasitravels.1980@gmail.com</span></div>
          </a>
          <div class="cinfo-item">
            <div class="ci-icon"><i class="fas fa-map-marker-alt"></i></div>
            <div><strong>Base Location</strong><span>Agra, Uttar Pradesh</span></div>
          </div>
        </div>
        <a href="https://wa.me/919411061000" target="_blank" class="wa-btn"><i class="fab fa-whatsapp"></i> Chat on WhatsApp</a>
      </div>
      <div class="contact-right">
        <div class="enquiry-form">
          <h3>Quick Enquiry</h3>
          <form id="enquiryForm">
            <div class="fg"><input type="text" id="eq-name" placeholder="Your Name *" required></div>
            <div class="fg"><input type="tel" id="eq-phone" placeholder="Phone Number *" required></div>
            <div class="fg"><input type="text" id="eq-route" placeholder="From → To (e.g. Agra → Delhi) *" required></div>
            <div class="fg"><input type="date" id="eq-date" required></div>
            <button type="submit" class="btn-primary full">Send on WhatsApp <i class="fas fa-arrow-right"></i></button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="footer">
  <div class="container footer-inner">
    <div class="f-brand">
      <div class="logo"><div class="logo-icon"><i class="fas fa-car"></i></div><div><h1>Brajwasi Tour & Travels</h1><span>Est. 1980 · Agra</span></div></div>
      <p>Premium car rental and tour services in Agra. Trusted by thousands for over four decades.</p>
    </div>
    <div class="f-links">
      <h4>Quick Links</h4>
      <a href="#fleet">Our Fleet</a>
      <a href="#why-us">Why Us</a>
      <a href="#contact">Contact</a>
    </div>
    <div class="f-contact">
      <h4>Contact</h4>
      <p><i class="fas fa-phone"></i> 9411061000</p>
      <p><i class="fas fa-envelope"></i> brajwasitravels.1980@gmail.com</p>
      <p><i class="fas fa-map-marker-alt"></i> Agra, Uttar Pradesh</p>
    </div>
  </div>
  <div class="footer-bottom">
    <p>© 2024 Brajwasi Tour & Travels, Agra. All rights reserved.</p>
  </div>
</footer>

<!-- Float Buttons -->
<a href="https://wa.me/919411061000" class="float-wa" target="_blank" title="WhatsApp"><i class="fab fa-whatsapp"></i></a>
<button class="float-chat" id="float-chat-btn" title="Chat with us" onclick="toggleChat()"><i class="fas fa-comments"></i><span class="chat-badge" id="chat-badge" style="display:none">1</span></button>

<!-- Customer Chat Widget -->
<div class="chat-widget" id="chat-widget" style="display:none">
  <div class="cw-header">
    <div class="cw-info">
      <div class="cw-avatar"><i class="fas fa-headset"></i></div>
      <div><strong>Brajwasi Travels Support</strong><span class="online-dot"></span><span>Online</span></div>
    </div>
    <button onclick="toggleChat()" class="cw-close"><i class="fas fa-times"></i></button>
  </div>
  <div id="cw-name-form" class="cw-name-form">
    <p>Please enter your details to start chat</p>
    <input type="text" id="cw-name" placeholder="Your Name *">
    <input type="tel" id="cw-phone" placeholder="Phone Number">
    <button onclick="startChat()">Start Chat <i class="fas fa-arrow-right"></i></button>
  </div>
  <div id="cw-messages" class="cw-messages" style="display:none"></div>
  <div id="cw-input-area" class="cw-input-area" style="display:none">
    <input type="text" id="cw-msg-input" placeholder="Type your message..." onkeypress="if(event.key==='Enter')sendChatMessage()">
    <button onclick="sendChatMessage()"><i class="fas fa-paper-plane"></i></button>
  </div>
</div>

<!-- Booking Modal -->
<div class="modal-overlay" id="bookingModal">
  <div class="modal">
    <button class="modal-close" onclick="closeBookingModal()"><i class="fas fa-times"></i></button>
    <div class="modal-hd">
      <h2><i class="fas fa-calendar-check"></i> Book Your Ride</h2>
      <p id="modal-car-name" class="modal-car"></p>
    </div>

    <!-- Live Price Calculator -->
    <div class="calc-box">
      <label>Estimate Your Fare</label>
      <div class="calc-row">
        <input type="number" id="est-km" placeholder="Enter distance in KM" min="1" oninput="calcPrice()">
        <span id="calc-price" class="calc-price"></span>
      </div>
      <p id="calc-note" class="calc-note"></p>
    </div>

    <form id="bookingForm" onsubmit="submitBooking(event)">
      <input type="hidden" id="bk-car-id">
      <div class="form-row-2">
        <div class="fg"><label>Full Name *</label><input type="text" id="bk-name" placeholder="Your name" required></div>
        <div class="fg"><label>Phone *</label><input type="tel" id="bk-phone" placeholder="Mobile number" required></div>
      </div>
      <div class="fg"><label>Email (optional)</label><input type="email" id="bk-email" placeholder="your@email.com"></div>
      <div class="form-row-2">
        <div class="fg"><label>Pickup Location *</label><input type="text" id="bk-pickup" placeholder="From where?" required></div>
        <div class="fg"><label>Drop Location *</label><input type="text" id="bk-drop" placeholder="Where to?" required></div>
      </div>
      <div class="form-row-2">
        <div class="fg"><label>Journey Date *</label><input type="date" id="bk-date" required></div>
        <div class="fg"><label>Journey Time *</label><input type="time" id="bk-time" required></div>
      </div>
      <div class="fg"><label>Special Instructions</label><textarea id="bk-notes" rows="2" placeholder="Any special requirements..."></textarea></div>

      <!-- Advance Payment Info -->
      <div class="advance-box">
        <div class="adv-icon"><i class="fas fa-info-circle"></i></div>
        <div>
          <strong>₹500 Advance Required</strong>
          <p>Pay ₹500 advance via UPI to confirm your booking. This amount is <em>fully refundable</em> if car doesn't arrive or you cancel before departure.</p>
          <div class="upi-id"><i class="fas fa-mobile-alt"></i> UPI ID: <strong>MRBRAJWASITRAVELS.eazypay@icici</strong> <button type="button" onclick="copyUPI()" class="copy-btn"><i class="fas fa-copy"></i> Copy</button></div>
        </div>
      </div>

      <button type="submit" class="book-submit" id="book-submit-btn">
        <i class="fas fa-check-circle"></i> Confirm Booking
      </button>
    </form>
  </div>
</div>

<!-- Success Modal -->
<div class="modal-overlay" id="successModal">
  <div class="modal success-modal">
    <div class="s-icon"><i class="fas fa-check-circle"></i></div>
    <h2>Booking Request Sent!</h2>
    <div class="s-booking-id" id="s-booking-id"></div>
    <p>Our team will call you shortly to confirm. Please pay <strong>₹500 advance</strong> to secure your booking.</p>
    <div class="upi-id" style="margin:12px 0"><i class="fas fa-mobile-alt"></i> UPI: <strong>MRBRAJWASITRAVELS.eazypay@icici</strong></div>
    <div class="s-actions">
      <a id="wa-share-btn" href="#" target="_blank" class="btn-primary"><i class="fab fa-whatsapp"></i> Share on WhatsApp</a>
      <button onclick="closeSuccessModal()" class="btn-outline">Close</button>
    </div>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
