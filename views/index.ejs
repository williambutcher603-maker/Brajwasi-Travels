<script>
// ═══════════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════════
var carData={},currentBookingId=null,payData=null;
var chatPhone=localStorage.getItem('bt_phone')||'';
var chatName=localStorage.getItem('bt_name')||'';
var lastMsgTs=null,chatPoll=null;
var customerSession=null;
var fbRating=0;

// ═══════════════════════════════════════════════
//  BOOT — runs after full DOM ready
// ═══════════════════════════════════════════════
document.addEventListener('DOMContentLoaded',function(){
  document.getElementById('heroBg')&&document.getElementById('heroBg').classList.add('loaded');
  initPush();
  wireChat();
  wireModals();
  wireBookingForm();
  wirePayBtn();
  wireEnquiry();
  wireFeedback();
  checkSession();
});
window.addEventListener('scroll',function(){
  var h=document.getElementById('header');
  if(h) h.classList.toggle('scrolled',window.scrollY>50);
});

// ═══════════════════════════════════════════════
//  CUSTOMER SESSION
// ═══════════════════════════════════════════════
function checkSession(){
  fetch('/api/auth/me').then(function(r){return r.json();}).then(function(d){
    if(d.loggedIn){customerSession=d;renderLoginBar(d);}
  }).catch(function(){});
}
function renderLoginBar(user){
  var bar=document.getElementById('loginBar');
  if(!bar)return;
  if(user){
    bar.innerHTML='<span style="font-size:13px;color:var(--muted)"><i class="fas fa-user-circle" style="color:var(--gold);margin-right:5px"></i>'+esc(user.name)+'</span> <button onclick="logoutCustomer()" style="background:none;border:1px solid var(--border);color:var(--muted);padding:5px 12px;border-radius:8px;font-size:12px;cursor:pointer;font-family:inherit;margin-left:8px">Logout</button>';
  }else{
    bar.innerHTML='<button onclick="openLoginModal()" style="display:inline-flex;align-items:center;gap:6px;background:var(--gold-bg);border:1px solid rgba(184,120,10,.3);color:var(--gold-d);padding:7px 16px;border-radius:8px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit"><i class="fas fa-user-circle"></i>Login to Book</button>';
  }
}
function logoutCustomer(){
  fetch('/api/auth/logout',{method:'POST'}).then(function(){customerSession=null;renderLoginBar(null);toast('Logged out','success');});
}

// ═══════════════════════════════════════════════
//  PUSH NOTIFICATIONS
// ═══════════════════════════════════════════════
function initPush(){
  if(!('serviceWorker'in navigator)||!('PushManager'in window))return;
  navigator.serviceWorker.register('/sw.js').then(function(){
    if(Notification.permission==='default'){
      setTimeout(function(){
        var nb=document.getElementById('notif-bar');
        if(nb)nb.style.display='flex';
      },5000);
    }
  }).catch(function(){});
}
function requestPush(){
  var nb=document.getElementById('notif-bar');
  if(nb)nb.style.display='none';
  Notification.requestPermission().then(function(p){
    if(p!=='granted')return;
    navigator.serviceWorker.ready.then(function(reg){
      fetch('/vapid-public-key').then(function(r){return r.json();}).then(function(d){
        if(!d.publicKey)return;
        reg.pushManager.subscribe({userVisibleOnly:true,applicationServerKey:b64ToUint8(d.publicKey)}).then(function(sub){
          var sd=JSON.parse(JSON.stringify(sub));
          sd.role='customer'; sd.phone=chatPhone||'';
          fetch('/subscribe',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(sd)});
          toast('Notifications enabled!','success');
        });
      });
    });
  });
}
function resubWithPhone(phone){
  if(!('serviceWorker'in navigator)||Notification.permission!=='granted')return;
  navigator.serviceWorker.ready.then(function(reg){
    reg.pushManager.getSubscription().then(function(sub){
      if(!sub)return;
      var sd=JSON.parse(JSON.stringify(sub));
      sd.role='customer'; sd.phone=phone;
      fetch('/subscribe',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(sd)});
    });
  });
}
function b64ToUint8(b){
  var pad='='.repeat((4-b.length%4)%4);
  var raw=atob((b+pad).replace(/-/g,'+').replace(/_/g,'/'));
  return Uint8Array.from(raw,function(c){return c.charCodeAt(0);});
}

// ═══════════════════════════════════════════════
//  CHAT
// ═══════════════════════════════════════════════
function wireChat(){
  var toggle=document.getElementById('chatToggle');
  var closeB=document.getElementById('chatCloseBtn');
  var startB=document.getElementById('chatStartBtn');
  var sendB=document.getElementById('chatSendBtn');
  var inp=document.getElementById('chatIn');
  if(!toggle){return;}
  toggle.addEventListener('click',function(e){e.stopPropagation();toggleChat();});
  if(closeB)closeB.addEventListener('click',function(e){e.stopPropagation();toggleChat();});
  if(startB)startB.addEventListener('click',startChat);
  if(sendB)sendB.addEventListener('click',sendChatMsg);
  if(inp)inp.addEventListener('keypress',function(e){if(e.key==='Enter')sendChatMsg();});
  if(chatPhone){
    var ni=document.getElementById('chatNameIn'),pi=document.getElementById('chatPhoneIn');
    if(ni)ni.value=chatName; if(pi)pi.value=chatPhone;
  }
}
function toggleChat(){
  var win=document.getElementById('chatWindow');
  if(!win)return;
  var open=win.classList.toggle('open');
  if(open){if(chatPhone)showChatBody();startChatPoll();}
  else stopChatPoll();
}
function showChatBody(){
  var s=document.getElementById('chatSetup'),b=document.getElementById('chatBody');
  if(s)s.style.display='none';
  if(b)b.style.display='flex';
  loadHistory();
}
function startChat(){
  var n=document.getElementById('chatNameIn')&&document.getElementById('chatNameIn').value.trim();
  var p=document.getElementById('chatPhoneIn')&&document.getElementById('chatPhoneIn').value.trim();
  if(!n||!p){toast('Enter name and phone','error');return;}
  chatName=n; chatPhone=p;
  localStorage.setItem('bt_name',n); localStorage.setItem('bt_phone',p);
  resubWithPhone(p);
  showChatBody();
}
function loadHistory(){
  if(!chatPhone)return;
  fetch('/api/chat/'+encodeURIComponent(chatPhone)+'/history').then(function(r){return r.json();}).then(function(d){
    var box=document.getElementById('chatMsgs');
    if(!box)return;
    box.innerHTML='';
    if(!d.messages||!d.messages.length){
      box.innerHTML='<div class="chat-empty" id="chatEmpty"><i class="fas fa-comment-slash" style="font-size:24px;display:block;margin-bottom:8px;color:#ccc"></i>No messages yet. Say hello!</div>';
    }else{
      d.messages.forEach(function(m){appendMsg(m,false);});
      lastMsgTs=d.messages[d.messages.length-1].createdAt;
    }
    scrollChat();
  }).catch(function(){});
}
function appendMsg(msg,doScroll){
  if(doScroll===undefined)doScroll=true;
  var box=document.getElementById('chatMsgs');
  if(!box)return;
  var empty=document.getElementById('chatEmpty');
  if(empty)empty.remove();
  if(msg._id&&document.getElementById('cm-'+msg._id))return;
  var d=document.createElement('div');
  d.className='chat-msg '+(msg.fromCustomer?'from-me':'from-admin');
  if(msg._id)d.id='cm-'+msg._id;
  var t=new Date(msg.createdAt).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'});
  d.innerHTML='<div>'+esc(msg.message)+'</div><div class="msg-time">'+(msg.fromCustomer?'You':'Brajwasi')+' · '+t+'</div>';
  box.appendChild(d);
  if(doScroll)scrollChat();
}
function scrollChat(){var b=document.getElementById('chatMsgs');if(b)b.scrollTop=b.scrollHeight;}
function sendChatMsg(){
  var inp=document.getElementById('chatIn');
  var msg=inp&&inp.value.trim();
  if(!msg||!chatPhone)return;
  inp.value='';
  var tid='tmp-'+Date.now();
  appendMsg({_id:tid,message:msg,fromCustomer:true,createdAt:new Date().toISOString()});
  fetch('/api/chat/send',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({customerName:chatName,customerPhone:chatPhone,message:msg})}).then(function(){
    lastMsgTs=new Date().toISOString();
    var te=document.getElementById('cm-'+tid);if(te)te.remove();
    loadHistory();
  }).catch(function(){});
}
function pollChat(){
  if(!chatPhone)return;
  var since=lastMsgTs||new Date(0).toISOString();
  fetch('/api/chat/'+encodeURIComponent(chatPhone)+'/updates?since='+encodeURIComponent(since)).then(function(r){return r.json();}).then(function(d){
    if(d.messages&&d.messages.length){
      d.messages.forEach(function(m){
        appendMsg(m);
        if(!lastMsgTs||new Date(m.createdAt)>new Date(lastMsgTs))lastMsgTs=m.createdAt;
      });
    }
  }).catch(function(){});
}
function startChatPoll(){if(!chatPoll)chatPoll=setInterval(pollChat,4000);}
function stopChatPoll(){clearInterval(chatPoll);chatPoll=null;}

