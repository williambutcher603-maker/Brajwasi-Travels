<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Brajwasi Tour & Travels Agra | Tour & Travels in Agra</title>
<meta name="description" content="Brajwasi Tour & Travels Agra – Trusted car rental since 2018. Book Innova Crysta for Taj Mahal tours, Agra sightseeing, and outstation trips.">
<!-- Google Search Console: replace content value below -->
<!-- <meta name="google-site-verification" content="YOUR_CODE_HERE" /> -->
<link rel="manifest" href="/manifest.json">
<link rel="icon" type="image/png" href="/images/favicon.png">
<link rel="apple-touch-icon" href="/images/favicon.png">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,400&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link rel="stylesheet" href="/css/main.css">
</head>
<body>

<div id="notif-bar" style="display:none" class="notif-bar">
  <i class="fas fa-bell"></i><span>Get booking updates on your phone</span>
  <button onclick="askNotifPermission()">Enable</button>
  <button class="nb-x" onclick="this.parentElement.style.display='none'"><i class="fas fa-times"></i></button>
</div>

<header class="hdr" id="hdr">
  <nav class="nav container">
    <a href="/" class="logo">
      <div class="logo-ico"><img src="/images/favicon.png" alt="BT" onerror="this.outerHTML='<i class=\'fas fa-car\'></i>'"></div>
      <div><h1>Brajwasi Tour & Travels</h1><span>Est. 2018 · Agra</span></div>
    </a>
    <div class="nav-links">
      <a href="#fleet">Fleet</a>
      <a href="#why">Why Us</a>
      <a href="/track">Track Booking</a>
      <a href="#contact">Contact</a>
      <a href="tel:9411061000" class="nav-call"><i class="fas fa-phone"></i> 9411061000</a>
    </div>
    <button class="burger" id="burger"><i class="fas fa-bars"></i></button>
  </nav>
  <div class="mob-nav" id="mob-nav">
    <a href="#fleet" onclick="closeMob()"><i class="fas fa-car-side"></i> Our Fleet</a>
    <a href="#why" onclick="closeMob()"><i class="fas fa-star"></i> Why Us</a>
    <a href="/track" onclick="closeMob()"><i class="fas fa-map-marker-alt"></i> Track Booking</a>
    <a href="#contact" onclick="closeMob()"><i class="fas fa-envelope"></i> Contact</a>
    <a href="tel:9411061000"><i class="fas fa-phone"></i> 9411061000</a>
  </div>
</header>

<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-ov"></div>
  <div class="container hero-in">
    <span class="hero-badge"><i class="fas fa-award"></i> Trusted Since 2018</span>
    <h1>Agra's Most<br><em>Trusted Travels</em></h1>
    <p>Premium cab service for Taj Mahal tours, outstation trips and airport transfers. Trusted by thousands of happy travellers.</p>
    <div class="hero-btns">
      <a href="#fleet" class="btn-gold"><i class="fas fa-car"></i> View Fleet</a>
      <a href="https://wa.me/919411061000" target="_blank" class="btn-wa"><i class="fab fa-whatsapp"></i> WhatsApp</a>
    </div>
  </div>
  <div class="scroll-dn"><i class="fas fa-chevron-down"></i></div>
</section>

<section class="sec" id="fleet">
  <div class="container">
    <div class="sec-hd"><span class="tag">Our Fleet</span><h2>Choose Your Ride</h2><p>AC equipped, well-maintained vehicles with professional verified chauffeurs.</p></div>
    <div class="cars-grid">
      <% if (!cars.length) { %>
        <div class="no-cars"><i class="fas fa-car-side"></i><p>Fleet details coming soon. Call <a href="tel:9411061000">9411061000</a></p></div>
      <% } else { cars.forEach(car => {
        const fkm = car.fixedPackage && car.fixedPackage.km;
        const fp = car.fixedPackage && car.fixedPackage.price ? car.fixedPackage.price : (fkm ? fkm * car.pricePerKm - 400 : null);
      %>
      <div class="car-card<%= !car.isAvailable ? ' unavail' : '' %>">
        <div class="car-img-w">
          <img src="<%= car.image %>" alt="<%= car.model %> hire Agra" loading="lazy" onerror="this.src='/images/default-crysta.jpg'">
          <span class="loc-tag"><i class="fas fa-map-marker-alt"></i> <%= car.availableIn.join(', ') %></span>
          <% if (car.ac) { %><span class="ac-tag"><i class="fas fa-snowflake"></i> AC</span><% } %>
          <% if (!car.isAvailable) { %><div class="unavail-ov"><i class="fas fa-clock"></i><span>Unavailable</span></div><% } %>
        </div>
        <div class="car-bd">
          <h3><%= car.model %></h3>
          <p class="car-sub"><%= car.name %> &bull; <i class="fas fa-users"></i> <%= car.seats %> Seats</p>
          <% if (car.description) { %><p class="car-desc"><%= car.description %></p><% } %>
          <div class="price-card">
            <div class="price-row-main">
              <div class="pi"><span class="pi-l">Per KM</span><span class="pi-v">₹<%= car.pricePerKm %></span></div>
              <% if (fkm && fp) { %><div class="pi-div"></div><div class="pi hi"><span class="pi-l"><%= fkm %>km Package</span><span class="pi-v grn">₹<%= fp.toLocaleString('en-IN') %></span></div><div class="pi-div"></div><div class="pi"><span class="pi-l">Extra KM</span><span class="pi-v">₹<%= car.extraKmCharge %>/km</span></div><% } %>
            </div>
            <% if (fkm && fp) { %><p class="price-formula"><i class="fas fa-calculator"></i> <%= fkm %>km = (<%= fkm %> × ₹<%= car.pricePerKm %>) − ₹400 = <strong>₹<%= fp.toLocaleString('en-IN') %></strong> · Extra @ ₹<%= car.extraKmCharge %>/km</p><% } %>
            <p class="toll-ln"><i class="fas fa-road"></i> Toll: <strong><%= car.tollTax %></strong></p>
          </div>
          <% if (car.isAvailable) { %>
          <button class="book-btn" onclick="openBook('<%= car._id %>','<%= car.model.replace(/'/g,"\\'") %>','<%= car.name.replace(/'/g,"\\'") %>',<%= car.pricePerKm %>,<%= fkm||0 %>,<%= fp||0 %>,<%= car.extraKmCharge %>)"><i class="fas fa-calendar-check"></i> Book Now</button>
          <% } else { %>
          <button class="book-btn disabled" disabled><i class="fas fa-clock"></i> Currently Unavailable</button>
          <% } %>
        </div>
      </div>
      <% }) } %>
    </div>
  </div>
</section>

<section class="sec dark-sec" id="why">
  <div class="container">
    <div class="sec-hd light"><span class="tag">Why Choose Us</span><h2>Our Promise</h2></div>
    <div class="why-grid">
      <div class="why-c"><div class="why-ico"><i class="fas fa-shield-alt"></i></div><h3>Safe & Reliable</h3><p>Licensed verified drivers. Regularly serviced vehicles for your safety.</p></div>
      <div class="why-c"><div class="why-ico"><i class="fas fa-clock"></i></div><h3>24/7 Available</h3><p>Airport pickups, early mornings, late nights — we're always ready.</p></div>
      <div class="why-c"><div class="why-ico"><i class="fas fa-rupee-sign"></i></div><h3>No Hidden Charges</h3><p>Transparent pricing. What you see is what you pay.</p></div>
      <div class="why-c"><div class="why-ico"><i class="fas fa-map-marked-alt"></i></div><h3>Local Experts</h3><p>Serving Agra since 2018. Every monument, every shortcut — we know it all.</p></div>
    </div>
  </div>
</section>

<section class="sec" id="contact">
  <div class="container">
    <div class="contact-grid">
      <div>
        <span class="tag">Get In Touch</span>
        <h2 class="contact-h2">Book Your Ride</h2>
        <p class="contact-sub">Available 24 hours, 7 days. Call, WhatsApp or email for instant booking.</p>
        <div class="ci-list">
          <a href="tel:9411061000" class="ci"><div class="ci-ico"><i class="fas fa-phone"></i></div><div><strong>Phone / WhatsApp</strong><span>9411061000</span></div></a>
          <a href="mailto:brajwasitravels.1980@gmail.com" class="ci"><div class="ci-ico"><i class="fas fa-envelope"></i></div><div><strong>Email</strong><span>brajwasitravels.1980@gmail.com</span></div></a>
          <div class="ci"><div class="ci-ico"><i class="fas fa-map-marker-alt"></i></div><div><strong>Location</strong><span>Agra, Uttar Pradesh</span></div></div>
          <a href="/track" class="ci"><div class="ci-ico" style="background:#EBF4FF;color:#1565C0;border-color:rgba(21,101,192,0.2)"><i class="fas fa-map-marker-alt"></i></div><div><strong>Track Your Booking</strong><span>Enter booking ID or phone</span></div></a>
        </div>
        <a href="https://wa.me/919411061000" target="_blank" class="wa-big"><i class="fab fa-whatsapp"></i> Chat on WhatsApp</a>
      </div>
      <div class="eq-form">
        <h3>Quick Enquiry</h3>
        <form id="eqForm">
          <div class="fg"><input type="text" id="eq-name" placeholder="Your Name *" required></div>
          <div class="fg"><input type="tel" id="eq-phone" placeholder="Phone Number *" required></div>
          <div class="fg"><input type="text" id="eq-route" placeholder="From → To *" required></div>
          <div class="fg"><input type="date" id="eq-date" required></div>
          <button type="submit" class="btn-gold full">Send via WhatsApp <i class="fas fa-arrow-right"></i></button>
        </form>
      </div>
    </div>
  </div>
</section>

<footer class="ftr">
  <div class="container ftr-inner">
    <div class="ftr-brand">
      <div class="logo"><div class="logo-ico"><img src="/images/favicon.png" alt="BT" onerror="this.outerHTML='<i class=\'fas fa-car\'></i>'"></div><div><h1>Brajwasi Tour & Travels</h1><span>Est. 2018 · Agra</span></div></div>
      <p>Premium car rental and tour services in Agra.</p>
    </div>
    <div class="ftr-links"><h4>Links</h4><a href="#fleet">Our Fleet</a><a href="#why">Why Us</a><a href="/track">Track Booking</a><a href="#contact">Contact</a></div>
    <div class="ftr-contact"><h4>Contact</h4><p><i class="fas fa-phone"></i> 9411061000</p><p><i class="fas fa-envelope"></i> brajwasitravels.1980@gmail.com</p><p><i class="fas fa-map-marker-alt"></i> Agra, Uttar Pradesh</p></div>
  </div>
  <div class="ftr-bot"><p>© 2024 Brajwasi Tour & Travels, Agra. All rights reserved.</p></div>
</footer>

<a href="https://wa.me/919411061000" class="fl-wa" target="_blank"><i class="fab fa-whatsapp"></i></a>
<button class="fl-chat" onclick="toggleChat()"><i class="fas fa-comments"></i><span id="chat-dot" style="display:none" class="chat-dot"></span></button>

<!-- CHAT WIDGET -->
<div class="chat-w" id="chat-w" style="display:none">
  <div class="cw-hd">
    <div class="cw-hd-l"><div class="cw-av"><img src="/images/favicon.png" alt="BT" onerror="this.outerHTML='<i class=\'fas fa-headset\'></i>'"></div><div><strong>Brajwasi Support</strong><br><small><span class="dot-green"></span> Online</small></div></div>
    <button onclick="toggleChat()" class="cw-cls"><i class="fas fa-times"></i></button>
  </div>
  <div id="cw-start" class="cw-start">
    <p>Start a conversation with us</p>
    <input type="text" id="cw-name" placeholder="Your Name *" maxlength="50">
    <input type="tel" id="cw-phone" placeholder="Phone Number (optional)" maxlength="15">
    <button onclick="startChat()" class="btn-gold" style="width:100%;justify-content:center;border-radius:8px">Start Chat <i class="fas fa-arrow-right"></i></button>
  </div>
  <div id="cw-msgs" style="display:none" class="cw-msgs"></div>
  <div id="cw-inp" style="display:none" class="cw-inp">
    <input type="text" id="cw-txt" placeholder="Type message..." onkeypress="if(event.key==='Enter')sendMsg()" maxlength="500">
    <button onclick="sendMsg()"><i class="fas fa-paper-plane"></i></button>
  </div>
</div>

<!-- BOOKING MODAL -->
<div class="overlay" id="bookModal">
  <div class="modal">
    <button class="m-cls" onclick="closeBook()"><i class="fas fa-times"></i></button>
    <div class="m-hd"><h2><i class="fas fa-calendar-check"></i> Book Your Ride</h2><p id="m-car"></p></div>
    <div class="calc-box">
      <label>Estimate Fare</label>
      <div class="calc-row"><input type="number" id="est-km" placeholder="Distance in KM" min="1" oninput="calcFare()"><span id="calc-out" class="calc-out"></span></div>
      <p id="calc-note" class="calc-note"></p>
    </div>
    <form id="bkForm" onsubmit="submitBook(event)">
      <input type="hidden" id="bk-id">
      <div class="frow2">
        <div class="fg"><label>Full Name *</label><input type="text" id="bk-name" required></div>
        <div class="fg"><label>Phone *</label><input type="tel" id="bk-phone" required></div>
      </div>
      <div class="fg"><label>Email (optional)</label><input type="email" id="bk-email"></div>
      <div class="frow2">
        <div class="fg"><label>Pickup *</label><input type="text" id="bk-pickup" required></div>
        <div class="fg"><label>Drop *</label><input type="text" id="bk-drop" required></div>
      </div>
      <div class="frow2">
        <div class="fg"><label>Date *</label><input type="date" id="bk-date" required></div>
        <div class="fg"><label>Time *</label><input type="time" id="bk-time" required></div>
      </div>
      <div class="fg"><label>Notes</label><textarea id="bk-notes" rows="2"></textarea></div>
      <button type="submit" id="bk-btn" class="btn-gold full"><i class="fas fa-check-circle"></i> Confirm Booking</button>
    </form>
  </div>
</div>

<!-- PAY MODAL -->
<div class="overlay" id="payModal">
  <div class="modal pay-m">
    <div class="pay-top">
      <div class="pay-check"><i class="fas fa-check-circle"></i></div>
      <h2>Booking Received!</h2>
      <div class="pay-bid" id="pay-bid"></div>
      <p>Pay ₹500 advance to confirm. <strong>Fully refundable</strong> if car doesn't arrive.</p>
    </div>
    <div class="pay-amt"><span>Advance</span><strong>₹500</strong></div>
    <div class="pay-apps" id="pay-apps">
      <button class="pa-btn" onclick="payApp('phonepe')"><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/5f/PhonePe_Logo.svg/120px-PhonePe_Logo.svg.png" alt="PhonePe"><span>PhonePe</span></button>
      <button class="pa-btn" onclick="payApp('gpay')"><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/f/f2/Google_Pay_Logo.svg/120px-Google_Pay_Logo.svg.png" alt="GPay"><span>Google Pay</span></button>
      <button class="pa-btn" onclick="payApp('paytm')"><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/24/Paytm_Logo_%28standalone%29.svg/120px-Paytm_Logo_%28standalone%29.svg.png" alt="Paytm"><span>Paytm</span></button>
      <button class="pa-btn" onclick="payApp('bhim')"><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/e/e6/BHIM_logo_%28cropped%29.png/120px-BHIM_logo_%28cropped%29.png" alt="BHIM"><span>BHIM UPI</span></button>
    </div>
    <div class="pay-qr" id="pay-qr" style="display:none">
      <p><i class="fas fa-qrcode"></i> Scan from your phone to pay</p>
      <img id="qr-img" src="" alt="UPI QR">
      <p class="qr-upi">UPI: MRBRAJWASITRAVELS.eazypay@icici</p>
    </div>
    <button class="pay-later" onclick="payLater()"><i class="fas fa-clock"></i> Pay Later – confirm by phone</button>
  </div>
</div>

<!-- SUCCESS MODAL -->
<div class="overlay" id="doneModal">
  <div class="modal done-m">
    <div class="done-ico"><i class="fas fa-check-circle"></i></div>
    <h2>All Done!</h2>
    <div class="done-bid" id="done-bid"></div>
    <p>Our team will call you shortly at <strong id="done-phone"></strong></p>
    <p style="margin-top:8px;font-size:13px;color:#666">Track your booking status anytime on <a href="/track" style="color:#B8731A">Track Booking</a></p>
    <div class="done-acts">
      <a id="wa-link" href="#" target="_blank" class="btn-gold"><i class="fab fa-whatsapp"></i> WhatsApp</a>
      <a href="/track" class="btn-outline"><i class="fas fa-map-marker-alt"></i> Track</a>
      <button onclick="closeDone()" class="btn-outline">Close</button>
    </div>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
