<!-- HERO -->
<section class="hero">
  <div class="hero-bg" id="heroBg"></div>
  <div class="hero-overlay"></div>
  <div class="container hero-content">
    <div class="hero-badge"><i class="fas fa-map-marker-alt"></i> Agra's Trusted Cab Service</div>
    <h1 class="hero-title">Explore Agra<br><em>In Comfort & Style</em></h1>
