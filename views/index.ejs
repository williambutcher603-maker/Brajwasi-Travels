<!-- QR code library -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

<script>
// ═══════════════════════════════════════════════════════════
// BRAJWASI TRAVELS - MAIN JS
// ALL code runs inline after HTML is parsed (script at bottom of body)
// NO DOMContentLoaded needed - DOM is already ready here
// ═══════════════════════════════════════════════════════════

// ── State ──────────────────────────────────────────────────
var _carData = {}, _bookingId = null, _payData = null;
var _chatPhone = localStorage.getItem('bt_phone') || '';
var _chatName  = localStorage.getItem('bt_name')  || '';
var _lastMsgTs = null, _chatPoll = null;
var _session   = null;
var _fbRating  = 0;

// ── Scroll ─────────────────────────────────────────────────
window.addEventListener('scroll', function() {
  var h = document.getElementById('header');
  if (h) h.classList.toggle('scrolled', window.scrollY > 50);
});
document.getElementById('heroBg') && document.getElementById('heroBg').classList.add('loaded');

// ── Push Notifications ─────────────────────────────────────
if ('serviceWorker' in navigator && 'PushManager' in window) {
  navigator.serviceWorker.register('/sw.js').then(function() {
    if (Notification.permission === 'default') {
      setTimeout(function() {
        var nb = document.getElementById('notif-bar');
        if (nb) nb.style.display = 'flex';
      }, 5000);
    }
  }).catch(function() {});
}
function requestPush() {
  var nb = document.getElementById('notif-bar');
  if (nb) nb.style.display = 'none';
  Notification.requestPermission().then(function(p) {
    if (p !== 'granted') return;
    navigator.serviceWorker.ready.then(function(reg) {
      fetch('/vapid-public-key').then(function(r) { return r.json(); }).then(function(d) {
        if (!d.publicKey) return;
        var pad = '='.repeat((4 - d.publicKey.length % 4) % 4);
        var raw = atob((d.publicKey + pad).replace(/-/g, '+').replace(/_/g, '/'));
        var key = Uint8Array.from(raw, function(c) { return c.charCodeAt(0); });
        reg.pushManager.subscribe({ userVisibleOnly: true, applicationServerKey: key }).then(function(sub) {
          var sd = JSON.parse(JSON.stringify(sub));
          sd.role = 'customer'; sd.phone = _chatPhone || '';
          fetch('/subscribe', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(sd) });
          showToast('Notifications enabled!', 'success');
        });
      });
    });
  });
}
function _resubPhone(phone) {
  if (!('serviceWorker' in navigator) || Notification.permission !== 'granted') return;
  navigator.serviceWorker.ready.then(function(reg) {
    reg.pushManager.getSubscription().then(function(sub) {
      if (!sub) return;
      var sd = JSON.parse(JSON.stringify(sub));
      sd.role = 'customer'; sd.phone = phone;
      fetch('/subscribe', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(sd) });
    });
  });
}

// ── Modal helpers ──────────────────────────────────────────
function showModal(id) {
  var el = document.getElementById(id);
  if (el) { el.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
}
function hideModal(id) {
  var el = document.getElementById(id);
  if (el) { el.style.display = 'none'; document.body.style.overflow = ''; }
}
// Overlay click to close
['bookingModal','paymentModal','successModal','feedbackModal','loginModal'].forEach(function(id) {
  var el = document.getElementById(id);
  if (el) el.addEventListener('click', function(e) { if (e.target === el) hideModal(id); });
});
// Close buttons
document.getElementById('closeBookingBtn').addEventListener('click', function() { hideModal('bookingModal'); });
document.getElementById('closePayBtn').addEventListener('click', function() { hideModal('paymentModal'); });
document.getElementById('closeSuccessBtn').addEventListener('click', function() { hideModal('successModal'); });
document.getElementById('closeFeedbackBtn').addEventListener('click', function() { hideModal('feedbackModal'); });
document.getElementById('closeLoginBtn').addEventListener('click', function() { hideModal('loginModal'); });

// ── BOOK NOW buttons (data-* attributes, no inline JS needed) ─
document.querySelectorAll('.book-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var d = btn.dataset;
    openBooking(d.carid, d.model, +d.ppk, +d.fkm, +d.fp, +d.ekc);
  });
});
function openBooking(id, model, ppk, fkm, fp, ekc) {
  _carData = { id: id, model: model, ppk: ppk, fkm: fkm, fp: fp, ekc: ekc };
  document.getElementById('bookCarId').value = id;
  document.getElementById('modalCarName').textContent = model;
  document.getElementById('estKm').value = '';
  document.getElementById('calcResult').style.display = 'none';
  document.getElementById('bkDate').min = new Date().toISOString().split('T')[0];
  if (_session) {
    document.getElementById('bkEmail').value = _session.email;
    if (!document.getElementById('bkName').value) document.getElementById('bkName').value = _session.name || '';
  }
  showModal('bookingModal');
}

// ── Price calculator ───────────────────────────────────────
document.getElementById('estKm').addEventListener('input', function() {
  var km = parseInt(this.value);
  var d = _carData;
  if (!km || km <= 0) { document.getElementById('calcResult').style.display = 'none'; return; }
  var total = 0, bd = '';
  if (d.fkm && d.fp && km <= d.fkm) { total = d.fp; bd = 'Fixed ' + d.fkm + 'km Package'; }
  else if (d.fkm && d.fp) { var ex = km - d.fkm; total = d.fp + ex * d.ekc; bd = d.fkm + 'km: \u20b9' + d.fp + ' + Extra ' + ex + 'km \u00d7 \u20b9' + d.ekc; }
  else { total = km * d.ppk; bd = km + 'km \u00d7 \u20b9' + d.ppk + '/km'; }
  document.getElementById('calcBreakdown').textContent = bd;
  document.getElementById('calcTotal').textContent = 'Estimated Fare: \u20b9' + total.toLocaleString('en-IN') + ' (excl. toll)';
  document.getElementById('calcResult').style.display = 'block';
});

// ── Booking form submit ────────────────────────────────────
document.getElementById('bookingForm').addEventListener('submit', function(e) {
  e.preventDefault();
  var km = document.getElementById('estKm').value;
  if (!km || +km < 1) { showToast('Please enter estimated distance in KM', 'error'); document.getElementById('estKm').focus(); return; }
  if (!_session) { showModal('loginModal'); return; }
  var btn = document.getElementById('bookSubmitBtn');
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...'; btn.disabled = true;
  fetch('/api/book', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      carId: document.getElementById('bookCarId').value,
      customerName: document.getElementById('bkName').value,
      customerPhone: document.getElementById('bkPhone').value,
      pickupLocation: document.getElementById('bkPickup').value,
      dropLocation: document.getElementById('bkDrop').value,
      journeyDate: document.getElementById('bkDate').value,
      journeyTime: document.getElementById('bkTime').value,
      estimatedKm: km,
      notes: document.getElementById('bkNotes').value
    })
  }).then(function(r) { return r.json(); }).then(function(d) {
    if (d.success) {
      _bookingId = d.bookingId;
      hideModal('bookingModal');
      document.getElementById('bookingForm').reset();
      openPayModal(d.bookingId);
    } else if (d.loginRequired) {
      showModal('loginModal');
    } else {
      showToast(d.error || 'Booking failed. Call 9411061000', 'error');
    }
  }).catch(function() { showToast('Network error. Call 9411061000', 'error'); })
  .finally(function() { btn.innerHTML = '<i class="fas fa-check-circle"></i> Confirm Booking'; btn.disabled = false; });
});

// ── Payment ────────────────────────────────────────────────
function openPayModal(bookingId) {
  document.getElementById('payBookingId').textContent = 'Booking ID: ' + bookingId;
  fetch('/api/payment/' + bookingId).then(function(r) { return r.json(); }).then(function(d) {
    if (d.error) { showSuccessModal(bookingId); return; }
    _payData = d;
    document.getElementById('upiIdTxt').textContent = 'UPI: ' + d.upiId;
    document.getElementById('upiPhonePe').onclick = function() { window.location.href = d.phonepe; };
    document.getElementById('upiGPay').onclick    = function() { window.location.href = d.gpay; };
    document.getElementById('upiPaytm').onclick   = function() { window.location.href = d.paytm; };
    document.getElementById('upiAnyBtn').onclick  = function() { window.location.href = d.upiUrl; };
    setTimeout(function() { showToast('If app did not open, try another or scan QR', 'info'); }, 2000);
    var isMobile = /Android|iPhone|iPad/i.test(navigator.userAgent);
    document.getElementById('upiQrWrap').style.display = isMobile ? 'none' : 'block';
    if (!isMobile && window.QRCode) {
      var canvas = document.getElementById('upiQR');
      var ctx = canvas.getContext('2d'); ctx.clearRect(0, 0, 176, 176);
      var div = document.createElement('div');
      new QRCode(div, { text: d.qrData, width: 176, height: 176, colorDark: '#1A1208', colorLight: '#FFFFFF', correctLevel: QRCode.CorrectLevel.M });
      setTimeout(function() {
        var img = div.querySelector('img');
        if (img) { var i = new Image(); i.onload = function() { ctx.drawImage(i, 0, 0, 176, 176); }; i.src = img.src; }
      }, 300);
    }
    showModal('paymentModal');
  }).catch(function() { showSuccessModal(bookingId); });
}
document.getElementById('paidBtn').addEventListener('click', function() {
  if (_bookingId) fetch('/api/payment/' + _bookingId + '/confirm', { method: 'POST' }).catch(function() {});
  hideModal('paymentModal');
  showSuccessModal(_bookingId);
});
function showSuccessModal(bookingId) {
  document.getElementById('successBookingId').textContent = bookingId;
  var tl = document.getElementById('trackLink');
  if (tl) tl.href = '/track?bookingId=' + bookingId;
  showModal('successModal');
}

// ── OTP Login ──────────────────────────────────────────────
fetch('/api/auth/me').then(function(r) { return r.json(); }).then(function(d) {
  if (d.loggedIn) { _session = d; renderLoginBar(d); }
  else renderLoginBar(null);
