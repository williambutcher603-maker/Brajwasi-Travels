<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cab Service in Agra | Brajwasi Tour & Travels – Taxi for Taj Mahal, Outstation</title>
<meta name="description" content="Best cab service in Agra since 2018. Book cars now for Taj Mahal tours, Fatehpur Sikri, Agra to Delhi, Jaipur, Lucknow. 24/7 available. Call 9411061000.">
<meta name="keywords" content="cab service in agra, taxi in agra, agra cab booking, taj mahal cab, agra to delhi taxi, tour and travels agra, innova crysta agra, outstation cab agra, brajwasi travels">
<meta name="robots" content="index, follow">
<meta property="og:title" content="Brajwasi Travels Agra | Tour and Travels in Agra">
<meta property="og:description" content="Trusted cab service in Agra since 2018. Book Toyota Crysta and more for Taj Mahal tours and outstation trips.">
<meta property="og:type" content="website">
<meta name="google-site-verification" content="25vVIruxvnPxmS12tcZykCuX5MjQ3eVOnWd74_PNADg">
<link rel="manifest" href="/manifest.json">
<link rel="icon" type="image/png" href="/images/favicon.png">
<link rel="apple-touch-icon" href="/images/favicon.png">
<meta name="theme-color" content="#B8780A">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link rel="stylesheet" href="/css/main.css">
<style>
/* ── Testimonials ── */
.testimonials-section{background:var(--bg);}
.testi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:22px;}
.testi-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r-lg);padding:24px;transition:var(--ease);}
.testi-card:hover{border-color:rgba(184,120,10,.35);transform:translateY(-3px);box-shadow:var(--shadow);}
.testi-stars{margin-bottom:12px;display:flex;gap:3px;font-size:15px;}
.testi-msg{font-size:14px;color:var(--muted);line-height:1.7;margin-bottom:16px;font-style:italic;}
.testi-author{display:flex;align-items:center;gap:10px;}
.testi-avatar{width:36px;height:36px;background:linear-gradient(135deg,var(--gold-l),var(--gold-d));border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:14px;flex-shrink:0;}
.testi-name{font-size:14px;font-weight:700;color:var(--text);}
.testi-date{font-size:11px;color:var(--light);}
/* ── Star picker ── */
.star-picker{display:flex;gap:6px;margin-bottom:6px;}
.star-picker i{font-size:28px;color:#E8DDD0;cursor:pointer;transition:color .15s;}
.star-picker i.lit{color:#F59E0B;}
/* ── Login bar ── */
#loginBar{display:flex;align-items:center;gap:8px;}
/* Chat real-time animations */
@keyframes chatBounce {
  0%   { transform: scale(0); }
  60%  { transform: scale(1.2); }
  100% { transform: scale(1); }
}
@keyframes fadeSlideUp {
  from { opacity:0; transform:translateY(6px); }
  to   { opacity:1; transform:translateY(0); }
}
@keyframes chatPulse {
  0%,100% { box-shadow: 0 4px 20px rgba(26,86,219,.4); }
  50%      { box-shadow: 0 4px 28px rgba(26,86,219,.8), 0 0 0 8px rgba(26,86,219,.15); }
}
.chat-has-unread { animation: chatPulse 1.8s ease infinite; }
@keyframes typingDot {
  0%,60%,100% { opacity:.3; transform:translateY(0); }
  30%          { opacity:1;  transform:translateY(-3px); }
}
</style>
</head>
<body>

<!-- Push bar -->
<div id="notif-bar" class="notif-bar" style="display:none">
  <span><i class="fas fa-bell"></i> Get booking updates on your phone</span>
  <button onclick="requestPush()">Enable</button>
  <button class="close-btn" onclick="document.getElementById('notif-bar').style.display='none'"><i class="fas fa-times"></i></button>
</div>

<!-- Header -->
<header class="header" id="header">
  <nav class="nav container">
    <a class="logo" href="/">
      <div class="logo-icon"><img src="/images/favicon.png" alt="BT" onerror="this.style.display='none';this.parentNode.innerHTML='<i class=\'fas fa-car\'></i>'"></div>
      <div><h1>Brajwasi Tour & Travels</h1><span>Est. 2018 · Agra</span></div>
    </a>
    <div class="nav-links">
      <a href="#cars">Our Fleet</a>
      <a href="#why-us">Why Us</a>
      <a href="#testimonials">Reviews</a>
      <a href="/partner">Partner With Us</a>
      <a href="/track">Track Booking</a>
      <a href="/payment">My Payments</a>
      <a href="#contact">Contact</a>
      <div id="loginBar"></div>
      <a href="tel:9411061000" class="call-btn"><i class="fas fa-phone"></i> Call Now</a>
    </div>
    <button class="hamburger" id="hamburger" onclick="document.getElementById('mob-menu').classList.toggle('open')"><i class="fas fa-bars"></i></button>
  </nav>
  <div class="mobile-menu" id="mob-menu">
    <a href="#cars" onclick="document.getElementById('mob-menu').classList.remove('open')"><i class="fas fa-car" style="color:var(--gold);margin-right:8px"></i>Our Fleet</a>
    <a href="#why-us" onclick="document.getElementById('mob-menu').classList.remove('open')"><i class="fas fa-star" style="color:var(--gold);margin-right:8px"></i>Why Us</a>
    <a href="#testimonials" onclick="document.getElementById('mob-menu').classList.remove('open')"><i class="fas fa-star" style="color:var(--gold);margin-right:8px"></i>Reviews</a>
    <a href="/track" onclick="document.getElementById('mob-menu').classList.remove('open')"><i class="fas fa-map-marker-alt" style="color:var(--gold);margin-right:8px"></i>Track Booking</a>
    <a href="/partner" onclick="document.getElementById('mob-menu').classList.remove('open')"><i class="fas fa-handshake" style="color:var(--gold);margin-right:8px"></i>Partner With Us</a>
    <a href="#contact" onclick="document.getElementById('mob-menu').classList.remove('open')"><i class="fas fa-envelope" style="color:var(--gold);margin-right:8px"></i>Contact</a>
    <a href="/payment" onclick="document.getElementById('mob-menu').classList.remove('open')"><i class="fas fa-rupee-sign" style="color:var(--gold);margin-right:8px"></i>My Payments</a>
    <div id="mobileLoginBar" style="padding:10px 20px;border-top:1px solid rgba(255,255,255,.1)"></div>
    <a href="tel:9411061000"><i class="fas fa-phone" style="color:var(--gold);margin-right:8px"></i>9411061000</a>
  </div>
</header>

<!-- Hero -->
<section class="hero">
  <div class="hero-bg" id="heroBg"></div>
  <div class="hero-overlay"></div>
  <div class="container hero-content">
    <div class="hero-badge"><i class="fas fa-map-marker-alt"></i> Agra's Trusted Cab Service</div>
    <h1 class="hero-title">Explore Agra<br><em>In Comfort & Style</em></h1>
    <p class="hero-sub">Premium cab services for Taj Mahal tours, outstation trips, and airport transfers. Your journey, our passion.</p>
    <div class="hero-actions">
      <a href="#cars" class="btn-primary"><i class="fas fa-car"></i> Explore Fleet</a>
      <a href="tel:9411061000" class="btn-outline"><i class="fas fa-phone"></i> 9411061000</a>
    </div>
    <div class="hero-stats">
      <div class="stat"><span>2018</span><em>Est. in Agra</em></div>
      <div class="stat-div"></div>
      <div class="stat"><span>24/7</span><em>Service</em></div>
      <div class="stat-div"></div>
      <div class="stat"><span>Agra</span><em>Based In</em></div>
    </div>
  </div>
  <div class="scroll-ind"><i class="fas fa-chevron-down"></i></div>
</section>

<!-- Fleet -->
<section class="section" id="cars">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Our Fleet</span>
      <h2 class="section-title">Choose Your Ride</h2>
      <p>Well-maintained AC vehicles driven by professional, experienced chauffeurs.</p>
    </div>
    <div class="cars-grid">
      <% if(!cars.length){ %>
        <div class="no-cars"><i class="fas fa-car-side"></i><p>Fleet coming soon. Call <a href="tel:9411061000">9411061000</a></p></div>
      <% } else { cars.forEach(function(car){ var fkm=car.fixedPackage&&car.fixedPackage.km?car.fixedPackage.km:0; var fp=car.fixedPackage&&car.fixedPackage.price?car.fixedPackage.price:0; %>
      <div class="car-card">
        <div class="car-img-wrap">
          <img src="<%= car.image %>" alt="<%= car.model %>" loading="lazy" onerror="this.src='/images/default-crysta.jpeg'">
          <div class="car-badge"><%= car.availableIn.join(', ') %></div>
          <% if(car.ac){ %><div class="ac-badge"><i class="fas fa-snowflake"></i> AC</div><% } %>
        </div>
        <div class="car-body">
          <div class="car-header">
            <div><h3><%= car.model %></h3><p class="car-brand"><%= car.name %></p></div>
            <div class="car-seats"><i class="fas fa-users"></i> <%= car.seats %> Seats</div>
          </div>
          <p class="car-desc"><%= car.description || 'Comfortable, reliable, professionally driven.' %></p>
          <div class="car-pricing">
            <% if(fkm>0){ %>
            <div class="cp-row"><span class="cp-label"><i class="fas fa-box" style="color:var(--gold)"></i> Fixed <%= fkm %>km Package</span><span class="cp-val green">₹<%= fp.toLocaleString('en-IN') %></span></div>
            <div class="cp-row"><span class="cp-label"><i class="fas fa-plus-circle" style="color:var(--gold)"></i> Extra km</span><span class="cp-val">₹<%= car.extraKmCharge %>/km</span></div>
            <% } else { %>
            <div class="cp-row"><span class="cp-label"><i class="fas fa-road" style="color:var(--gold)"></i> Per km rate</span><span class="cp-val">₹<%= car.pricePerKm %>/km</span></div>
            <% } %>
            <div class="cp-row"><span class="cp-label"><i class="fas fa-toll"></i> Toll tax</span><span class="cp-val small"><%= car.tollTax %></span></div>
          </div>
          <button class="book-btn" type="button" data-carid="<%= car._id %>" data-model="<%= car.model.replace(/\"/g,'&quot;') %>" data-ppk="<%= car.pricePerKm %>" data-fkm="<%= fkm %>" data-fp="<%= fp %>" data-ekc="<%= car.extraKmCharge %>">
            <i class="fas fa-calendar-check"></i> Book Now
          </button>
        </div>
      </div>
      <% }); } %>
    </div>
  </div>
</section>

<!-- Why Us -->
<section class="section why-section" id="why-us">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Our Promise</span>
      <h2 class="section-title">Why Brajwasi Tour & Travels?</h2>
    </div>
    <div class="features-grid">
      <div class="feature-card"><div class="feature-icon"><i class="fas fa-shield-alt"></i></div><h3>Safe & Reliable</h3><p>Licensed, verified drivers. Regularly serviced vehicles for your peace of mind.</p></div>
      <div class="feature-card"><div class="feature-icon"><i class="fas fa-clock"></i></div><h3>24/7 Available</h3><p>Round-the-clock service for airport pickups, late-night returns, and emergency travel.</p></div>
      <div class="feature-card"><div class="feature-icon"><i class="fas fa-rupee-sign"></i></div><h3>Transparent Pricing</h3><p>No hidden charges. Fixed packages and clear per-km rates. What you see is what you pay.</p></div>
      <div class="feature-card"><div class="feature-icon"><i class="fas fa-map-marked-alt"></i></div><h3>Live Tracking</h3><p>Track your cab's live location from booking confirmation till arrival. Full transparency.</p></div>
    </div>
  </div>
</section>

<!-- Testimonials -->
<section class="section testimonials-section" id="testimonials">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">What Customers Say</span>
      <h2 class="section-title">Real Reviews From Real Travellers</h2>
      <p>Honest feedback from customers who travelled with us. Every review is verified.</p>
    </div>
    <div class="testi-grid">
      <% if(!testimonials||!testimonials.length){ %>
      <div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--muted)">
        <i class="fas fa-comment-slash" style="font-size:36px;color:var(--border);display:block;margin-bottom:12px"></i>
        <p>No reviews yet. Be the first to share your experience!</p>
      </div>
      <% } else { testimonials.forEach(function(t){ %>
      <div class="testi-card">
        <div class="testi-stars"><% for(var i=1;i<=5;i++){ %><i class="fas fa-star" style="color:<%= i<=t.rating?'#F59E0B':'#E8DDD0' %>"></i><% } %></div>
        <p class="testi-msg">"<%= t.message %>"</p>
        <div class="testi-author">
          <div class="testi-avatar"><%= t.name.charAt(0).toUpperCase() %></div>
          <div><div class="testi-name"><%= t.name %></div><div class="testi-date"><%= new Date(t.createdAt).toLocaleDateString('en-IN',{month:'short',year:'numeric'}) %></div></div>
        </div>
      </div>
      <% }); } %>
    </div>
    <div style="text-align:center;margin-top:36px">
      <button id="openFeedbackBtn" class="btn-primary" style="display:inline-flex;align-items:center;gap:8px">
        <i class="fas fa-star"></i> Share Your Experience
      </button>
    </div>
  </div>
</section>

<!-- Contact -->
<section class="contact-section section" id="contact">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info">
        <span class="section-tag">Get In Touch</span>
        <h2>Book Your Ride Today</h2>
        <p>Available 24 hours, 7 days a week. Call, WhatsApp, or chat below.</p>
        <div class="contact-items">
          <a href="tel:9411061000" class="contact-item"><div class="ci-icon"><i class="fas fa-phone"></i></div><div><strong>Call / WhatsApp</strong><span>9411061000</span></div></a>
          <a href="mailto:brajwasitravels.1980@gmail.com" class="contact-item"><div class="ci-icon"><i class="fas fa-envelope"></i></div><div><strong>Email</strong><span>brajwasitravels.1980@gmail.com</span></div></a>
          <div class="contact-item"><div class="ci-icon"><i class="fas fa-map-marker-alt"></i></div><div><strong>Base Location</strong><span>Agra, Uttar Pradesh</span></div></div>
          <a href="https://wa.me/919411061000" target="_blank" class="wa-btn"><i class="fab fa-whatsapp"></i> Chat on WhatsApp</a>
        </div>
      </div>
      <div>
        <div class="quick-form">
          <h3>Quick Enquiry</h3>
          <form id="enquiryForm">
            <div class="form-group"><input type="text" id="eq-name" placeholder="Your Name *" required></div>
            <div class="form-group"><input type="tel" id="eq-phone" placeholder="Phone Number *" required></div>
            <div class="form-group"><input type="text" id="eq-route" placeholder="From → To *" required></div>
            <div class="form-group"><input type="date" id="eq-date" required></div>
            <button type="submit" class="btn-primary full-btn">Send Enquiry <i class="fas fa-arrow-right"></i></button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a class="logo" href="/"><div class="logo-icon"><img src="/images/favicon.png" alt="BT" onerror="this.style.display='none';this.parentNode.innerHTML='<i class=\'fas fa-car\'></i>'"></div><div><h1>Brajwasi Tour & Travels</h1><span>Est. 2018 · Agra</span></div></a>
      <p>Premium car rental in Agra. Trusted by thousands of tourists and business travellers for safe, comfortable journeys.</p>
    </div>
    <div class="footer-links">
      <h4>Quick Links</h4>
      <a href="#cars">Our Fleet</a><a href="#why-us">Why Us</a><a href="#testimonials">Reviews</a>
      <a href="/track">Track Booking</a>
      <a href="/payment">My Payments</a><a href="/partner">Partner With Us</a><a href="#contact">Contact</a>
    </div>
    <div class="footer-contact">
      <h4>Contact</h4>
      <p><i class="fas fa-phone"></i> 9411061000</p>
      <p><i class="fas fa-envelope"></i> brajwasitravels.1980@gmail.com</p>
      <p><i class="fas fa-map-marker-alt"></i> Agra, Uttar Pradesh</p>
    </div>
  </div>
  <div class="footer-bottom"><p>© 2024 Brajwasi Tour & Travels · All rights reserved · Agra's Trusted Car Rental</p></div>
</footer>

<!-- Floating WhatsApp -->
<a href="https://wa.me/919411061000" class="float-wa" target="_blank"><i class="fab fa-whatsapp"></i></a>

<!-- ═══ CHAT WIDGET ═══ -->
<div id="chatFloat" style="position:fixed;bottom:90px;left:20px;z-index:99991;pointer-events:auto">
  <button id="chatBtn" style="position:relative;width:54px;height:54px;border-radius:50%;background:linear-gradient(135deg,#1a56db,#0e3eb3);color:#fff;border:none;cursor:pointer;font-size:22px;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(26,86,219,.4);pointer-events:auto;transition:transform .2s">
    <i class="fas fa-comment-dots" id="chatBtnIcon"></i>
    <span id="chatBadge" style="display:none;position:absolute;top:-4px;right:-4px;background:#ef4444;color:#fff;border-radius:20px;font-size:10px;font-weight:800;min-width:20px;height:20px;padding:0 5px;align-items:center;justify-content:center;border:2px solid #fff;font-family:DM Sans,sans-serif;animation:chatBounce .4s ease"></span>
  </button>
  <div id="chatPreview" style="display:none;position:absolute;bottom:64px;left:0;background:#1a1a2e;color:#fff;border-radius:12px;padding:10px 14px;font-size:12px;font-weight:600;white-space:nowrap;box-shadow:0 4px 20px rgba(0,0,0,.3);max-width:220px;animation:fadeSlideUp .3s ease;pointer-events:none">
    <span id="chatPreviewText"></span>
    <div style="position:absolute;bottom:-6px;left:18px;width:12px;height:12px;background:#1a1a2e;transform:rotate(45deg);border-radius:2px"></div>
  </div>
</div>
<div id="chatWindow" style="position:fixed;bottom:158px;left:20px;width:340px;background:#fff;border:1px solid #E8DDD0;border-radius:18px;box-shadow:0 16px 50px rgba(26,18,8,.18);z-index:99992;display:none;flex-direction:column;overflow:hidden;max-height:520px">
  <div style="background:linear-gradient(135deg,#1a56db,#0e3eb3);padding:14px 18px;display:flex;justify-content:space-between;align-items:center">
    <div><div style="color:#fff;font-size:14px;font-weight:700"><i class="fas fa-headset" style="margin-right:5px"></i>Live Support</div><div style="color:rgba(255,255,255,.75);font-size:11px;margin-top:2px"><span style="width:8px;height:8px;background:#4ade80;border-radius:50%;display:inline-block;margin-right:4px"></span>Brajwasi · Fast replies</div></div>
    <button id="chatCloseBtn" style="background:none;border:none;color:rgba(255,255,255,.8);cursor:pointer;font-size:16px"><i class="fas fa-times"></i></button>
  </div>
  <div id="chatSetup" style="padding:20px;background:#fff">
    <p style="color:#7A6A55;font-size:12px;margin-bottom:14px">Enter your details to chat with us.</p>
    <input type="text" id="chatNameIn" placeholder="Your Name *" style="width:100%;background:#F8F5F0;border:1px solid #E8DDD0;color:#1A1208;padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:10px;outline:none;font-family:inherit">
    <input type="tel" id="chatPhoneIn" placeholder="Your Phone *" style="width:100%;background:#F8F5F0;border:1px solid #E8DDD0;color:#1A1208;padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:10px;outline:none;font-family:inherit">
    <button id="chatStartBtn" style="width:100%;padding:11px;background:linear-gradient(135deg,#1a56db,#0e3eb3);color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit"><i class="fas fa-comment"></i> Start Chat</button>
  </div>
  <div id="chatBody" style="display:none;flex-direction:column;flex:1;overflow:hidden">
    <div id="chatMsgs" style="flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:8px;min-height:200px;background:#F8F5F0">
      <div id="chatEmpty" style="text-align:center;color:#A0917E;font-size:13px;padding:20px"><i class="fas fa-comment-slash" style="font-size:24px;display:block;margin-bottom:8px;color:#ccc"></i>No messages yet. Say hello!</div>
    </div>
    <div style="display:flex;gap:8px;padding:12px;border-top:1px solid #E8DDD0;background:#fff">
      <input type="text" id="chatIn" placeholder="Type a message..." style="flex:1;background:#F8F5F0;border:1px solid #E8DDD0;color:#1A1208;padding:9px 13px;border-radius:20px;font-size:13px;outline:none;font-family:inherit">
      <button id="chatSendBtn" style="width:36px;height:36px;background:linear-gradient(135deg,#1a56db,#0e3eb3);border:none;border-radius:50%;color:#fff;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0"><i class="fas fa-paper-plane"></i></button>
    </div>
  </div>
</div>

<!-- ═══ BOOKING MODAL ═══ -->
<div id="bookingModal" style="position:fixed;inset:0;background:rgba(26,18,8,.6);backdrop-filter:blur(6px);z-index:10000;display:none;align-items:center;justify-content:center;padding:16px">
  <div style="background:#fff;border:1px solid #E8DDD0;border-radius:20px;padding:30px;width:100%;max-width:620px;max-height:92vh;overflow-y:auto;position:relative;box-shadow:0 24px 80px rgba(26,18,8,.3)">
    <button id="closeBookingBtn" style="position:absolute;top:16px;right:16px;background:#F0EBE3;border:1px solid #E8DDD0;color:#7A6A55;width:32px;height:32px;border-radius:8px;cursor:pointer;font-size:14px"><i class="fas fa-times"></i></button>
    <div style="margin-bottom:20px"><h2 style="font-family:'Playfair Display',serif;font-size:24px;color:#1A1208">Book Your Ride</h2><p id="modalCarName" style="font-size:14px;color:#B8780A;margin-top:4px;font-weight:600"></p></div>
    <div style="background:#FFF8EC;border:1px solid rgba(184,120,10,.2);border-radius:12px;padding:16px;margin-bottom:18px">
      <div style="display:flex;align-items:center;gap:12px">
        <label style="font-size:13px;color:#7A6A55;white-space:nowrap;font-weight:600"><i class="fas fa-road" style="color:#B8780A;margin-right:5px"></i>Distance (km) <span style="color:#C0392B">*</span></label>
        <input type="number" id="estKm" placeholder="Enter KM" min="1" required style="flex:1;background:#fff;border:1px solid #E8DDD0;color:#1A1208;padding:9px 12px;border-radius:8px;font-size:14px;outline:none;font-family:inherit">
      </div>
