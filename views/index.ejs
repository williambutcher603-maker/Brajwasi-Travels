      <div class="calc-row">
        <label><i class="fas fa-road" style="color:var(--gold);margin-right:5px"></i>Estimated Distance (km) <span style="color:var(--red)">*</span></label>
        <input type="number" id="estKm" placeholder="Enter KM *" min="1" required>
      </div>
      <div class="calc-result" id="calcResult" style="display:none">
        <div class="calc-breakdown" id="calcBreakdown"></div>
        <div class="calc-total" id="calcTotal"></div>
      </div>
