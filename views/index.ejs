<script src="/js/main.js"></script>
<script>
// ============ CHAT WIDGET ============
let chatPhone = localStorage.getItem('bt_chat_phone') || '';
let chatName = localStorage.getItem('bt_chat_name') || '';
let lastMsgTime = null;
let chatPollInterval = null;

function toggleChat() {
  const win = document.getElementById('chatWindow');
  win.classList.toggle('open');
  if (win.classList.contains('open')) {
    if (chatPhone) showChatBody();
    startPolling();
  } else {
    stopPolling();
  }
}

function showChatBody() {
  document.getElementById('chatSetup').style.display = 'none';
  const body = document.getElementById('chatBody');
  body.style.display = 'flex';
  loadChatHistory();
}

async function startChat() {
  const name = document.getElementById('chatName').value.trim();
  const phone = document.getElementById('chatPhone').value.trim();
  if (!name || !phone) { alert('Please enter your name and phone number'); return; }
  chatName = name;
  chatPhone = phone;
  localStorage.setItem('bt_chat_name', name);
  localStorage.setItem('bt_chat_phone', phone);
  showChatBody();
}

async function loadChatHistory() {
  if (!chatPhone) return;
  try {
    const resp = await fetch('/api/chat/' + encodeURIComponent(chatPhone) + '/history');
    const data = await resp.json();
    const msgs = document.getElementById('chatMessages');
    msgs.innerHTML = '';
    if (data.messages.length === 0) {
      msgs.innerHTML = '<div class="chat-empty"><i class="fas fa-comment-slash" style="font-size:28px;display:block;margin-bottom:8px"></i>No messages yet.<br>Send us a message!</div>';
    } else {
      data.messages.forEach(m => appendChatMsg(m, false));
    }
    if (data.messages.length > 0) {
      lastMsgTime = data.messages[data.messages.length - 1].createdAt;
    }
    scrollChatToBottom();
  } catch(e) {}
}

function appendChatMsg(msg, scroll = true) {
  const msgs = document.getElementById('chatMessages');
  const emptyEl = msgs.querySelector('.chat-empty');
  if (emptyEl) emptyEl.remove();
  
  const div = document.createElement('div');
  div.className = 'chat-msg ' + (msg.fromCustomer ? 'from-me' : 'from-admin');
  const time = new Date(msg.createdAt).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' });
  div.innerHTML = `${msg.message}<div class="chat-msg-time">${msg.fromCustomer ? 'You' : 'Brajwasi Travels'} · ${time}</div>`;
  msgs.appendChild(div);
  if (scroll) scrollChatToBottom();
}

function scrollChatToBottom() {
  const msgs = document.getElementById('chatMessages');
  msgs.scrollTop = msgs.scrollHeight;
}

async function sendChatMsg() {
  const input = document.getElementById('chatInput');
  const msg = input.value.trim();
  if (!msg || !chatPhone) return;
  input.value = '';
  
  // Optimistic UI
  const tempMsg = { message: msg, fromCustomer: true, createdAt: new Date().toISOString() };
  appendChatMsg(tempMsg);
  
  try {
    await fetch('/api/chat/send', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ customerName: chatName, customerPhone: chatPhone, message: msg })
    });
    lastMsgTime = new Date().toISOString();
  } catch(e) {}
}

async function pollForReplies() {
  if (!chatPhone || !document.getElementById('chatWindow').classList.contains('open')) return;
  try {
    const since = lastMsgTime || new Date(0).toISOString();
    const resp = await fetch('/api/chat/' + encodeURIComponent(chatPhone) + '/updates?since=' + encodeURIComponent(since));
    const data = await resp.json();
    const newAdminMsgs = data.messages.filter(m => !m.fromCustomer);
    newAdminMsgs.forEach(m => {
      appendChatMsg(m);
      lastMsgTime = m.createdAt;
    });
  } catch(e) {}
}

function startPolling() {
  if (chatPollInterval) return;
  chatPollInterval = setInterval(pollForReplies, 5000);
}

function stopPolling() {
  clearInterval(chatPollInterval);
  chatPollInterval = null;
}

// Init chat if already set up
if (chatPhone) {
  // Show badge if window not open
}
</script>
</body>
</html>
