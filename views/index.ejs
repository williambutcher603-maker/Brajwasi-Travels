.testi-author{display:flex;align-items:center;gap:10px;}
.testi-avatar{width:36px;height:36px;background:linear-gradient(135deg,var(--gold-l),var(--gold-d));border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:14px;flex-shrink:0;}
.testi-name{font-size:14px;font-weight:700;color:var(--text);}
.testi-date{font-size:11px;color:var(--light);}
