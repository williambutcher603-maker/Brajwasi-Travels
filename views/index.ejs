<!-- FLEET -->
<section class="section" id="cars">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Our Fleet</span>
      <h2 class="section-title">Choose Your Ride</h2>
      <p>Well-maintained AC vehicles driven by professional, experienced chauffeurs.</p>
    </div>
    <div class="cars-grid">
      <% if(!cars.length){ %>
        <div class="no-cars"><i class="fas fa-car-side"></i><p>Fleet coming soon. Call <a href="tel:9411061000">9411061000</a></p></div>
      <% } else { cars.forEach(car => {
        const fkm = car.fixedPackage?.km || 0;
        const fp  = car.fixedPackage?.price || 0;
      %>
      <div class="car-card">
        <div class="car-img-wrap">
          <img src="<%= car.image %>" alt="<%= car.model %>" loading="lazy" onerror="this.src='/images/default-crysta.jpg'">
          <div class="car-badge"><%= car.availableIn.join(', ') %></div>
          <% if(car.ac){ %><div class="ac-badge"><i class="fas fa-snowflake"></i> AC</div><% } %>
        </div>
        <div class="car-body">
          <div class="car-header">
            <div><h3><%= car.model %></h3><p class="car-brand"><%= car.name %></p></div>
            <div class="car-seats"><i class="fas fa-users"></i> <%= car.seats %> Seats</div>
          </div>
          <p class="car-desc"><%= car.description || 'Comfortable, reliable, professionally driven.' %></p>
          <div class="car-pricing">
            <% if(fkm > 0){ %>
            <div class="cp-row">
              <span class="cp-label"><i class="fas fa-box" style="color:var(--gold)"></i> Fixed <%= fkm %>km Package</span>
              <span class="cp-val green">₹<%= fp.toLocaleString('en-IN') %></span>
            </div>
            <div class="cp-row">
              <span class="cp-label"><i class="fas fa-plus-circle" style="color:var(--gold)"></i> Extra km</span>
              <span class="cp-val">₹<%= car.extraKmCharge %>/km</span>
            </div>
            <% } else { %>
            <div class="cp-row">
              <span class="cp-label"><i class="fas fa-road" style="color:var(--gold)"></i> Per km rate</span>
              <span class="cp-val">₹<%= car.pricePerKm %>/km</span>
            </div>
            <% } %>
            <div class="cp-row">
              <span class="cp-label"><i class="fas fa-toll"></i> Toll tax</span>
              <span class="cp-val small"><%= car.tollTax %></span>
            </div>
          </div>
          <button class="book-btn" type="button"
            onclick="openBooking('<%= car._id %>','<%= car.model.replace(/'/g,"\\'") %>',<%= car.pricePerKm %>,<%= fkm %>,<%= fp %>,<%= car.extraKmCharge %>)">
            <i class="fas fa-calendar-check"></i> Book Now
          </button>
        </div>
      </div>
      <% }) } %>
    </div>
  </div>
</section>

