function openModal(id){var e=document.getElementById(id);if(e){e.classList.add('open');document.body.style.overflow='hidden';}}
function closeModal(id){var e=document.getElementById(id);if(e){e.classList.remove('open');document.body.style.overflow='';}}
function openFeedback(){openModal('feedbackModal');}
function closeFeedback(){closeModal('feedbackModal');}
function openLoginModal(){
  var s1=document.getElementById('otpStep1'),s2=document.getElementById('otpStep2'),al=document.getElementById('otpAlert');
  if(s1)s1.style.display='block'; if(s2)s2.style.display='none'; if(al)al.innerHTML='';
  openModal('loginModal');
}
function wireModals(){
  var pairs=[['closeBookingBtn','bookingModal'],['closePayBtn','paymentModal'],['closeSuccessBtn','successModal'],['closeFeedbackBtn','feedbackModal'],['closeLoginBtn','loginModal']];
  pairs.forEach(function(pr){
    var btn=document.getElementById(pr[0]);
    if(btn)btn.addEventListener('click',function(){closeModal(pr[1]);});
  });
  ['bookingModal','paymentModal','successModal','feedbackModal','loginModal'].forEach(function(id){
    var el=document.getElementById(id);
    if(el)el.addEventListener('click',function(e){if(e.target===e.currentTarget)closeModal(id);});
  });
  // OTP buttons
  var soBtn=document.getElementById('sendOtpBtn'),voBtn=document.getElementById('verifyOtpBtn');
  var oEmail=document.getElementById('otpEmailIn'),oCode=document.getElementById('otpCodeIn');
  if(soBtn)soBtn.addEventListener('click',sendOtp);
  if(voBtn)voBtn.addEventListener('click',verifyOtp);
  if(oEmail)oEmail.addEventListener('keypress',function(e){if(e.key==='Enter')sendOtp();});
  if(oCode)oCode.addEventListener('keypress',function(e){if(e.key==='Enter')verifyOtp();});
}

// ═══════════════════════════════════════════════
//  OTP LOGIN
// ═══════════════════════════════════════════════
function sendOtp(){
  var email=document.getElementById('otpEmailIn').value.trim();
  var name=document.getElementById('otpNameIn').value.trim();
  var al=document.getElementById('otpAlert');
  if(!email){al.innerHTML='<div style="color:var(--red);font-size:13px;margin-bottom:8px">Please enter your email</div>';return;}
  var btn=document.getElementById('sendOtpBtn');
  btn.innerHTML='<i class="fas fa-spinner fa-spin"></i> Sending...'; btn.disabled=true;
  fetch('/api/auth/send-otp',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email:email,name:name})}).then(function(r){return r.json();}).then(function(d){
    if(d.success){
      document.getElementById('otpStep1').style.display='none';
      document.getElementById('otpStep2').style.display='block';
      document.getElementById('otpEmailDisplay').textContent=email;
      al.innerHTML='';
      setTimeout(function(){var c=document.getElementById('otpCodeIn');if(c)c.focus();},100);
    }else{al.innerHTML='<div style="color:var(--red);font-size:13px;margin-bottom:8px">'+(d.error||'Failed')+'</div>';}
    btn.innerHTML='<i class="fas fa-paper-plane"></i> Send OTP'; btn.disabled=false;
  }).catch(function(){al.innerHTML='<div style="color:var(--red);font-size:13px">Network error</div>';btn.innerHTML='<i class="fas fa-paper-plane"></i> Send OTP';btn.disabled=false;});
}
function verifyOtp(){
  var email=document.getElementById('otpEmailIn').value.trim();
  var otp=document.getElementById('otpCodeIn').value.trim();
  var al=document.getElementById('otpAlert');
  if(!otp){al.innerHTML='<div style="color:var(--red);font-size:13px">Enter the OTP</div>';return;}
  var btn=document.getElementById('verifyOtpBtn');
  btn.innerHTML='<i class="fas fa-spinner fa-spin"></i> Verifying...'; btn.disabled=true;
  fetch('/api/auth/verify-otp',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email:email,otp:otp})}).then(function(r){return r.json();}).then(function(d){
    if(d.success){
      customerSession=d; closeModal('loginModal'); renderLoginBar(d);
      toast('Logged in as '+d.name+'! Complete your booking.','success');
      var ef=document.getElementById('bkEmail');if(ef)ef.value=d.email;
    }else{al.innerHTML='<div style="color:var(--red);font-size:13px;margin-bottom:8px">'+(d.error||'Invalid OTP')+'</div>';}
    btn.innerHTML='<i class="fas fa-check"></i> Verify & Login'; btn.disabled=false;
  }).catch(function(){al.innerHTML='<div style="color:var(--red);font-size:13px">Network error</div>';btn.innerHTML='<i class="fas fa-check"></i> Verify & Login';btn.disabled=false;});
}

