<!-- QR.js for UPI QR generation -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script src="/js/main.js"></script>

<script>
// ===== BOOKING STATE =====
let currentCarData = {};
let currentBookingId = null;
let currentPaymentData = null;

// ===== CHAT =====
let chatPhone = localStorage.getItem('bt_chat_phone') || '';
let chatName = localStorage.getItem('bt_chat_name') || '';
let lastMsgTime = null;
let chatPollInterval = null;

function toggleChat() {
  const win = document.getElementById('chatWindow');
  win.classList.toggle('open');
  if (win.classList.contains('open')) {
    if (chatPhone) showChatBody();
    startPolling();
  } else { stopPolling(); }
}
function showChatBody() {
  document.getElementById('chatSetup').style.display = 'none';
  const body = document.getElementById('chatBody');
  body.style.display = 'flex';
  loadChatHistory();
}
async function startChat() {
  const name = document.getElementById('chatName').value.trim();
  const phone = document.getElementById('chatPhone').value.trim();
  if (!name || !phone) { alert('Please enter your name and phone number'); return; }
  chatName = name; chatPhone = phone;
  localStorage.setItem('bt_chat_name', name);
  localStorage.setItem('bt_chat_phone', phone);
  showChatBody();
}
async function loadChatHistory() {
  if (!chatPhone) return;
  try {
    const resp = await fetch('/api/chat/' + encodeURIComponent(chatPhone) + '/history');
    const data = await resp.json();
    const msgs = document.getElementById('chatMessages');
    msgs.innerHTML = '';
    if (!data.messages || !data.messages.length) {
      msgs.innerHTML = '<div class="chat-empty"><i class="fas fa-comment-slash" style="font-size:28px;display:block;margin-bottom:8px;color:#ccc"></i>No messages yet.<br>Say hello!</div>';
    } else {
      data.messages.forEach(m => appendChatMsg(m, false));
      lastMsgTime = data.messages[data.messages.length - 1].createdAt;
    }
    scrollChatToBottom();
  } catch(e) { console.log('Chat load error:', e); }
}
function appendChatMsg(msg, scroll = true) {
  const msgs = document.getElementById('chatMessages');
  const emptyEl = msgs.querySelector('.chat-empty');
  if (emptyEl) emptyEl.remove();
  // Prevent duplicate messages by _id
  if (msg._id && document.getElementById('cmsg-' + msg._id)) return;
  const div = document.createElement('div');
  div.className = 'chat-msg ' + (msg.fromCustomer ? 'from-me' : 'from-admin');
  if (msg._id) div.id = 'cmsg-' + msg._id;
  const time = new Date(msg.createdAt).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' });
  const sender = msg.fromCustomer ? 'You' : '🧑‍💼 Brajwasi';
  div.innerHTML = `<div>${msg.message}</div><div class="chat-msg-time">${sender} · ${time}</div>`;
  msgs.appendChild(div);
  if (scroll) scrollChatToBottom();
}
function scrollChatToBottom() {
  const msgs = document.getElementById('chatMessages');
  msgs.scrollTop = msgs.scrollHeight;
}
async function sendChatMsg() {
  const input = document.getElementById('chatInput');
  const msg = input.value.trim();
  if (!msg || !chatPhone) return;
  input.value = '';
  // Optimistic UI (no id yet)
  const tempId = 'temp-' + Date.now();
  appendChatMsg({ _id: tempId, message: msg, fromCustomer: true, createdAt: new Date().toISOString() });
  try {
    const resp = await fetch('/api/chat/send', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ customerName: chatName, customerPhone: chatPhone, message: msg })
    });
    const data = await resp.json();
    lastMsgTime = new Date().toISOString();
    // Remove temp message, reload history to get real _id
    const tempEl = document.getElementById('cmsg-' + tempId);
    if (tempEl) tempEl.remove();
    await loadChatHistory();
  } catch(e) {}
}
async function pollForReplies() {
  if (!chatPhone || !document.getElementById('chatWindow').classList.contains('open')) return;
  try {
    const since = lastMsgTime || new Date(0).toISOString();
    const resp = await fetch('/api/chat/' + encodeURIComponent(chatPhone) + '/updates?since=' + encodeURIComponent(since));
    const data = await resp.json();
    if (data.messages && data.messages.length > 0) {
      data.messages.forEach(m => {
        appendChatMsg(m);
        if (!lastMsgTime || new Date(m.createdAt) > new Date(lastMsgTime)) {
          lastMsgTime = m.createdAt;
        }
      });
    }
  } catch(e) {}
}
function startPolling() { if (!chatPollInterval) chatPollInterval = setInterval(pollForReplies, 4000); }
function stopPolling() { clearInterval(chatPollInterval); chatPollInterval = null; }

// ===== BOOKING MODAL =====
function openBooking(carId, carModel, pricePerKm, fixedKm, fixedPrice, extraKmCharge) {
  currentCarData = { carId, carModel, pricePerKm, fixedKm, fixedPrice, extraKmCharge };
  document.getElementById('book-car-id').value = carId;
  document.getElementById('modal-car-name').textContent = carModel;
  document.getElementById('est-km').value = '';
  document.getElementById('calc-result').style.display = 'none';
  document.getElementById('book-date').min = new Date().toISOString().split('T')[0];
  document.getElementById('bookingModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeBooking() {
  document.getElementById('bookingModal').classList.remove('open');
  document.body.style.overflow = '';
}
function closeSuccess() {
  document.getElementById('successModal').classList.remove('open');
  document.body.style.overflow = '';
}
function closePayment() {
  document.getElementById('paymentModal').classList.remove('open');
  document.body.style.overflow = '';
}

document.getElementById('bookingModal').addEventListener('click', e => { if (e.target === e.currentTarget) closeBooking(); });
document.getElementById('successModal').addEventListener('click', e => { if (e.target === e.currentTarget) closeSuccess(); });
document.getElementById('paymentModal').addEventListener('click', e => { if (e.target === e.currentTarget) closePayment(); });

// ===== PRICE CALCULATOR =====
function calculatePrice() {
  const km = parseInt(document.getElementById('est-km').value);
  if (!km || km <= 0) { document.getElementById('calc-result').style.display = 'none'; return; }
  const { pricePerKm, fixedKm, fixedPrice, extraKmCharge } = currentCarData;
  let total = 0, breakdown = '';
  if (fixedKm && fixedPrice && km <= fixedKm) {
    total = fixedPrice;
    breakdown = `📦 Fixed ${fixedKm}km Package`;
  } else if (fixedKm && fixedPrice && km > fixedKm) {
    const extra = km - fixedKm;
    total = parseInt(fixedPrice) + (extra * extraKmCharge);
    breakdown = `📦 Fixed ${fixedKm}km: ₹${fixedPrice} + Extra ${extra}km × ₹${extraKmCharge} = ₹${extra * extraKmCharge}`;
  } else {
    total = km * pricePerKm;
    breakdown = `📍 ${km}km × ₹${pricePerKm}/km`;
  }
  const resultEl = document.getElementById('calc-result');
  resultEl.querySelector('.calc-breakdown').textContent = breakdown;
  resultEl.querySelector('.calc-total').textContent = `Estimated Fare: ₹${total.toLocaleString('en-IN')} (excl. toll)`;
  resultEl.style.display = 'block';
}

// ===== BOOKING FORM SUBMIT =====
document.getElementById('bookingForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = e.target.querySelector('.book-submit');
  const origText = btn.innerHTML;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
  btn.disabled = true;

  const payload = {
    carId: document.getElementById('book-car-id').value,
    customerName: document.getElementById('book-name').value,
    customerPhone: document.getElementById('book-phone').value,
    customerEmail: document.getElementById('book-email').value,
    pickupLocation: document.getElementById('book-pickup').value,
    dropLocation: document.getElementById('book-drop').value,
    journeyDate: document.getElementById('book-date').value,
    journeyTime: document.getElementById('book-time').value,
    estimatedKm: document.getElementById('est-km').value || 0,
    notes: document.getElementById('book-notes').value
  };

  try {
    const resp = await fetch('/api/book', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await resp.json();
    if (data.success) {
      closeBooking();
      currentBookingId = data.bookingId;
      e.target.reset();
      // Show payment modal first
      openPaymentModal(data.bookingId);
    } else {
      showToast('❌ Booking failed. Please call 9411061000', 'error');
    }
  } catch (err) {
    showToast('❌ Network error. Please call 9411061000', 'error');
  } finally {
    btn.innerHTML = origText;
    btn.disabled = false;
  }
});

// ===== UPI PAYMENT =====
let qrInstance = null;

async function openPaymentModal(bookingId) {
  document.getElementById('payment-booking-id').textContent = 'Booking ID: ' + bookingId;

  try {
    const resp = await fetch('/api/payment/' + bookingId);
    currentPaymentData = await resp.json();

    // Set app links
    document.getElementById('btn-phonepe').onclick = () => { openUpiApp('phonepe'); return false; };
    document.getElementById('btn-gpay').onclick = () => { openUpiApp('gpay'); return false; };
    document.getElementById('btn-paytm').onclick = () => { openUpiApp('paytm'); return false; };

    document.getElementById('upiIdDisplay').textContent = 'UPI: ' + currentPaymentData.upiId;

    // Generate QR
    const canvas = document.getElementById('upiQRCanvas');
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, 180, 180);

    if (window.QRCode) {
      if (qrInstance) { try { qrInstance.clear(); } catch(e){} }
      const qrDiv = document.createElement('div');
      qrInstance = new QRCode(qrDiv, {
        text: currentPaymentData.qrData,
        width: 180,
        height: 180,
        colorDark: '#1A1208',
        colorLight: '#FFFFFF',
        correctLevel: QRCode.CorrectLevel.M
      });
      setTimeout(() => {
        const img = qrDiv.querySelector('img');
        if (img) {
          const tempImg = new Image();
          tempImg.onload = () => ctx.drawImage(tempImg, 0, 0, 180, 180);
          tempImg.src = img.src;
        }
      }, 200);
    }

    // On mobile hide QR, on desktop show it
    const isMobile = /Android|iPhone|iPad/i.test(navigator.userAgent);
    document.getElementById('qrWrap').style.display = isMobile ? 'none' : 'block';

  } catch(e) { console.log('Payment data fetch failed:', e); }

  document.getElementById('paymentModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function openUpiApp(app) {
  if (!currentPaymentData) return;
  let url = currentPaymentData.upiUrl;
  if (app === 'phonepe') url = currentPaymentData.phonepe;
  else if (app === 'gpay') url = currentPaymentData.gpay;
  else if (app === 'paytm') url = currentPaymentData.paytm;

  // Try to open the app
  window.location.href = url;

  // Fallback: if app not installed, after 2s show message
  setTimeout(() => {
    showToast('💡 If app didn\'t open, use the QR or try another app', 'info');
  }, 2000);
}

async function markPaid() {
  if (!currentBookingId) return;
  try {
    await fetch('/api/payment/' + currentBookingId + '/confirm', { method: 'POST' });
  } catch(e) {}
  closePayment();
  document.getElementById('success-booking-id').textContent = currentBookingId;
  document.getElementById('successModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}

// ===== ENQUIRY FORM =====
document.getElementById('enquiryForm').addEventListener('submit', (e) => {
  e.preventDefault();
  const name = document.getElementById('eq-name').value;
  const phone = document.getElementById('eq-phone').value;
  const route = document.getElementById('eq-route').value;
  const date = document.getElementById('eq-date').value;
  const waMsg = encodeURIComponent(`Hi Brajwasi Tour & Travels,\n\n👤 Name: ${name}\n📞 Phone: ${phone}\n🗺 Route: ${route}\n📅 Date: ${date}\n\nPlease confirm availability.`);
  window.open(`https://wa.me/919411061000?text=${waMsg}`, '_blank');
  e.target.reset();
  showToast('✅ Redirecting to WhatsApp...', 'success');
});

// ===== TOAST =====
function showToast(message, type = 'success') {
  const existing = document.querySelector('.toast');
  if (existing) existing.remove();
  const toast = document.createElement('div');
  toast.className = 'toast';
  const colors = { success: { bg: '#EAF7EE', border: '#1A7A3A', color: '#1A7A3A' }, error: { bg: '#FDEDEB', border: '#C0392B', color: '#C0392B' }, info: { bg: '#EEF4FF', border: '#1A5DAB', color: '#1A5DAB' } };
  const c = colors[type] || colors.success;
  toast.innerHTML = message;
  toast.style.cssText = `position:fixed;bottom:90px;right:20px;z-index:99999;background:${c.bg};border:1px solid ${c.border};color:${c.color};padding:14px 20px;border-radius:10px;font-size:14px;font-weight:600;box-shadow:0 4px 20px rgba(0,0,0,0.12);max-width:320px;animation:fadeInUp 0.3s ease;`;
  document.body.appendChild(toast);
  setTimeout(() => toast.remove(), 4000);
}

