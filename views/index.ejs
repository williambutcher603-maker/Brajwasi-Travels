//  BOOKING
// ═══════════════════════════════════════════════
function openBooking(id,model,ppk,fkm,fp,ekc){
  carData={id:id,model:model,ppk:ppk,fkm:fkm,fp:fp,ekc:ekc};
  document.getElementById('bookCarId').value=id;
  document.getElementById('modalCarName').textContent=model;
  document.getElementById('estKm').value='';
  document.getElementById('calcResult').style.display='none';
  document.getElementById('bkDate').min=new Date().toISOString().split('T')[0];
  if(customerSession){
    var en=document.getElementById('bkEmail');if(en)en.value=customerSession.email;
    var nn=document.getElementById('bkName');if(nn&&!nn.value)nn.value=customerSession.name;
  }
  openModal('bookingModal');
}
function wireBookingForm(){
  var km=document.getElementById('estKm');
  if(km)km.addEventListener('input',calcPrice);
  var form=document.getElementById('bookingForm');
  if(!form)return;
  form.addEventListener('submit',function(e){
    e.preventDefault();
    var kmVal=document.getElementById('estKm').value;
    if(!kmVal||+kmVal<1){toast('Please enter estimated distance in KM','error');document.getElementById('estKm').focus();return;}
    if(!customerSession){openLoginModal();return;}
    var btn=document.getElementById('bookSubmitBtn');
    btn.innerHTML='<i class="fas fa-spinner fa-spin"></i> Processing...'; btn.disabled=true;
    fetch('/api/book',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
      carId:document.getElementById('bookCarId').value,
      customerName:document.getElementById('bkName').value,
      customerPhone:document.getElementById('bkPhone').value,
      pickupLocation:document.getElementById('bkPickup').value,
      dropLocation:document.getElementById('bkDrop').value,
      journeyDate:document.getElementById('bkDate').value,
      journeyTime:document.getElementById('bkTime').value,
      estimatedKm:kmVal,
      notes:document.getElementById('bkNotes').value
    })}).then(function(r){return r.json();}).then(function(d){
      if(d.success){currentBookingId=d.bookingId;closeModal('bookingModal');form.reset();openPayModal(d.bookingId);}
      else if(d.loginRequired){openLoginModal();}
      else{toast(d.error||'Booking failed. Call 9411061000','error');}
      btn.innerHTML='<i class="fas fa-check-circle"></i> Confirm Booking'; btn.disabled=false;
    }).catch(function(){toast('Network error. Call 9411061000','error');btn.innerHTML='<i class="fas fa-check-circle"></i> Confirm Booking';btn.disabled=false;});
  });
}
function calcPrice(){
  var km=parseInt(document.getElementById('estKm').value);
  var d=carData;
  if(!km||km<=0){document.getElementById('calcResult').style.display='none';return;}
  var total=0,bd='';
  if(d.fkm&&d.fp&&km<=d.fkm){total=d.fp;bd='📦 Fixed '+d.fkm+'km Package';}
  else if(d.fkm&&d.fp){var ex=km-d.fkm;total=d.fp+ex*d.ekc;bd='📦 '+d.fkm+'km: ₹'+d.fp+' + Extra '+ex+'km × ₹'+d.ekc;}
  else{total=km*d.ppk;bd='📍 '+km+'km × ₹'+d.ppk+'/km';}
  document.getElementById('calcBreakdown').textContent=bd;
  document.getElementById('calcTotal').textContent='Estimated Fare: ₹'+total.toLocaleString('en-IN')+' (excl. toll)';
  document.getElementById('calcResult').style.display='block';
}

// ═══════════════════════════════════════════════
//  PAYMENT
// ═══════════════════════════════════════════════
function openPayModal(bookingId){
  document.getElementById('payBookingId').textContent='Booking ID: '+bookingId;
  fetch('/api/payment/'+bookingId).then(function(r){return r.json();}).then(function(d){
    if(d.error){showSuccess(bookingId);return;}
    payData=d;
    document.getElementById('upiIdTxt').textContent='UPI: '+d.upiId;
    var map={upiPhonePe:'phonepe',upiGPay:'gpay',upiPaytm:'paytm',upiAnyBtn:'upi'};
    Object.keys(map).forEach(function(id){
      var el=document.getElementById(id);
      if(el)el.onclick=function(e){if(id!=='upiAnyBtn')e.preventDefault();launchUpi(map[id]);};
    });
    var isMobile=/Android|iPhone|iPad/i.test(navigator.userAgent);
    var qw=document.getElementById('upiQrWrap');
    if(qw)qw.style.display=isMobile?'none':'block';
    if(!isMobile)drawQR(d.qrData);
    openModal('paymentModal');
  }).catch(function(){showSuccess(bookingId);});
}
function launchUpi(app){
  if(!payData)return;
  var urls={phonepe:payData.phonepe,gpay:payData.gpay,paytm:payData.paytm,upi:payData.upiUrl};
  window.location.href=urls[app]||payData.upiUrl;
  setTimeout(function(){toast('If app did not open, try another or scan QR','info');},2000);
}
function drawQR(data){
  var canvas=document.getElementById('upiQR');
  if(!canvas||!window.QRCode)return;
  var ctx=canvas.getContext('2d'); ctx.clearRect(0,0,176,176);
  var div=document.createElement('div');
  new QRCode(div,{text:data,width:176,height:176,colorDark:'#1A1208',colorLight:'#FFFFFF',correctLevel:QRCode.CorrectLevel.M});
  setTimeout(function(){var img=div.querySelector('img');if(img){var i=new Image();i.onload=function(){ctx.drawImage(i,0,0,176,176);};i.src=img.src;}},300);
}
function wirePayBtn(){
  var btn=document.getElementById('paidBtn');
  if(btn)btn.addEventListener('click',function(){
    if(currentBookingId)fetch('/api/payment/'+currentBookingId+'/confirm',{method:'POST'}).catch(function(){});
    closeModal('paymentModal');
    showSuccess(currentBookingId);
  });
}
function showSuccess(bookingId){
  document.getElementById('successBookingId').textContent=bookingId;
  var tl=document.getElementById('trackLink');if(tl)tl.href='/track?bookingId='+bookingId;
  openModal('successModal');
}

