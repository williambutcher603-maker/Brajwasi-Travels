.testi-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r-lg);padding:24px;transition:var(--ease);}
.testi-card:hover{border-color:rgba(184,120,10,.35);transform:translateY(-3px);box-shadow:var(--shadow);}
