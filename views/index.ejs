<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
// ═══════════════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════════════
window.addEventListener('load', () => {
  document.getElementById('heroBg').classList.add('loaded');
  initPush();
  initChat();
});
window.addEventListener('scroll', () => {
  document.getElementById('header').classList.toggle('scrolled', window.scrollY > 50);
});

// ═══════════════════════════════════════════════════
//  PUSH NOTIFICATIONS
// ═══════════════════════════════════════════════════
async function initPush() {
  if (!('serviceWorker' in navigator) || !('PushManager' in window)) return;
  try {
    await navigator.serviceWorker.register('/sw.js');
    if (Notification.permission === 'default')
      setTimeout(() => { document.getElementById('notif-bar').style.display = 'flex'; }, 4000);
  } catch(e) {}
}
async function requestPush() {
  document.getElementById('notif-bar').style.display = 'none';
  const p = await Notification.requestPermission();
  if (p === 'granted') {
    try {
      const reg = await navigator.serviceWorker.ready;
      const r = await fetch('/vapid-public-key');
      const { publicKey } = await r.json();
      if (!publicKey) return;
      const sub = await reg.pushManager.subscribe({ userVisibleOnly: true, applicationServerKey: b64ToUint8(publicKey) });
      await fetch('/subscribe', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(sub) });
      toast('✅ Notifications enabled!', 'success');
    } catch(e) {}
  }
}
function b64ToUint8(b) {
  const pad = '='.repeat((4 - b.length % 4) % 4);
  const raw = atob((b + pad).replace(/-/g,'+').replace(/_/g,'/'));
  return Uint8Array.from(raw, c => c.charCodeAt(0));
}

// ═══════════════════════════════════════════════════
//  CHAT — event listeners only (no inline onclick)
// ═══════════════════════════════════════════════════
let chatPhone = localStorage.getItem('bt_phone') || '';
let chatName  = localStorage.getItem('bt_name')  || '';
let lastMsgTs = null;
let chatPoll  = null;

function initChat() {
  // Wire up all chat events here — guaranteed to run after DOM is ready
  document.getElementById('chatToggle').addEventListener('click', toggleChat);
  document.getElementById('chatCloseBtn').addEventListener('click', toggleChat);
  document.getElementById('chatStartBtn').addEventListener('click', startChat);
  document.getElementById('chatSendBtn').addEventListener('click', sendChat);
  document.getElementById('chatIn').addEventListener('keypress', e => { if (e.key === 'Enter') sendChat(); });
  // If returning user, pre-fill name
  if (chatPhone) {
    document.getElementById('chatNameIn').value = chatName;
    document.getElementById('chatPhoneIn').value = chatPhone;
  }
}

function toggleChat() {
  const win = document.getElementById('chatWindow');
  const isOpen = win.classList.toggle('open');
  if (isOpen) {
    if (chatPhone) showChatBody();
    startChatPoll();
  } else {
    stopChatPoll();
  }
}

function showChatBody() {
  document.getElementById('chatSetup').style.display = 'none';
  document.getElementById('chatBody').style.display = 'flex';
  loadChatHistory();
}

function startChat() {
  const name  = document.getElementById('chatNameIn').value.trim();
  const phone = document.getElementById('chatPhoneIn').value.trim();
  if (!name || !phone) { toast('Please enter your name and phone', 'error'); return; }
  chatName  = name;
  chatPhone = phone;
  localStorage.setItem('bt_name',  name);
  localStorage.setItem('bt_phone', phone);
  showChatBody();
}

async function loadChatHistory() {
  try {
    const r = await fetch('/api/chat/' + encodeURIComponent(chatPhone) + '/history');
    const d = await r.json();
    const box = document.getElementById('chatMsgs');
    box.innerHTML = '';
    if (!d.messages.length) {
      box.innerHTML = '<div class="chat-empty" id="chatEmpty"><i class="fas fa-comment-slash" style="font-size:26px;display:block;margin-bottom:8px;color:#ccc"></i>No messages yet. Say hello!</div>';
    } else {
      d.messages.forEach(m => appendMsg(m, false));
      lastMsgTs = d.messages.at(-1).createdAt;
    }
    scrollChat();
  } catch(e) {}
}

function appendMsg(msg, doScroll = true) {
  const box = document.getElementById('chatMsgs');
  if (!box) return;
  const empty = box.querySelector('#chatEmpty');
  if (empty) empty.remove();
  if (msg._id && document.getElementById('cm-' + msg._id)) return;
  const d = document.createElement('div');
  d.className = 'chat-msg ' + (msg.fromCustomer ? 'from-me' : 'from-admin');
  if (msg._id) d.id = 'cm-' + msg._id;
  const t = new Date(msg.createdAt).toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit' });
  d.innerHTML = `<div>${esc(msg.message)}</div><div class="msg-time">${msg.fromCustomer ? 'You' : '🧑‍💼 Brajwasi'} · ${t}</div>`;
  box.appendChild(d);
  if (doScroll) scrollChat();
}

function scrollChat() {
  const b = document.getElementById('chatMsgs');
  if (b) b.scrollTop = b.scrollHeight;
}

async function sendChat() {
  const input = document.getElementById('chatIn');
  const msg = input.value.trim();
  if (!msg || !chatPhone) return;
  input.value = '';
  const tempId = 'tmp-' + Date.now();
  appendMsg({ _id: tempId, message: msg, fromCustomer: true, createdAt: new Date().toISOString() });
  try {
    await fetch('/api/chat/send', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ customerName: chatName, customerPhone: chatPhone, message: msg })
    });
    lastMsgTs = new Date().toISOString();
    // Remove temp, reload to get real _id
    const te = document.getElementById('cm-' + tempId);
    if (te) te.remove();
    await loadChatHistory();
  } catch(e) {}
}

async function pollChat() {
  if (!chatPhone) return;
  try {
    const since = lastMsgTs || new Date(0).toISOString();
    const r = await fetch('/api/chat/' + encodeURIComponent(chatPhone) + '/updates?since=' + encodeURIComponent(since));
    const d = await r.json();
    if (d.messages?.length) {
      d.messages.forEach(m => {
        appendMsg(m);
        if (!lastMsgTs || new Date(m.createdAt) > new Date(lastMsgTs)) lastMsgTs = m.createdAt;
      });
    }
  } catch(e) {}
}

function startChatPoll() { if (!chatPoll) chatPoll = setInterval(pollChat, 4000); }
function stopChatPoll()  { clearInterval(chatPoll); chatPoll = null; }

// ═══════════════════════════════════════════════════
//  BOOKING
// ═══════════════════════════════════════════════════
let carData = {};
let currentBookingId = null;
let payData = null;
let qrInst = null;

function openBooking(id, model, ppk, fkm, fp, ekc) {
  carData = { id, model, ppk, fkm, fp, ekc };
  document.getElementById('bookCarId').value = id;
  document.getElementById('modalCarName').textContent = model;
  document.getElementById('estKm').value = '';
  document.getElementById('calcResult').style.display = 'none';
  document.getElementById('bkDate').min = new Date().toISOString().split('T')[0];
  openModal('bookingModal');
}

document.getElementById('estKm').addEventListener('input', calcPrice);
function calcPrice() {
  const km = parseInt(document.getElementById('estKm').value);
  const { ppk, fkm, fp, ekc } = carData;
  if (!km || km <= 0) { document.getElementById('calcResult').style.display = 'none'; return; }
  let total = 0, breakdown = '';
  if (fkm && fp && km <= fkm) { total = fp; breakdown = `📦 Fixed ${fkm}km Package`; }
  else if (fkm && fp && km > fkm) { const ex = km - fkm; total = fp + ex * ekc; breakdown = `📦 ${fkm}km: ₹${fp} + Extra ${ex}km × ₹${ekc}`; }
  else { total = km * ppk; breakdown = `📍 ${km}km × ₹${ppk}/km`; }
  document.getElementById('calcBreakdown').textContent = breakdown;
  document.getElementById('calcTotal').textContent = `Estimated Fare: ₹${total.toLocaleString('en-IN')} (excl. toll)`;
  document.getElementById('calcResult').style.display = 'block';
}

document.getElementById('bookingForm').addEventListener('submit', async e => {
  e.preventDefault();
  const btn = document.getElementById('bookSubmitBtn');
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...'; btn.disabled = true;
  try {
    const r = await fetch('/api/book', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        carId: document.getElementById('bookCarId').value,
        customerName: document.getElementById('bkName').value,
        customerPhone: document.getElementById('bkPhone').value,
        customerEmail: document.getElementById('bkEmail').value,
        pickupLocation: document.getElementById('bkPickup').value,
        dropLocation: document.getElementById('bkDrop').value,
        journeyDate: document.getElementById('bkDate').value,
        journeyTime: document.getElementById('bkTime').value,
        estimatedKm: document.getElementById('estKm').value || 0,
        notes: document.getElementById('bkNotes').value
      })
    });
    const d = await r.json();
    if (d.success) {
      currentBookingId = d.bookingId;
      closeModal('bookingModal');
      document.getElementById('bookingForm').reset();
      await openPayModal(d.bookingId);
    } else { toast('❌ Booking failed. Call 9411061000', 'error'); }
  } catch(err) { toast('❌ Network error. Call 9411061000', 'error'); }
  finally { btn.innerHTML = '<i class="fas fa-check-circle"></i> Confirm Booking'; btn.disabled = false; }
});

// ═══════════════════════════════════════════════════
//  PAYMENT
// ═══════════════════════════════════════════════════
async function openPayModal(bookingId) {
  document.getElementById('payBookingId').textContent = 'Booking ID: ' + bookingId;
  try {
    const r = await fetch('/api/payment/' + bookingId);
    payData = await r.json();
    if (payData.error) { toast('UPI not configured. Please call 9411061000', 'error'); showSuccess(bookingId); return; }

    document.getElementById('upiIdTxt').textContent = 'UPI: ' + payData.upiId;
    document.getElementById('upiPhonePe').onclick = e => { e.preventDefault(); launchUpi('phonepe'); };
    document.getElementById('upiGPay').onclick    = e => { e.preventDefault(); launchUpi('gpay'); };
    document.getElementById('upiPaytm').onclick   = e => { e.preventDefault(); launchUpi('paytm'); };
    document.getElementById('upiAnyBtn').onclick  = () => launchUpi('upi');

    // QR for desktop
    const isMobile = /Android|iPhone|iPad/i.test(navigator.userAgent);
    const qrWrap = document.getElementById('upiQrWrap');
    qrWrap.style.display = isMobile ? 'none' : 'block';
    if (!isMobile) drawQR(payData.qrData);

    openModal('paymentModal');
  } catch(e) { showSuccess(bookingId); }
}

function launchUpi(app) {
  if (!payData) return;
  const urls = { phonepe: payData.phonepe, gpay: payData.gpay, paytm: payData.paytm, upi: payData.upiUrl };
  window.location.href = urls[app] || payData.upiUrl;
  setTimeout(() => toast('💡 If app didn\'t open, try another app or scan the QR', 'info'), 2000);
}

function drawQR(data) {
  const canvas = document.getElementById('upiQR');
  if (!canvas || !window.QRCode) return;
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0, 0, 176, 176);
  const div = document.createElement('div');
  const qr = new QRCode(div, { text: data, width: 176, height: 176, colorDark: '#1A1208', colorLight: '#FFFFFF', correctLevel: QRCode.CorrectLevel.M });
  setTimeout(() => {
    const img = div.querySelector('img');
    if (img) { const i = new Image(); i.onload = () => ctx.drawImage(i, 0, 0, 176, 176); i.src = img.src; }
  }, 300);
}

document.getElementById('paidBtn').addEventListener('click', async () => {
  if (currentBookingId) {
    try { await fetch('/api/payment/' + currentBookingId + '/confirm', { method: 'POST' }); } catch(e) {}
  }
  closeModal('paymentModal');
  showSuccess(currentBookingId);
});

function showSuccess(bookingId) {
  document.getElementById('successBookingId').textContent = bookingId;
  document.getElementById('trackLink').href = '/track?bookingId=' + bookingId;
  openModal('successModal');
}

// ═══════════════════════════════════════════════════
//  MODALS
// ═══════════════════════════════════════════════════
function openModal(id) { document.getElementById(id).classList.add('open'); document.body.style.overflow = 'hidden'; }
function closeModal(id) { document.getElementById(id).classList.remove('open'); document.body.style.overflow = ''; }

document.getElementById('closeBookingBtn').addEventListener('click', () => closeModal('bookingModal'));
document.getElementById('closePayBtn').addEventListener('click', () => closeModal('paymentModal'));
document.getElementById('closeSuccessBtn').addEventListener('click', () => closeModal('successModal'));
['bookingModal','paymentModal','successModal'].forEach(id => {
  document.getElementById(id).addEventListener('click', e => { if (e.target === e.currentTarget) closeModal(id); });
});

// ═══════════════════════════════════════════════════
//  ENQUIRY FORM
// ═══════════════════════════════════════════════════
document.getElementById('enquiryForm').addEventListener('submit', e => {
  e.preventDefault();
  const name  = document.getElementById('eq-name').value;
  const phone = document.getElementById('eq-phone').value;
  const route = document.getElementById('eq-route').value;
  const date  = document.getElementById('eq-date').value;
  const msg   = encodeURIComponent(`Hi Brajwasi Tour & Travels,\n\n👤 Name: ${name}\n📞 Phone: ${phone}\n🗺 Route: ${route}\n📅 Date: ${date}\n\nPlease confirm availability.`);
  window.open(`https://wa.me/919411061000?text=${msg}`, '_blank');
  e.target.reset();
  toast('✅ Redirecting to WhatsApp...', 'success');
});

// ═══════════════════════════════════════════════════
//  TOAST
// ═══════════════════════════════════════════════════
function toast(msg, type = 'success') {
  document.querySelector('.toast')?.remove();
  const t = document.createElement('div');
  const c = { success: ['#EAF7EE','#1A7A3A'], error: ['#FDEDEB','#C0392B'], info: ['#EEF4FF','#1A5DAB'] }[type] || ['#EAF7EE','#1A7A3A'];
  t.style.cssText = `position:fixed;bottom:90px;right:20px;z-index:99999;background:${c[0]};border:1px solid ${c[1]};color:${c[1]};padding:13px 18px;border-radius:10px;font-size:14px;font-weight:600;box-shadow:0 4px 20px rgba(0,0,0,.12);max-width:320px;font-family:'DM Sans',sans-serif;animation:fadeUp .3s ease;`;
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 4000);
}

function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
