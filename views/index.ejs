// ── CHAT — Real-time with unread badge & preview ─────────
var _unreadCount = 0;
var _chatOpen    = false;
var _bgPoll      = null;   // background poll even when window closed
var _bgLastTs    = new Date().toISOString(); // start from NOW so old msgs don't trigger badge

// Wire buttons
document.getElementById('chatBtn').addEventListener('click', function() {
  _chatOpen = !_chatOpen;
  var win = document.getElementById('chatWindow');
  win.style.display = _chatOpen ? 'flex' : 'none';
  if (_chatOpen) {
    _clearBadge();
    _hidePreview();
    if (_chatPhone) _showChatBody();
    _startChatPoll();
  } else {
    _stopChatPoll();
    _startBgPoll();   // keep bg polling so badge updates
  }
});
document.getElementById('chatCloseBtn').addEventListener('click', function() {
  _chatOpen = false;
  document.getElementById('chatWindow').style.display = 'none';
  _stopChatPoll();
  _startBgPoll();
});
document.getElementById('chatStartBtn').addEventListener('click', _startChat);
document.getElementById('chatSendBtn').addEventListener('click', _sendChat);
document.getElementById('chatIn').addEventListener('keypress', function(e) { if (e.key === 'Enter') _sendChat(); });

// Pre-fill returning user
if (_chatPhone) {
  var _ni = document.getElementById('chatNameIn'); var _pi = document.getElementById('chatPhoneIn');
  if (_ni) _ni.value = _chatName; if (_pi) _pi.value = _chatPhone;
  // Start background poll silently — shows badge if admin replied while away
  _startBgPoll();
}

function _showChatBody() {
  document.getElementById('chatSetup').style.display = 'none';
  document.getElementById('chatBody').style.display = 'flex';
  _loadChatHistory();
}
function _startChat() {
  var n = document.getElementById('chatNameIn').value.trim();
  var p = document.getElementById('chatPhoneIn').value.trim();
  if (!n || !p) { showToast('Enter your name and phone', 'error'); return; }
  _chatName = n; _chatPhone = p;
  localStorage.setItem('bt_name', n); localStorage.setItem('bt_phone', p);
  _resubPhone(p);
  _showChatBody();
  _stopBgPoll();
}

// ── Badge helpers ──────────────────────────────────────────
function _setBadge(count) {
  var badge = document.getElementById('chatBadge');
  var btn   = document.getElementById('chatBtn');
  if (!badge) return;
  if (count > 0) {
    badge.style.display = 'flex';
    badge.textContent = count > 9 ? '9+' : count;
    btn.classList.add('chat-has-unread');
    btn.style.transform = 'scale(1.05)';
  } else {
    _clearBadge();
  }
}
function _clearBadge() {
  _unreadCount = 0;
  _bgLastTs = new Date().toISOString(); // reset so bg poll doesn't re-show cleared messages
  var badge = document.getElementById('chatBadge');
  var btn   = document.getElementById('chatBtn');
  if (badge) badge.style.display = 'none';
  if (btn)   { btn.classList.remove('chat-has-unread'); btn.style.transform = ''; }
  _hidePreview();
}
function _showPreview(text) {
  var prev = document.getElementById('chatPreview');
  var txt  = document.getElementById('chatPreviewText');
  if (!prev || !txt) return;
  txt.textContent = '💬 ' + (text.length > 35 ? text.substring(0, 35) + '…' : text);
  prev.style.display = 'block';
  // Auto-hide after 5s
  clearTimeout(window._previewTimer);
  window._previewTimer = setTimeout(_hidePreview, 5000);
}
function _hidePreview() {
  var prev = document.getElementById('chatPreview');
  if (prev) prev.style.display = 'none';
}

// ── Load history ────────────────────────────────────────────
function _loadChatHistory() {
  fetch('/api/chat/' + encodeURIComponent(_chatPhone) + '/history')
    .then(function(r) { return r.json(); })
    .then(function(d) {
      var box = document.getElementById('chatMsgs');
      box.innerHTML = '';
      if (!d.messages || !d.messages.length) {
        box.innerHTML = '<div id="chatEmpty" style="text-align:center;color:#A0917E;font-size:13px;padding:20px"><i class="fas fa-comment-slash" style="font-size:24px;display:block;margin-bottom:8px;color:#ccc"></i>No messages yet. Say hello!</div>';
      } else {
        d.messages.forEach(function(m) { _appendMsg(m, false); });
        _lastMsgTs = d.messages[d.messages.length - 1].createdAt;
      }
      box.scrollTop = box.scrollHeight;
    }).catch(function() {});
}

// ── Append a single message bubble ─────────────────────────
function _appendMsg(msg, scroll) {
  if (scroll === undefined) scroll = true;
  var box   = document.getElementById('chatMsgs');
  var empty = document.getElementById('chatEmpty');
  if (empty) empty.remove();
  if (msg._id && document.getElementById('cm-' + msg._id)) return;

  var wrap = document.createElement('div');
  wrap.style.cssText = 'display:flex;flex-direction:column;align-items:' + (msg.fromCustomer ? 'flex-end' : 'flex-start') + ';margin-bottom:2px';

  var bubble = document.createElement('div');
  bubble.style.cssText = 'max-width:82%;padding:9px 13px;border-radius:' + (msg.fromCustomer ? '14px 14px 4px 14px' : '14px 14px 14px 4px') + ';font-size:13px;line-height:1.5;word-break:break-word;animation:fadeSlideUp .25s ease;' + (msg.fromCustomer ? 'background:linear-gradient(135deg,#1a56db,#0e3eb3);color:#fff' : 'background:#fff;color:#1A1208;border:1px solid #E8DDD0;box-shadow:0 1px 3px rgba(0,0,0,.06)');
  if (msg._id) bubble.id = 'cm-' + msg._id;

  var t = new Date(msg.createdAt).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' });
  var senderLabel = msg.fromCustomer ? 'You' : '🧑‍💼 Brajwasi';
  bubble.innerHTML = '<div>' + _esc(msg.message) + '</div><div style="font-size:10px;opacity:.55;margin-top:3px;display:flex;align-items:center;gap:3px;justify-content:' + (msg.fromCustomer ? 'flex-end' : 'flex-start') + '">' + senderLabel + ' · ' + t + (msg.fromCustomer ? ' <span style="color:rgba(255,255,255,.6)">✓</span>' : '') + '</div>';

  wrap.appendChild(bubble);
  box.appendChild(wrap);
  if (scroll) { box.scrollTop = box.scrollHeight; }
}

// ── Send message ────────────────────────────────────────────
function _sendChat() {
  var inp = document.getElementById('chatIn');
  var msg = inp.value.trim();
  if (!msg || !_chatPhone) return;
  inp.value = '';
  inp.focus();
  // Optimistic bubble
  var tid = 'tmp-' + Date.now();
  _appendMsg({ _id: tid, message: msg, fromCustomer: true, createdAt: new Date().toISOString() });
  // Show typing indicator
  _showTypingIndicator();
  fetch('/api/chat/send', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ customerName: _chatName, customerPhone: _chatPhone, message: msg })
  }).then(function() {
    _lastMsgTs = new Date().toISOString();
    var te = document.getElementById('cm-' + tid); if (te) te.parentNode && te.parentNode.remove();
    _hideTypingIndicator();
    _loadChatHistory();
  }).catch(function() { _hideTypingIndicator(); });
}

function _showTypingIndicator() {
  var box = document.getElementById('chatMsgs');
  if (document.getElementById('typingIndicator')) return;
  var el = document.createElement('div');
  el.id = 'typingIndicator';
  el.style.cssText = 'display:flex;align-items:flex-start;margin-bottom:2px';
  el.innerHTML = '<div style="background:#fff;border:1px solid #E8DDD0;border-radius:14px 14px 14px 4px;padding:10px 14px;box-shadow:0 1px 3px rgba(0,0,0,.06)"><div style="display:flex;gap:4px;align-items:center"><span style="width:6px;height:6px;border-radius:50%;background:#ccc;animation:typingDot 1.2s ease infinite"></span><span style="width:6px;height:6px;border-radius:50%;background:#ccc;animation:typingDot 1.2s ease .2s infinite"></span><span style="width:6px;height:6px;border-radius:50%;background:#ccc;animation:typingDot 1.2s ease .4s infinite"></span></div></div>';
  box.appendChild(el);
  box.scrollTop = box.scrollHeight;
}
function _hideTypingIndicator() {
  var el = document.getElementById('typingIndicator');
  if (el) el.remove();
}

// ── Real-time poll (window open) ────────────────────────────
function _pollChat() {
  if (!_chatPhone) return;
  var since = _lastMsgTs || new Date(0).toISOString();
  fetch('/api/chat/' + encodeURIComponent(_chatPhone) + '/updates?since=' + encodeURIComponent(since))
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.messages && d.messages.length) {
        d.messages.forEach(function(m) {
          _appendMsg(m, true);
          if (!_lastMsgTs || new Date(m.createdAt) > new Date(_lastMsgTs)) _lastMsgTs = m.createdAt;
        });
      }
    }).catch(function() {});
}

// ── Background poll (window closed) — shows badge ──────────
function _bgPollFn() {
  if (!_chatPhone || _chatOpen) return;
  fetch('/api/chat/' + encodeURIComponent(_chatPhone) + '/updates?since=' + encodeURIComponent(_bgLastTs))
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (!d.messages || !d.messages.length) return;
      var newAdminMsgs = d.messages.filter(function(m) { return !m.fromCustomer; });
      // Update bgLastTs to latest received
      _bgLastTs = d.messages[d.messages.length - 1].createdAt;
      if (newAdminMsgs.length > 0) {
        _unreadCount += newAdminMsgs.length;
        _setBadge(_unreadCount);
        _showPreview(newAdminMsgs[newAdminMsgs.length - 1].message);
        _playBeep();
      }
    }).catch(function() {});
}
function _playBeep() {
  try {
    var ctx = new (window.AudioContext || window.webkitAudioContext)();
    var osc = ctx.createOscillator();
    var gain = ctx.createGain();
    osc.connect(gain); gain.connect(ctx.destination);
    osc.frequency.value = 880;
    gain.gain.setValueAtTime(0.15, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.35);
    osc.start(ctx.currentTime); osc.stop(ctx.currentTime + 0.35);
  } catch(e) {}
}

function _startChatPoll() { if (!_chatPoll) _chatPoll = setInterval(_pollChat, 2500); }
function _stopChatPoll()  { clearInterval(_chatPoll); _chatPoll = null; }
function _startBgPoll()   { if (!_bgPoll) _bgPoll = setInterval(_bgPollFn, 5000); }
function _stopBgPoll()    { clearInterval(_bgPoll); _bgPoll = null; }

// ── Enquiry form ───────────────────────────────────────────
document.getElementById('enquiryForm').addEventListener('submit', function(e) {
  e.preventDefault();
  var n = document.getElementById('eq-name').value, p = document.getElementById('eq-phone').value;
