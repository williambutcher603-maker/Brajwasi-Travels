<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Brajwasi Travels – Premium Car Rentals | Agra</title>
<meta name="description" content="Brajwasi Travels – Trusted car rental service since 1980. Book Toyota Crysta and more for Agra tours, Taj Mahal visits, and outstation trips.">
<link rel="manifest" href="/manifest.json">
<link rel="icon" type="image/png" href="/images/favicon.png">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link rel="stylesheet" href="/css/main.css">
<style>
/* Advance payment notice */
.advance-notice {
  background: linear-gradient(135deg, rgba(201,146,42,0.12), rgba(201,146,42,0.04));
  border: 1px solid rgba(201,146,42,0.35);
  border-radius: 14px;
  padding: 18px 22px;
  margin: 20px 0;
  display: flex;
  gap: 14px;
  align-items: flex-start;
}
.advance-notice .an-icon {
  width: 40px; height: 40px; min-width: 40px;
  background: rgba(201,146,42,0.15);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  color: #C9922A; font-size: 18px;
}
.advance-notice h4 { color: #E8B84B; margin-bottom: 4px; font-size: 14px; font-weight: 700; }
.advance-notice p { color: rgba(255,255,255,0.6); font-size: 13px; line-height: 1.5; margin: 0; }
.advance-notice .upi-id {
  display: inline-block; background: rgba(201,146,42,0.15); border: 1px solid rgba(201,146,42,0.3);
  color: #E8B84B; padding: 3px 10px; border-radius: 6px; font-weight: 700; font-size: 13px;
  margin-top: 6px; font-family: monospace; letter-spacing: 0.5px;
}

/* Booking ID display in success */
.booking-id-display { 
  font-size: 22px; font-weight: 800; color: #C9922A; 
  background: rgba(201,146,42,0.1); border: 1px solid rgba(201,146,42,0.3);
  border-radius: 10px; padding: 10px 20px; display: inline-block; margin: 8px 0;
  letter-spacing: 2px; font-family: monospace;
}

/* Chat widget */
.chat-float {
  position: fixed; bottom: 90px; left: 20px; z-index: 9998;
}
.chat-btn {
  width: 54px; height: 54px; border-radius: 50%;
  background: linear-gradient(135deg, #1a56db, #0e3eb3);
  color: #fff; border: none; cursor: pointer;
  font-size: 22px; display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 20px rgba(26,86,219,0.5);
  transition: all 0.3s; position: relative;
}
.chat-btn:hover { transform: scale(1.08); }
.chat-badge {
  position: absolute; top: -4px; right: -4px;
  width: 18px; height: 18px; background: #f85149;
  border-radius: 50%; font-size: 10px; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  display: none;
}
.chat-window {
  position: fixed; bottom: 160px; left: 20px; width: 340px;
  background: #161B22; border: 1px solid rgba(255,255,255,0.1);
  border-radius: 18px; box-shadow: 0 20px 60px rgba(0,0,0,0.6);
  z-index: 9999; display: none; flex-direction: column; overflow: hidden;
  max-height: 520px;
}
.chat-window.open { display: flex; }
.chat-head {
  background: linear-gradient(135deg, #1a56db, #0e3eb3);
  padding: 16px 18px; display: flex; justify-content: space-between; align-items: center;
}
.chat-head h4 { color: #fff; font-size: 15px; margin: 0; font-weight: 700; }
.chat-head p { color: rgba(255,255,255,0.7); font-size: 11px; margin: 2px 0 0; }
.chat-close { background: none; border: none; color: rgba(255,255,255,0.7); cursor: pointer; font-size: 16px; }
.chat-setup { padding: 20px; }
.chat-setup input {
  width: 100%; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);
  color: #E6EDF3; padding: 10px 14px; border-radius: 8px; font-size: 13px;
  margin-bottom: 10px; outline: none; font-family: inherit;
}
.chat-setup input:focus { border-color: #1a56db; }
.chat-setup button {
  width: 100%; padding: 11px; background: linear-gradient(135deg, #1a56db, #0e3eb3);
  color: #fff; border: none; border-radius: 8px; font-size: 13px;
  font-weight: 700; cursor: pointer; font-family: inherit;
}
.chat-messages { flex: 1; overflow-y: auto; padding: 14px; display: flex; flex-direction: column; gap: 8px; min-height: 200px; }
.chat-msg { max-width: 82%; padding: 9px 13px; border-radius: 12px; font-size: 13px; line-height: 1.4; word-break: break-word; }
.chat-msg.from-me { background: linear-gradient(135deg, #1a56db, #0e3eb3); color: #fff; align-self: flex-end; border-bottom-right-radius: 4px; }
.chat-msg.from-admin { background: rgba(255,255,255,0.08); color: #E6EDF3; align-self: flex-start; border-bottom-left-radius: 4px; }
.chat-msg-time { font-size: 10px; opacity: 0.6; margin-top: 3px; }
.chat-input-row { display: flex; gap: 8px; padding: 12px; border-top: 1px solid rgba(255,255,255,0.07); }
.chat-input-row input {
  flex: 1; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);
  color: #E6EDF3; padding: 9px 13px; border-radius: 20px; font-size: 13px;
  outline: none; font-family: inherit;
}
.chat-input-row input:focus { border-color: #1a56db; }
.chat-input-row button {
  width: 36px; height: 36px; background: linear-gradient(135deg, #1a56db, #0e3eb3);
  border: none; border-radius: 50%; color: #fff; cursor: pointer; font-size: 15px;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.chat-empty { text-align: center; color: rgba(255,255,255,0.3); font-size: 13px; padding: 30px 20px; }
.online-dot { width: 8px; height: 8px; background: #3fb950; border-radius: 50%; display: inline-block; margin-right: 5px; animation: pulse 2s infinite; }
@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

/* Per-car pricing in card */
.car-price-summary {
  background: rgba(201,146,42,0.06);
  border: 1px solid rgba(201,146,42,0.2);
  border-radius: 10px;
  padding: 12px 14px;
  margin: 12px 0;
}
.cps-row { display: flex; justify-content: space-between; align-items: center; padding: 4px 0; font-size: 13px; }
.cps-row:not(:last-child) { border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 7px; margin-bottom: 3px; }
.cps-label { color: rgba(255,255,255,0.55); }
.cps-val { color: #E8B84B; font-weight: 700; }
.cps-val.green { color: #3fb950; }
.cps-val.muted { color: rgba(255,255,255,0.45); font-size: 12px; font-weight: 400; }

@media (max-width: 400px) {
  .chat-window { width: calc(100vw - 24px); left: 12px; }
}
</style>
</head>
<body>

<!-- Push notification bar -->
<div id="notif-bar" class="notif-bar" style="display:none">
  <span><i class="fas fa-bell"></i> Get notified about booking updates</span>
  <button onclick="requestNotificationPermission()">Enable</button>
  <button onclick="document.getElementById('notif-bar').style.display='none'" class="close-btn"><i class="fas fa-times"></i></button>
</div>

<!-- Header -->
<header class="header" id="header">
  <nav class="nav container">
    <div class="logo">
      <div class="logo-icon"><i class="fas fa-car"></i></div>
      <div>
        <h1>Brajwasi Travels</h1>
        <span>Est. 1980</span>
      </div>
    </div>
    <div class="nav-links">
      <a href="#cars">Our Fleet</a>
      <a href="#why-us">Why Us</a>
      <a href="#contact">Contact</a>
      <a href="tel:9411061000" class="call-btn"><i class="fas fa-phone"></i> Call Now</a>
    </div>
    <button class="hamburger" id="hamburger"><i class="fas fa-bars"></i></button>
  </nav>
  <div class="mobile-menu" id="mobile-menu">
    <a href="#cars">Our Fleet</a>
    <a href="#why-us">Why Us</a>
    <a href="#contact">Contact</a>
    <a href="tel:9411061000"><i class="fas fa-phone"></i> 9411061000</a>
  </div>
</header>

<!-- Hero -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="container hero-content">
    <div class="hero-badge"><i class="fas fa-star"></i> Trusted Since 1980</div>
    <h1 class="hero-title">
      Explore Agra<br>
      <em>In Comfort & Style</em>
    </h1>
    <p class="hero-subtitle">Premium cab services for Taj Mahal tours, outstation trips, and airport transfers. Your journey, our passion.</p>
    <div class="hero-actions">
      <a href="#cars" class="btn-primary"><i class="fas fa-car"></i> Explore Fleet</a>
      <a href="tel:9411061000" class="btn-outline"><i class="fas fa-phone"></i> 9411061000</a>
    </div>
    <div class="hero-stats">
      <div class="stat"><span>40+</span><em>Years Experience</em></div>
      <div class="stat-divider"></div>
      <div class="stat"><span>5000+</span><em>Happy Customers</em></div>
      <div class="stat-divider"></div>
      <div class="stat"><span>24/7</span><em>Available</em></div>
    </div>
  </div>
  <div class="scroll-indicator"><i class="fas fa-chevron-down"></i></div>
</section>

<!-- Cars Fleet Section -->
<section class="section" id="cars">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Our Fleet</span>
      <h2 class="section-title">Choose Your Ride</h2>
      <p>Well-maintained vehicles for every journey. All cars are AC equipped and driven by professional chauffeurs.</p>
    </div>

    <div class="cars-grid">
      <% if (cars.length === 0) { %>
        <div class="no-cars">
          <i class="fas fa-car-side"></i>
          <p>Fleet details coming soon. Call us at <a href="tel:9411061000">9411061000</a></p>
        </div>
      <% } else { %>
        <% cars.forEach(car => { %>
        <% 
          // Calculate fixed package display price
          const fixedKm = car.fixedPackage && car.fixedPackage.km ? car.fixedPackage.km : 0;
          const fixedPriceRaw = car.fixedPackage && car.fixedPackage.price ? car.fixedPackage.price : 0;
          // Formula: fixedKm * pricePerKm - 400 (discount baked in) but we just show the actual stored price
          const displayFixedPrice = fixedPriceRaw;
        %>
        <div class="car-card" data-car-id="<%= car._id %>">
          <div class="car-image-wrap">
            <img src="<%= car.image %>" alt="<%= car.model %>" loading="lazy" onerror="this.src='/images/default-crysta.jpg'">
            <div class="car-badge"><%= car.availableIn.join(', ') %></div>
            <% if (car.ac) { %><div class="ac-badge"><i class="fas fa-snowflake"></i> AC</div><% } %>
          </div>
          <div class="car-body">
            <div class="car-header">
              <div>
                <h3><%= car.model %></h3>
                <p class="car-brand"><%= car.name %></p>
              </div>
              <div class="car-seats"><i class="fas fa-users"></i> <%= car.seats %> Seats</div>
            </div>
            <p class="car-desc"><%= car.description || 'Comfortable and reliable vehicle for your journey.' %></p>
            
            <div class="car-price-summary">
              <% if (fixedKm > 0) { %>
              <div class="cps-row">
                <span class="cps-label"><i class="fas fa-box" style="margin-right:5px;color:#C9922A"></i> Fixed <%= fixedKm %>km Package</span>
                <span class="cps-val green">₹<%= displayFixedPrice.toLocaleString('en-IN') %></span>
              </div>
              <div class="cps-row">
                <span class="cps-label"><i class="fas fa-plus-circle" style="margin-right:5px;color:#C9922A"></i> Extra km charge</span>
                <span class="cps-val">₹<%= car.extraKmCharge %>/km</span>
              </div>
              <% } else { %>
              <div class="cps-row">
                <span class="cps-label"><i class="fas fa-road" style="margin-right:5px;color:#C9922A"></i> Per km rate</span>
                <span class="cps-val">₹<%= car.pricePerKm %>/km</span>
              </div>
              <% } %>
              <div class="cps-row">
                <span class="cps-label"><i class="fas fa-toll" style="margin-right:5px"></i> Toll tax</span>
                <span class="cps-val muted"><%= car.tollTax %></span>
              </div>
            </div>

            <button class="book-btn" type="button" onclick="openBooking('<%= car._id %>', '<%= car.model.replace(/'/g, "\\'") %>', <%= car.pricePerKm %>, <%= fixedKm %>, <%= displayFixedPrice %>, <%= car.extraKmCharge %>)">
              <i class="fas fa-calendar-check"></i> Book Now
            </button>
          </div>
        </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</section>

<!-- Why Choose Us -->
<section class="section why-section" id="why-us">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Our Promise</span>
      <h2 class="section-title">Why Brajwasi Travels?</h2>
    </div>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>
        <h3>Safe & Reliable</h3>
        <p>Licensed drivers with clean records. Regularly serviced vehicles for your safety.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon"><i class="fas fa-clock"></i></div>
        <h3>24/7 Available</h3>
        <p>Round-the-clock service for airport pickups, late-night returns, and emergency travel.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon"><i class="fas fa-rupee-sign"></i></div>
        <h3>Transparent Pricing</h3>
        <p>No hidden charges. Fixed packages and clear per-km rates. What you see is what you pay.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon"><i class="fas fa-map-marked-alt"></i></div>
        <h3>Local Expertise</h3>
        <p>40+ years serving Agra. Our drivers know every shortcut, monument, and hidden gem.</p>
      </div>
    </div>
  </div>
</section>

<!-- Contact Section -->
<section class="contact-section section" id="contact">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info">
        <span class="section-tag">Get In Touch</span>
        <h2>Book Your Ride Today</h2>
        <p>Reach us directly for instant booking or any queries. Available 24 hours, 7 days a week.</p>
        <div class="contact-items">
          <a href="tel:9411061000" class="contact-item">
            <div class="ci-icon"><i class="fas fa-phone"></i></div>
            <div><strong>Call / WhatsApp</strong><span>9411061000</span></div>
          </a>
          <a href="mailto:brajwasitravels.1980@gmail.com" class="contact-item">
            <div class="ci-icon"><i class="fas fa-envelope"></i></div>
            <div><strong>Email</strong><span>brajwasitravels.1980@gmail.com</span></div>
          </a>
          <div class="contact-item">
            <div class="ci-icon"><i class="fas fa-map-marker-alt"></i></div>
            <div><strong>Base Location</strong><span>Agra, Uttar Pradesh</span></div>
          </div>
          <a href="https://wa.me/919411061000" target="_blank" class="whatsapp-btn">
            <i class="fab fa-whatsapp"></i> Chat on WhatsApp
          </a>
        </div>
      </div>
      <div class="contact-form-wrap">
        <div class="quick-form">
          <h3>Quick Enquiry</h3>
          <form id="enquiryForm">
            <div class="form-group">
              <input type="text" placeholder="Your Name *" id="eq-name" required>
            </div>
            <div class="form-group">
              <input type="tel" placeholder="Phone Number *" id="eq-phone" required>
            </div>
            <div class="form-group">
              <input type="text" placeholder="From → To *" id="eq-route" required>
            </div>
            <div class="form-group">
              <input type="date" id="eq-date" required>
            </div>
            <button type="submit" class="btn-primary full-btn">Send Enquiry <i class="fas fa-arrow-right"></i></button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <div class="logo"><div class="logo-icon"><i class="fas fa-car"></i></div><div><h1>Brajwasi Travels</h1><span>Est. 1980</span></div></div>
      <p>Premium car rental services in Agra. Trusted by thousands of tourists and business travelers for over four decades.</p>
    </div>
    <div class="footer-links">
      <h4>Quick Links</h4>
      <a href="#cars">Our Fleet</a>
      <a href="#why-us">Why Us</a>
      <a href="#contact">Contact</a>
      <a href="tel:9411061000">Call Now</a>
    </div>
    <div class="footer-contact">
      <h4>Contact</h4>
      <p><i class="fas fa-phone"></i> 9411061000</p>
      <p><i class="fas fa-envelope"></i> brajwasitravels.1980@gmail.com</p>
      <p><i class="fas fa-map-marker-alt"></i> Agra, Uttar Pradesh</p>
    </div>
  </div>
  <div class="footer-bottom">
    <p>© 2024 Brajwasi Travels. All rights reserved. | Agra's Most Trusted Car Rental</p>
  </div>
</footer>

<!-- Floating WhatsApp -->
<a href="https://wa.me/919411061000" class="float-whatsapp" target="_blank" title="Chat on WhatsApp">
  <i class="fab fa-whatsapp"></i>
</a>

<!-- Floating Chat Button -->
<div class="chat-float">
  <button class="chat-btn" onclick="toggleChat()" id="chatToggleBtn" title="Chat with us">
    <i class="fas fa-comment-dots"></i>
    <span class="chat-badge" id="chatBadge">!</span>
  </button>
</div>

<!-- Chat Window -->
<div class="chat-window" id="chatWindow">
  <div class="chat-head">
    <div>
      <h4><i class="fas fa-headset" style="margin-right:6px"></i> Live Support</h4>
      <p><span class="online-dot"></span>Brajwasi Travels · Usually replies fast</p>
    </div>
    <button class="chat-close" onclick="toggleChat()"><i class="fas fa-times"></i></button>
  </div>
  
  <!-- Setup form (shown when no phone yet) -->
  <div id="chatSetup" class="chat-setup">
    <p style="color:rgba(255,255,255,0.5);font-size:12px;margin-bottom:14px">Enter your details to start chatting with us.</p>
    <input type="text" id="chatName" placeholder="Your Name *">
    <input type="tel" id="chatPhone" placeholder="Your Phone Number *">
    <button onclick="startChat()"><i class="fas fa-comment"></i> Start Chat</button>
  </div>

  <!-- Messages area (hidden until setup done) -->
  <div id="chatBody" style="display:none;flex-direction:column;flex:1;overflow:hidden">
    <div class="chat-messages" id="chatMessages">
      <div class="chat-empty"><i class="fas fa-comment-slash" style="font-size:28px;display:block;margin-bottom:8px"></i>No messages yet.<br>Send us a message!</div>
    </div>
    <div class="chat-input-row">
      <input type="text" id="chatInput" placeholder="Type a message..." onkeypress="if(event.key==='Enter') sendChatMsg()">
      <button onclick="sendChatMsg()"><i class="fas fa-paper-plane"></i></button>
    </div>
  </div>
</div>

<!-- Book Now Modal -->
<div class="modal-overlay" id="bookingModal">
  <div class="modal">
    <button class="modal-close" onclick="closeBooking()"><i class="fas fa-times"></i></button>
    <div class="modal-header">
      <h2>Book Your Ride</h2>
      <p id="modal-car-name">Toyota Crysta</p>
    </div>
    
    <div class="price-calculator">
      <div class="calc-row">
        <label>Estimated Distance (km)</label>
        <input type="number" id="est-km" placeholder="Enter KM" min="1" oninput="calculatePrice()">
      </div>
      <div class="calc-result" id="calc-result" style="display:none">
        <div class="calc-breakdown"></div>
        <div class="calc-total"></div>
      </div>
    </div>

    <div class="advance-notice">
      <div class="an-icon"><i class="fas fa-shield-alt"></i></div>
      <div>
        <h4>₹500 Refundable Advance</h4>
        <p>Pay ₹500 advance to confirm your booking. <strong>100% refundable</strong> if car doesn't arrive or you cancel before the car departs.</p>
        <div class="upi-id">MRBRAJWASITRAVELS.eazypay@icici</div>
      </div>
    </div>

    <form id="bookingForm">
      <input type="hidden" id="book-car-id">
      <div class="form-row">
        <div class="form-group">
          <label>Your Name *</label>
          <input type="text" id="book-name" placeholder="Full name" required>
        </div>
        <div class="form-group">
          <label>Phone Number *</label>
          <input type="tel" id="book-phone" placeholder="Mobile number" required>
        </div>
      </div>
      <div class="form-group">
        <label>Email (optional)</label>
        <input type="email" id="book-email" placeholder="your@email.com">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Pickup Location *</label>
          <input type="text" id="book-pickup" placeholder="From where?" required>
        </div>
        <div class="form-group">
          <label>Drop Location *</label>
          <input type="text" id="book-drop" placeholder="Where to?" required>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Journey Date *</label>
          <input type="date" id="book-date" required>
        </div>
        <div class="form-group">
          <label>Journey Time *</label>
          <input type="time" id="book-time" required>
        </div>
      </div>
      <div class="form-group">
        <label>Special Instructions</label>
        <textarea id="book-notes" placeholder="Any special requirements..." rows="2"></textarea>
      </div>
      <button type="submit" class="btn-primary full-btn book-submit">
        <i class="fas fa-check-circle"></i> Confirm Booking
      </button>
    </form>
  </div>
</div>

<!-- Success Modal -->
<div class="modal-overlay" id="successModal">
  <div class="modal success-modal">
    <div class="success-icon"><i class="fas fa-check-circle"></i></div>
    <h2>Booking Confirmed!</h2>
    <p id="success-booking-id" class="booking-id-display"></p>
    <p style="font-size:13px;color:rgba(255,255,255,0.6);margin:8px 0">Save this ID for reference</p>
    <div class="advance-notice" style="margin:16px 0;text-align:left">
      <div class="an-icon"><i class="fas fa-university"></i></div>
      <div>
        <h4>Pay ₹500 Advance to Confirm</h4>
        <p>UPI ID: <strong>MRBRAJWASITRAVELS.eazypay@icici</strong><br>Refundable if car doesn't arrive or cancelled before car departs.</p>
