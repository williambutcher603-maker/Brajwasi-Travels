    </div>
    <form id="bookingForm">
      <input type="hidden" id="bookCarId">
      <div class="form-row">
        <div class="form-group"><label>Your Name *</label><input type="text" id="bkName" required></div>
        <div class="form-group"><label>Phone *</label><input type="tel" id="bkPhone" required></div>
      </div>
      <div class="form-group"><label>Email (optional)</label><input type="email" id="bkEmail"></div>
      <div class="form-row">
        <div class="form-group"><label>Pickup Location *</label><input type="text" id="bkPickup" placeholder="From where?" required></div>
        <div class="form-group"><label>Drop Location *</label><input type="text" id="bkDrop" placeholder="Where to?" required></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Journey Date *</label><input type="date" id="bkDate" required></div>
        <div class="form-group"><label>Journey Time *</label><input type="time" id="bkTime" required></div>
      </div>
      <div class="form-group"><label>Special Instructions</label><textarea id="bkNotes" rows="2"></textarea></div>
      <button type="submit" class="btn-primary full-btn" id="bookSubmitBtn"><i class="fas fa-check-circle"></i> Confirm Booking</button>
    </form>
  </div>
</div>

