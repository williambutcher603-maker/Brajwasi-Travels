// ═══════════════════════════════════════════════
//  FEEDBACK (TESTIMONIALS)
// ═══════════════════════════════════════════════
function wireFeedback(){
  var picker=document.getElementById('starPicker');
  if(picker){
    Array.from(picker.querySelectorAll('i')).forEach(function(star){
      star.addEventListener('click',function(){
        fbRating=+star.dataset.val;
        document.getElementById('fbRating').value=fbRating;
        Array.from(picker.querySelectorAll('i')).forEach(function(s,i){s.classList.toggle('active',i<fbRating);});
      });
      star.addEventListener('mouseover',function(){
        Array.from(picker.querySelectorAll('i')).forEach(function(s,i){s.style.color=i<+star.dataset.val?'#F59E0B':'#E8DDD0';});
      });
      star.addEventListener('mouseout',function(){
        Array.from(picker.querySelectorAll('i')).forEach(function(s,i){s.style.color=i<fbRating?'#F59E0B':'#E8DDD0';});
      });
    });
  }
  var charEl=document.getElementById('fbMsg'),cc=document.getElementById('fbCharCount');
  if(charEl&&cc)charEl.addEventListener('input',function(){cc.textContent=this.value.length+' / 500';});
  var form=document.getElementById('feedbackForm');
  if(!form)return;
  form.addEventListener('submit',function(e){
    e.preventDefault();
    if(!fbRating){toast('Please select a star rating','error');return;}
    var btn=document.getElementById('fbSubmitBtn');
    btn.innerHTML='<i class="fas fa-spinner fa-spin"></i> Submitting...'; btn.disabled=true;
    fetch('/api/testimonials',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
      name:document.getElementById('fbName').value,
      phone:document.getElementById('fbPhone').value,
      rating:fbRating,
      message:document.getElementById('fbMsg').value
    })}).then(function(r){return r.json();}).then(function(d){
      if(d.success){
        closeFeedback(); form.reset(); fbRating=0;
        var stars=document.getElementById('starPicker');
        if(stars)Array.from(stars.querySelectorAll('i')).forEach(function(s){s.classList.remove('active');});
        toast('Thank you! Your review will appear after approval.','success');
      }else{toast(d.error||'Failed to submit','error');}
      btn.innerHTML='<i class="fas fa-paper-plane"></i> Submit Review'; btn.disabled=false;
    }).catch(function(){toast('Network error. Please try again.','error');btn.innerHTML='<i class="fas fa-paper-plane"></i> Submit Review';btn.disabled=false;});
  });
}

// ═══════════════════════════════════════════════
//  UTILS
// ═══════════════════════════════════════════════
function toast(msg,type){
  document.querySelector('.toast-msg')&&document.querySelector('.toast-msg').remove();
  var t=document.createElement('div'); t.className='toast-msg';
  var c={success:['#EAF7EE','#1A7A3A'],error:['#FDEDEB','#C0392B'],info:['#EEF4FF','#1A5DAB']}[type]||['#EAF7EE','#1A7A3A'];
  t.style.cssText='position:fixed;bottom:90px;right:20px;z-index:999999;background:'+c[0]+';border:1px solid '+c[1]+';color:'+c[1]+';padding:13px 18px;border-radius:10px;font-size:14px;font-weight:600;box-shadow:0 4px 20px rgba(0,0,0,.12);max-width:320px;font-family:DM Sans,sans-serif;';
  t.textContent=msg; document.body.appendChild(t);
  setTimeout(function(){t.remove();},4000);
}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
