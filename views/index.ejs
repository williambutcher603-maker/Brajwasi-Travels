function renderLoginBar(user) {
  var ids = ['loginBar','mobileLoginBar'];
  for (var i=0; i<ids.length; i++) {
    var bar = document.getElementById(ids[i]);
    if (!bar) continue;
    if (user) {
      bar.innerHTML = '<span style="font-size:13px;color:#7A6A55"><i class="fas fa-user-circle" style="color:#B8780A;margin-right:5px"></i>' + _esc(user.name) + '</span><button onclick="logoutUser()" style="background:none;border:1px solid #E8DDD0;color:#7A6A55;padding:5px 11px;border-radius:8px;font-size:12px;cursor:pointer;font-family:inherit;margin-left:6px">Logout</button>';
    } else {
      bar.innerHTML = '<button onclick="showModal('loginModal')" style="display:inline-flex;align-items:center;gap:6px;background:#FFF8EC;border:1px solid rgba(184,120,10,.3);color:#8A5A06;padding:7px 14px;border-radius:8px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit"><i class="fas fa-user-circle"></i>Login</button>';
    }
  }
}
}
function logoutUser() {
  fetch('/api/auth/logout', { method: 'POST' }).then(function() { _session = null; renderLoginBar(null); });
}
