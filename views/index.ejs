.star-picker{display:flex;gap:6px;margin-bottom:6px;}
.star-picker i{font-size:28px;color:#E8DDD0;cursor:pointer;transition:color .15s;}
.star-picker i.active,.star-picker i:hover{color:#F59E0B;}
</style>


<!-- LOGIN MODAL (OTP) -->
<div class="modal-overlay" id="loginModal">
  <div class="modal" style="max-width:440px">
    <button class="modal-close" id="closeLoginBtn"><i class="fas fa-times"></i></button>
    <div class="modal-header">
      <h2><i class="fas fa-lock" style="color:var(--gold);margin-right:8px"></i>Login to Book</h2>
      <p>Enter your email to receive a one-time password</p>
    </div>
    <div id="otpAlert"></div>
    <!-- Step 1: Enter email -->
    <div id="otpStep1">
      <div class="form-group"><label>Your Name</label><input type="text" id="otpNameIn" placeholder="Full name (optional)" autocomplete="name"></div>
      <div class="form-group"><label>Email Address *</label><input type="email" id="otpEmailIn" placeholder="you@example.com" autocomplete="email" required></div>
      <button class="btn-primary full-btn" id="sendOtpBtn" style="margin-top:8px">
        <i class="fas fa-paper-plane"></i> Send OTP to Email
      </button>
      <p style="text-align:center;font-size:12px;color:var(--light);margin-top:12px">We send a 6-digit code to your email. No password needed.</p>
    </div>
    <!-- Step 2: Enter OTP -->
    <div id="otpStep2" style="display:none">
      <div style="background:var(--gold-bg);border:1px solid rgba(184,120,10,.2);border-radius:10px;padding:14px 16px;margin-bottom:16px;text-align:center">
        <p style="font-size:13px;color:var(--muted)">OTP sent to <strong id="otpEmailDisplay"></strong></p>
        <p style="font-size:12px;color:var(--light);margin-top:4px">Check your inbox (and spam folder)</p>
      </div>
      <div class="form-group"><label>Enter 6-Digit OTP *</label><input type="text" id="otpCodeIn" placeholder="e.g. 482916" maxlength="6" autocomplete="one-time-code" style="text-align:center;font-size:22px;letter-spacing:8px;font-weight:800"></div>
      <button class="btn-primary full-btn" id="verifyOtpBtn">
        <i class="fas fa-check"></i> Verify & Login
      </button>
      <button onclick="document.getElementById('otpStep1').style.display='block';document.getElementById('otpStep2').style.display='none'" style="display:block;width:100%;margin-top:10px;padding:10px;background:none;border:1px solid var(--border);border-radius:var(--r);color:var(--muted);cursor:pointer;font-size:13px;font-family:inherit">
        ← Use a different email
      </button>
    </div>
  </div>
</div>
