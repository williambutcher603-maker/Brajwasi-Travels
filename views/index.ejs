</section>

<!-- TESTIMONIALS -->
<section class="section testimonials-section" id="testimonials">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">What Customers Say</span>
      <h2 class="section-title">Real Reviews From Real Travellers</h2>
      <p>Honest feedback from customers who travelled with us. Every review is verified.</p>
    </div>

    <!-- Testimonials grid -->
    <div class="testi-grid" id="testiGrid">
      <% if(!testimonials || !testimonials.length){ %>
      <div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--muted)">
        <i class="fas fa-comment-slash" style="font-size:36px;color:var(--border);display:block;margin-bottom:12px"></i>
        <p>No reviews yet. Be the first to share your experience!</p>
      </div>
      <% } else { testimonials.forEach(t => { %>
      <div class="testi-card">
        <div class="testi-stars">
          <% for(let i=1;i<=5;i++){ %><i class="fas fa-star" style="color:<%= i<=t.rating ? '#F59E0B' : '#E8DDD0' %>"></i><% } %>
        </div>
        <p class="testi-msg">"<%= t.message %>"</p>
        <div class="testi-author">
          <div class="testi-avatar"><%= t.name.charAt(0).toUpperCase() %></div>
          <div>
            <div class="testi-name"><%= t.name %></div>
            <div class="testi-date"><%= new Date(t.createdAt).toLocaleDateString('en-IN',{month:'short',year:'numeric'}) %></div>
          </div>
        </div>
      </div>
      <% }) } %>
    </div>

    <!-- Leave a review button -->
    <div style="text-align:center;margin-top:36px">
      <button class="btn-primary" onclick="openFeedback()" style="display:inline-flex">
        <i class="fas fa-star"></i> Share Your Experience
      </button>
    </div>
  </div>
</section>

