<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Track Booking – Brajwasi Tour & Travels</title>
<link rel="icon" type="image/png" href="/images/favicon.png">
<meta name="theme-color" content="#B8780A">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
:root{--gold:#B8780A;--gold-l:#D4920E;--gold-d:#8A5A06;--gold-bg:#FFF8EC;--bg:#fff;--bg2:#F8F5F0;--bg3:#F0EBE3;--border:#E8DDD0;--text:#1A1208;--muted:#7A6A55;--light:#A0917E;--green:#1A7A3A;--green-bg:#EAF7EE;--red:#C0392B;--red-bg:#FDEDEB;--blue:#1A5DAB;--blue-bg:#EEF4FF;}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--bg2);color:var(--text);min-height:100vh;}
.header{background:var(--bg);border-bottom:1px solid var(--border);padding:14px 20px;display:flex;align-items:center;gap:14px;box-shadow:0 2px 12px rgba(184,120,10,.08);}
.logo-icon{width:40px;height:40px;background:linear-gradient(135deg,var(--gold-l),var(--gold-d));border-radius:9px;display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0;}
.logo-icon img{width:100%;height:100%;object-fit:cover;border-radius:9px;}
.logo h1{font-family:'Playfair Display',serif;font-size:16px;color:var(--text);}
.logo span{font-size:10px;color:var(--gold);letter-spacing:1.5px;text-transform:uppercase;}
.back-btn{margin-left:auto;display:inline-flex;align-items:center;gap:6px;color:var(--muted);text-decoration:none;font-size:13px;font-weight:600;padding:7px 14px;border:1px solid var(--border);border-radius:8px;background:var(--bg);transition:all .2s;}
.back-btn:hover{color:var(--gold);border-color:var(--gold);}
.page{max-width:720px;margin:0 auto;padding:28px 20px;}
.search-card{background:var(--bg);border:1px solid var(--border);border-radius:16px;padding:28px;box-shadow:0 2px 16px rgba(184,120,10,.08);margin-bottom:24px;}
.search-card h2{font-family:'Playfair Display',serif;font-size:24px;margin-bottom:6px;}
.search-card p{color:var(--muted);font-size:14px;margin-bottom:20px;}
.search-row{display:flex;gap:10px;flex-wrap:wrap;}
.search-row input{flex:1;min-width:200px;background:var(--bg2);border:1px solid var(--border);color:var(--text);padding:11px 16px;border-radius:10px;font-size:14px;font-family:'DM Sans',sans-serif;outline:none;}
.search-row input:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(184,120,10,.1);}
.search-btn{padding:11px 24px;background:linear-gradient(135deg,var(--gold-l),var(--gold-d));color:#fff;border:none;border-radius:10px;font-weight:700;font-size:14px;cursor:pointer;font-family:'DM Sans',sans-serif;white-space:nowrap;display:flex;align-items:center;gap:7px;}
.search-btn:hover{opacity:.9;}
.or-div{display:flex;align-items:center;gap:10px;margin:14px 0;color:var(--light);font-size:13px;}
.or-div::before,.or-div::after{content:'';flex:1;height:1px;background:var(--border);}
.result-card{background:var(--bg);border:1px solid var(--border);border-radius:16px;overflow:hidden;box-shadow:0 2px 16px rgba(184,120,10,.08);display:none;}
.result-header{padding:20px 24px;background:var(--gold-bg);border-bottom:1px solid rgba(184,120,10,.2);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;}
.booking-id-lbl{font-family:monospace;font-size:18px;font-weight:800;color:var(--gold-d);letter-spacing:1px;}
.status-badge{display:inline-flex;align-items:center;gap:5px;padding:6px 14px;border-radius:20px;font-size:13px;font-weight:700;}
.st-pending{background:rgba(184,120,10,.12);color:var(--gold-d);border:1px solid rgba(184,120,10,.25);}
.st-confirmed{background:var(--green-bg);color:var(--green);border:1px solid rgba(26,122,58,.25);}
.st-completed{background:var(--blue-bg);color:var(--blue);border:1px solid rgba(26,93,171,.25);}
.st-cancelled{background:var(--red-bg);color:var(--red);border:1px solid rgba(192,57,43,.2);}
.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:0;padding:0;}
.info-row{padding:14px 24px;border-bottom:1px solid var(--border);display:flex;align-items:flex-start;gap:12px;}
.info-row:nth-child(odd){background:var(--bg2);}
.info-icon{width:32px;height:32px;background:var(--gold-bg);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--gold);font-size:13px;flex-shrink:0;}
.info-label{font-size:11px;color:var(--light);text-transform:uppercase;letter-spacing:.5px;font-weight:700;margin-bottom:2px;}
.info-val{font-size:14px;font-weight:600;color:var(--text);}
.adv-status{padding:16px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px;}
.adv-paid{background:var(--green-bg);border-radius:10px;padding:10px 16px;color:var(--green);font-weight:700;font-size:13px;flex:1;display:flex;align-items:center;gap:8px;}
.adv-unpaid{background:var(--gold-bg);border-radius:10px;padding:10px 16px;color:var(--gold-d);font-weight:700;font-size:13px;flex:1;display:flex;align-items:center;gap:8px;}
.map-section{padding:20px 24px;}
.map-section h3{font-size:15px;font-weight:700;margin-bottom:12px;display:flex;align-items:center;gap:8px;}
#trackMap{height:300px;border-radius:12px;border:1px solid var(--border);overflow:hidden;}
.no-location{background:var(--bg3);border:1px solid var(--border);border-radius:12px;padding:24px;text-align:center;color:var(--muted);font-size:13px;}
.no-location i{font-size:28px;color:var(--border);display:block;margin-bottom:8px;}
.confirmed-notice{background:var(--green-bg);border:1px solid rgba(26,122,58,.25);border-radius:12px;padding:16px 20px;margin:16px 24px;display:flex;align-items:center;gap:12px;font-size:14px;color:var(--green);font-weight:600;}
.confirmed-notice i{font-size:20px;}
.pending-notice{background:var(--gold-bg);border:1px solid rgba(184,120,10,.25);border-radius:12px;padding:16px 20px;margin:16px 24px;display:flex;align-items:center;gap:12px;font-size:14px;color:var(--gold-d);font-weight:600;}
.error-box{background:var(--red-bg);border:1px solid rgba(192,57,43,.2);border-radius:12px;padding:18px 20px;text-align:center;color:var(--red);font-size:14px;font-weight:600;display:none;margin-top:12px;}
.refresh-btn{margin:12px 24px 20px;display:inline-flex;align-items:center;gap:7px;padding:9px 20px;background:var(--bg2);border:1px solid var(--border);color:var(--muted);border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s;}
.refresh-btn:hover{color:var(--gold);border-color:var(--gold);}
@media(max-width:600px){.info-grid{grid-template-columns:1fr;}.search-row{flex-direction:column;}}
</style>
</head>
<body>
<div class="header">
  <div class="logo-icon"><img src="/images/favicon.png" alt="BT" onerror="this.style.display='none';this.parentNode.innerHTML='<i class=\'fas fa-car\' style=\'color:#fff\'></i>'"></div>
  <div class="logo"><h1>Brajwasi Tour & Travels</h1><span>Est. 2018 · Agra</span></div>
  <a href="/" class="back-btn"><i class="fas fa-arrow-left"></i> Back to Home</a>
</div>

<div class="page">
  <div class="search-card">
    <h2><i class="fas fa-map-marker-alt" style="color:var(--gold);margin-right:8px"></i>Track Your Booking</h2>
    <p>Enter your Booking ID or phone number to see real-time status and driver location.</p>
    <div class="search-row">
      <input type="text" id="trackInput" placeholder="Booking ID (e.g. BT-A1B2C3)" autocomplete="off" style="text-transform:uppercase">
      <button class="search-btn" onclick="doTrack()"><i class="fas fa-search"></i> Track</button>
    </div>
    <div class="or-div">or</div>
    <div class="search-row">
      <input type="tel" id="phoneInput" placeholder="Your phone number" autocomplete="tel">
      <button class="search-btn" onclick="doTrackPhone()"><i class="fas fa-phone"></i> Track by Phone</button>
    </div>
    <div class="error-box" id="errBox"><i class="fas fa-exclamation-circle" style="margin-right:8px"></i><span id="errMsg"></span></div>
  </div>

  <div class="result-card" id="resultCard">
    <div class="result-header">
      <div>
        <div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px">Booking</div>
        <div class="booking-id-lbl" id="resBookingId"></div>
      </div>
      <div class="status-badge" id="resBadge"></div>
    </div>

    <div id="confirmedNotice" style="display:none" class="confirmed-notice"><i class="fas fa-check-circle"></i>Your booking is confirmed! Our driver will arrive on time.</div>
    <div id="pendingNotice" style="display:none" class="pending-notice"><i class="fas fa-clock"></i>Your booking is pending confirmation. We'll call you shortly.</div>

    <div class="info-grid">
      <div class="info-row"><div class="info-icon"><i class="fas fa-user"></i></div><div><div class="info-label">Customer</div><div class="info-val" id="resCust"></div></div></div>
      <div class="info-row"><div class="info-icon"><i class="fas fa-car"></i></div><div><div class="info-label">Car</div><div class="info-val" id="resCar"></div></div></div>
      <div class="info-row"><div class="info-icon"><i class="fas fa-map-marker-alt"></i></div><div><div class="info-label">Pickup</div><div class="info-val" id="resPickup"></div></div></div>
      <div class="info-row"><div class="info-icon"><i class="fas fa-flag"></i></div><div><div class="info-label">Drop</div><div class="info-val" id="resDrop"></div></div></div>
      <div class="info-row"><div class="info-icon"><i class="fas fa-calendar"></i></div><div><div class="info-label">Journey Date</div><div class="info-val" id="resDate"></div></div></div>
      <div class="info-row"><div class="info-icon"><i class="fas fa-clock"></i></div><div><div class="info-label">Journey Time</div><div class="info-val" id="resTime"></div></div></div>
      <div class="info-row" style="grid-column:1/-1"><div class="info-icon"><i class="fas fa-rupee-sign"></i></div><div><div class="info-label">Estimated Fare</div><div class="info-val" id="resFare"></div></div></div>
    </div>

    <div class="adv-status" id="advSection"></div>

    <div class="map-section">
      <h3><i class="fas fa-satellite" style="color:var(--gold)"></i>Driver Location</h3>
      <div id="mapWrap">
        <div class="no-location" id="noLocation"><i class="fas fa-map-marked-alt"></i>Driver location will appear here once your booking is confirmed and the driver is on the way.</div>
        <div id="trackMap" style="display:none"></div>
      </div>
    </div>

    <button class="refresh-btn" id="refreshBtn"><i class="fas fa-sync-alt"></i> Refresh Status</button>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
let map = null;
let driverMarker = null;
let currentTrackId = null;
let trackRefresh = null;

// Auto-track from URL param
window.addEventListener('load', () => {
  const p = new URLSearchParams(location.search);
  const bid = p.get('bookingId') || p.get('phone');
  if (bid) {
    if (bid.startsWith('BT-') || bid.match(/^[A-Z0-9-]+$/i)) {
      document.getElementById('trackInput').value = bid.toUpperCase();
      doTrack();
    } else {
      document.getElementById('phoneInput').value = bid;
      doTrackPhone();
    }
  }
  document.getElementById('trackInput').addEventListener('keypress', e => { if (e.key === 'Enter') doTrack(); });
  document.getElementById('phoneInput').addEventListener('keypress', e => { if (e.key === 'Enter') doTrackPhone(); });
  document.getElementById('refreshBtn').addEventListener('click', () => {
    if (currentTrackId) fetchBooking('/api/track?bookingId=' + currentTrackId);
  });
});

async function doTrack() {
  const v = document.getElementById('trackInput').value.trim().toUpperCase();
  if (!v) { showErr('Please enter a Booking ID'); return; }
  await fetchBooking('/api/track?bookingId=' + encodeURIComponent(v));
}
async function doTrackPhone() {
  const v = document.getElementById('phoneInput').value.trim();
  if (!v) { showErr('Please enter your phone number'); return; }
  await fetchBooking('/api/track?phone=' + encodeURIComponent(v));
}

async function fetchBooking(url) {
  hideErr();
  try {
    const r = await fetch(url);
    if (!r.ok) { const d = await r.json(); showErr(d.error || 'Booking not found'); return; }
    const d = await r.json();
    currentTrackId = d.bookingId;
    renderBooking(d);
    // Auto-refresh every 20s for confirmed bookings
    clearInterval(trackRefresh);
    if (d.status === 'confirmed') {
      trackRefresh = setInterval(() => fetchBooking('/api/track?bookingId=' + currentTrackId), 20000);
    }
  } catch(e) { showErr('Network error. Please try again.'); }
}

function renderBooking(d) {
  document.getElementById('resBookingId').textContent = d.bookingId;
  document.getElementById('resCust').textContent = d.customerName;
  document.getElementById('resCar').textContent = d.carName || '—';
  document.getElementById('resPickup').textContent = d.pickupLocation;
  document.getElementById('resDrop').textContent = d.dropLocation;
  document.getElementById('resDate').textContent = new Date(d.journeyDate).toLocaleDateString('en-IN', { day: '2-digit', month: 'long', year: 'numeric' });
  document.getElementById('resTime').textContent = d.journeyTime || '—';
  document.getElementById('resFare').textContent = d.totalPrice ? '₹' + d.totalPrice.toLocaleString('en-IN') : 'Will be calculated';

  // Status badge
  const badge = document.getElementById('resBadge');
  const sc = { pending: ['st-pending','⏳'], confirmed: ['st-confirmed','✅'], completed: ['st-completed','🏁'], cancelled: ['st-cancelled','❌'] };
  const [cls, emoji] = sc[d.status] || ['st-pending','⏳'];
  badge.className = 'status-badge ' + cls;
  badge.textContent = emoji + ' ' + d.status.charAt(0).toUpperCase() + d.status.slice(1);

  // Notices
  document.getElementById('confirmedNotice').style.display = d.status === 'confirmed' ? 'flex' : 'none';
  document.getElementById('pendingNotice').style.display = d.status === 'pending' ? 'flex' : 'none';

  // Advance
  const advEl = document.getElementById('advSection');
  advEl.innerHTML = d.advancePaid
    ? '<div class="adv-paid"><i class="fas fa-check-circle"></i> ₹500 Advance Paid – Booking Secured</div>'
    : '<div class="adv-unpaid"><i class="fas fa-exclamation-circle"></i> ₹500 Advance Pending – Pay to confirm</div>';

  // Map
  if (d.driverLat && d.driverLng) {
    document.getElementById('noLocation').style.display = 'none';
    const mapEl = document.getElementById('trackMap');
    mapEl.style.display = 'block';
    if (!map) {
      map = L.map('trackMap').setView([d.driverLat, d.driverLng], 14);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' }).addTo(map);
    } else { map.setView([d.driverLat, d.driverLng], 14); }
    const icon = L.divIcon({ html: '<div style="background:#B8780A;color:#fff;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;box-shadow:0 2px 8px rgba(0,0,0,.3);border:2px solid #fff">🚗</div>', iconSize: [36,36], iconAnchor: [18,18], className: '' });
    if (!driverMarker) driverMarker = L.marker([d.driverLat, d.driverLng], { icon }).addTo(map);
    else driverMarker.setLatLng([d.driverLat, d.driverLng]);
    const lastSeen = d.driverLastSeen ? new Date(d.driverLastSeen).toLocaleTimeString('en-IN') : 'unknown';
    driverMarker.bindPopup(`<b>Driver Location</b><br>Last updated: ${lastSeen}`).openPopup();
  } else {
    document.getElementById('noLocation').style.display = 'block';
    document.getElementById('trackMap').style.display = 'none';
  }

  document.getElementById('resultCard').style.display = 'block';
  document.getElementById('resultCard').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function showErr(msg) {
  document.getElementById('errMsg').textContent = msg;
  document.getElementById('errBox').style.display = 'block';
  document.getElementById('resultCard').style.display = 'none';
}
function hideErr() { document.getElementById('errBox').style.display = 'none'; }
</script>
</body>
</html>
